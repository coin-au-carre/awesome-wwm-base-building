---
import "@/styles/global.css"

interface Props {
  title?: string
  description?: string
}

const {
  title = "Awesome WWM Base Building",
  description = "Discover the most beautiful constructions in Jiang Hu 🏯",
} = Astro.props

const base = import.meta.env.BASE_URL.replace(/\/$/, "")

const navLinks = [
  { href: `${base}/`, label: "Guild Bases" },
  { href: `${base}/solo`, label: "Solo Builds" },
  { href: `${base}/scoring`, label: "Scoring" },
  { href: `${base}/about`, label: "About" },
  { href: `${base}/contribute`, label: "Contribute" },
]

const currentPath = Astro.url.pathname.replace(/\/$/, "") || `${base}/`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="I2hHH7CU14QUGQNoWsiZPqkRVcfLky_Add6wnUzXbzc" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <title>{title}</title>
    <!-- Google Tag Manager -->
    <script is:inline>
      ;(function (w, d, s, l, i) {
        w[l] = w[l] || []
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" })
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : ""
        j.async = true
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl
        f.parentNode.insertBefore(j, f)
      })(window, document, "script", "dataLayer", "GTM-NJQF6GDD")
    </script>
  </head>
  <body>
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-NJQF6GDD"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe>
    </noscript>

    <!-- Top nav -->
    <header class="sticky top-0 z-50 border-b border-border bg-background/90 backdrop-blur-sm">
      <div class="mx-auto max-w-7xl px-4">
        <div class="flex h-14 items-center justify-between gap-4">
          <!-- Logo -->
          <a
            href={`${base}/`}
            class="shrink-0 font-heading font-semibold text-sm hover:text-primary transition-colors"
          >
            🏯 <span class="hidden sm:inline">Awesome WWM</span><span class="sm:hidden">WWM</span>
          </a>

          <!-- Desktop nav -->
          <nav class="hidden md:flex items-center gap-1">
            {
              navLinks.map((link) => {
                const isActive =
                  link.href === `${base}/`
                    ? currentPath === `${base}/` || currentPath === base
                    : currentPath.startsWith(link.href)
                return (
                  <a
                    href={link.href}
                    class={[
                      "rounded-md px-3 py-1.5 text-sm transition-colors",
                      isActive
                        ? "bg-muted font-medium text-foreground"
                        : "text-muted-foreground hover:text-foreground hover:bg-muted/60",
                    ].join(" ")}
                  >
                    {link.label}
                  </a>
                )
              })
            }
          </nav>

          <div class="flex items-center gap-2">
            <!-- Discord CTA -->
            <a
              href="https://discord.gg/Qygt9u26Bn"
              target="_blank"
              rel="noopener noreferrer"
              class="hidden sm:inline-flex items-center gap-1.5 rounded-full bg-primary px-3 py-1.5 text-xs font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
            >
              Discord ↗
            </a>

            <!-- Mobile hamburger -->
            <button
              id="menu-toggle"
              aria-label="Toggle menu"
              class="md:hidden flex flex-col gap-1 p-2 rounded-md hover:bg-muted transition-colors"
            >
              <span class="block w-5 h-px bg-foreground transition-all" id="bar1"></span>
              <span class="block w-5 h-px bg-foreground transition-all" id="bar2"></span>
              <span class="block w-5 h-px bg-foreground transition-all" id="bar3"></span>
            </button>
          </div>
        </div>

        <!-- Mobile menu -->
        <div id="mobile-menu" class="hidden md:hidden pb-3 space-y-1 border-t border-border pt-3">
          {
            navLinks.map((link) => {
              const isActive =
                link.href === `${base}/`
                  ? currentPath === `${base}/` || currentPath === base
                  : currentPath.startsWith(link.href)
              return (
                <a
                  href={link.href}
                  class={[
                    "block rounded-md px-3 py-2 text-sm transition-colors",
                    isActive
                      ? "bg-muted font-medium text-foreground"
                      : "text-muted-foreground hover:text-foreground hover:bg-muted/60",
                  ].join(" ")}
                >
                  {link.label}
                </a>
              )
            })
          }
          <a
            href="https://discord.gg/Qygt9u26Bn"
            target="_blank"
            rel="noopener noreferrer"
            class="block rounded-md px-3 py-2 text-sm text-primary font-medium"
          >
            Discord ↗
          </a>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-4 py-8">
      <slot />
    </main>

    <footer class="border-t border-border mt-16 py-6 text-center text-sm text-muted-foreground">
      2026 — Made with ❤️ by the{" "}
      <a
        href="https://discord.gg/Qygt9u26Bn"
        class="underline hover:text-foreground transition-colors"
      >
        Awesome WWM building community
      </a>
    </footer>

    <script is:inline>
      const toggle = document.getElementById("menu-toggle")
      const menu = document.getElementById("mobile-menu")
      const bar1 = document.getElementById("bar1")
      const bar2 = document.getElementById("bar2")
      const bar3 = document.getElementById("bar3")
      let open = false
      toggle.addEventListener("click", () => {
        open = !open
        menu.classList.toggle("hidden", !open)
        bar1.style.transform = open ? "translateY(8px) rotate(45deg)" : ""
        bar2.style.opacity = open ? "0" : "1"
        bar3.style.transform = open ? "translateY(-8px) rotate(-45deg)" : ""
      })
    </script>
  </body>
</html>
