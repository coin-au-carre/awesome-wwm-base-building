---
import type { ScreenshotSection } from "@/types/guild"
import { thumbUrl } from "@/lib/format"

interface Props {
  screenshots?: string[]
  screenshotSections?: ScreenshotSection[]
  videos?: string[]
}

const { screenshots = [], screenshotSections, videos = [] } = Astro.props

// Use sections if present and at least one has a label; otherwise fall back to flat list.
const hasSections = screenshotSections && screenshotSections.length > 0 && screenshotSections.some(s => s.label)
const sections: ScreenshotSection[] = hasSections
  ? screenshotSections!
  : screenshots.length > 0 ? [{ screenshots }] : []

// Assign global lightbox indices across all sections.
let globalIndex = 0
const sectionsWithIndex: { label?: string; items: { src: string; index: number }[] }[] = sections.map(s => ({
  label: s.label,
  items: (s.screenshots ?? []).map(src => ({ src, index: globalIndex++ })),
}))

function youtubeVideoID(rawURL: string): string {
  try {
    const u = new URL(rawURL)
    if (u.hostname === "youtu.be") return u.pathname.replace(/^\//, "")
    if (u.hostname === "www.youtube.com" || u.hostname === "youtube.com") {
      return u.searchParams.get("v") ?? ""
    }
    return ""
  } catch {
    return ""
  }
}

function tiktokVideoID(rawURL: string): string {
  try {
    const u = new URL(rawURL)
    if (u.hostname === "www.tiktok.com" || u.hostname === "tiktok.com") {
      const m = u.pathname.match(/\/video\/(\d+)/)
      return m ? m[1] : ""
    }
    return ""
  } catch {
    return ""
  }
}

function isTiktokURL(rawURL: string): boolean {
  try {
    const h = new URL(rawURL).hostname
    return h === "www.tiktok.com" || h === "tiktok.com" || h === "vt.tiktok.com"
  } catch {
    return false
  }
}
---

{
  videos.length > 0 && (
    <section>
      <h3 class="text-sm font-medium text-muted-foreground mb-3">Videos</h3>
      <div class="space-y-4">
        {videos.map((v) => {
          const ytID = youtubeVideoID(v)
          const ttID = tiktokVideoID(v)
          if (ytID) return (
            <div class="aspect-video w-full max-w-4xl mx-auto overflow-hidden rounded-xl">
              <iframe
                src={`https://www.youtube.com/embed/${ytID}`}
                title="Guild video"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                class="h-full w-full"
              />
            </div>
          )
          if (ttID) return (
            <div class="aspect-video w-full max-w-4xl mx-auto overflow-hidden rounded-xl">
              <iframe
                src={`https://www.tiktok.com/embed/v2/${ttID}`}
                title="TikTok video"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                class="h-full w-full border-0"
              />
            </div>
          )
          if (isTiktokURL(v)) return (
            <div class="aspect-video w-full max-w-4xl mx-auto overflow-hidden rounded-xl bg-muted flex items-center justify-center">
              <a href={v} target="_blank" rel="noopener noreferrer" class="flex flex-col items-center gap-2 text-muted-foreground hover:text-foreground transition-colors">
                <svg class="w-10 h-10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/></svg>
                <span class="text-sm font-medium">Watch on TikTok</span>
              </a>
            </div>
          )
          return (
            <div class="aspect-video w-full overflow-hidden rounded-xl bg-muted">
              <video src={v} controls class="h-full w-full object-cover" />
            </div>
          )
        })}
      </div>
    </section>
  )
}

{
  sectionsWithIndex.length > 0 && (
    <section class="space-y-6">
      <h3 class="text-sm font-medium text-muted-foreground">
        Screenshots <span class="text-xs font-normal text-muted-foreground/60">· click to enlarge</span>
      </h3>
      {sectionsWithIndex.map(sec => (
        <div>
          {sec.label && (
            <p class="text-sm font-medium mb-2">{sec.label}</p>
          )}
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            {sec.items.map(({ src, index }) => (
              <button
                type="button"
                class="lightbox-trigger group relative w-full overflow-hidden rounded-xl ring-1 ring-border focus:outline-none focus:ring-2 focus:ring-primary"
                data-src={src}
                data-thumb={thumbUrl(src)}
                data-index={index}
              >
                <img
                  src={thumbUrl(src)}
                  alt={`Screenshot ${index + 1}`}
                  loading="lazy"
                  decoding="async"
                  onerror="this.closest('button').style.display='none'"
                  class="w-full object-cover aspect-video transition-transform duration-300 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors flex items-center justify-center">
                  <svg class="opacity-0 group-hover:opacity-100 transition-opacity w-8 h-8 text-white drop-shadow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15" />
                  </svg>
                </div>
              </button>
            ))}
          </div>
        </div>
      ))}
    </section>
  )
}

{
  sectionsWithIndex.length === 0 && videos.length === 0 && (
    <p class="text-muted-foreground text-sm">
      No media yet —{" "}
      <a href="https://discord.gg/Qygt9u26Bn" class="underline hover:text-foreground transition-colors" data-umami-event="discord_cta_click">
        join the Discord
      </a>{" "}
      to add your guild's screenshots.
    </p>
  )
}

<!-- Lightbox overlay -->
<div
  id="lightbox"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-label="Image viewer"
>
  <!-- Close -->
  <button
    id="lightbox-close"
    class="absolute top-4 right-4 text-white/70 hover:text-white transition-colors p-2 rounded-full hover:bg-white/10"
    aria-label="Close"
  >
    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <!-- Prev -->
  <button
    id="lightbox-prev"
    class="absolute left-3 sm:left-6 text-white/70 hover:text-white transition-colors p-2 rounded-full hover:bg-white/10 disabled:opacity-20 disabled:cursor-not-allowed"
    aria-label="Previous"
  >
    <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
    </svg>
  </button>

  <!-- Image -->
  <div class="flex items-center justify-center w-full h-full p-2">
    <div id="lightbox-spinner" class="absolute inset-0 flex items-center justify-center pointer-events-none">
      <svg class="w-8 h-8 text-white/40 animate-spin" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
      </svg>
    </div>
    <img
      id="lightbox-img"
      src=""
      alt=""
      class="max-h-full max-w-full rounded-xl object-contain shadow-2xl select-none transition-opacity duration-200"
      style="opacity:0"
    />
  </div>

  <!-- Next -->
  <button
    id="lightbox-next"
    class="absolute right-3 sm:right-6 text-white/70 hover:text-white transition-colors p-2 rounded-full hover:bg-white/10 disabled:opacity-20 disabled:cursor-not-allowed"
    aria-label="Next"
  >
    <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
    </svg>
  </button>

  <!-- Counter -->
  <div id="lightbox-counter" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/50 text-sm tabular-nums"></div>
</div>

<script>
  const triggers = document.querySelectorAll<HTMLButtonElement>(".lightbox-trigger")
  const lightbox = document.getElementById("lightbox")!
  const img = document.getElementById("lightbox-img") as HTMLImageElement
  const spinner = document.getElementById("lightbox-spinner")!
  const btnClose = document.getElementById("lightbox-close")!
  const btnPrev = document.getElementById("lightbox-prev") as HTMLButtonElement
  const btnNext = document.getElementById("lightbox-next") as HTMLButtonElement
  const counter = document.getElementById("lightbox-counter")!

  const srcs = Array.from(triggers).map((t) => t.dataset.src ?? "")
  const thumbs = Array.from(triggers).map((t) => t.dataset.thumb ?? t.dataset.src ?? "")
  let current = 0
  const preloaded = new Set<string>()

  function preload(index: number) {
    const src = srcs[index]
    if (!src || preloaded.has(src)) return
    preloaded.add(src)
    const p = new Image()
    p.src = src
  }

  function show(index: number) {
    const navigating = current !== index && lightbox.classList.contains("flex")
    current = index
    const src = srcs[current]
    const thumb = thumbs[current]
    counter.textContent = `${current + 1} / ${srcs.length}`
    btnPrev.disabled = current === 0
    btnNext.disabled = current === srcs.length - 1

    // Show thumbnail immediately — already in browser cache from the grid
    if (thumb && thumb !== img.src) {
      img.style.opacity = navigating ? "0" : "1"
      img.src = thumb
      img.alt = `Screenshot ${current + 1}`
      spinner.style.display = "none"
      // Small fade-in when navigating between images
      if (navigating) requestAnimationFrame(() => { img.style.opacity = "1" })
    } else {
      img.style.opacity = "0"
      spinner.style.display = "flex"
    }

    // Load full-res in the background, swap silently when ready
    if (src !== thumb) {
      const captured = index
      const full = new Image()
      full.onload = () => {
        if (current !== captured) return
        img.src = src
        spinner.style.display = "none"
      }
      full.onerror = () => { spinner.style.display = "none" }
      full.src = src
      preloaded.add(src)
    }

    // Preload adjacent images in both directions
    preload(current + 1)
    preload(current - 1)

    lightbox.classList.remove("hidden")
    lightbox.classList.add("flex")
    document.body.style.overflow = "hidden"
  }

  function close() {
    lightbox.classList.add("hidden")
    lightbox.classList.remove("flex")
    document.body.style.overflow = ""
  }

  triggers.forEach((t) => {
    t.addEventListener("click", () => {
      const index = Number(t.dataset.index ?? 0)
      ;(window as any).umami?.track("lightbox_open", { index })
      show(index)
    })
  })

  btnClose.addEventListener("click", close)
  btnPrev.addEventListener("click", () => current > 0 && show(current - 1))
  btnNext.addEventListener("click", () => current < srcs.length - 1 && show(current + 1))

  lightbox.addEventListener("click", (e) => {
    if (e.target === lightbox) close()
  })

  document.addEventListener("keydown", (e) => {
    if (lightbox.classList.contains("hidden")) return
    if (e.key === "Escape") close()
    if (e.key === "ArrowLeft" && current > 0) show(current - 1)
    if (e.key === "ArrowRight" && current < srcs.length - 1) show(current + 1)
  })

  // Swipe navigation
  let touchStartX = 0
  lightbox.addEventListener("touchstart", (e) => { touchStartX = e.touches[0].clientX }, { passive: true })
  lightbox.addEventListener("touchend", (e) => {
    const dx = e.changedTouches[0].clientX - touchStartX
    if (Math.abs(dx) < 40) return
    if (dx < 0 && current < srcs.length - 1) show(current + 1)
    if (dx > 0 && current > 0) show(current - 1)
  }, { passive: true })
</script>
