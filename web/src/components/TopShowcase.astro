---
import type { RankedGuild } from "@/types/guild"
import { rankLabel } from "@/lib/slugify"

interface Props {
  guilds: RankedGuild[]
}

const { guilds } = Astro.props
const base = import.meta.env.BASE_URL.replace(/\/$/, "")
---

<div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
  {
    guilds.map((g) => {
      const img = g.screenshots?.[0]
      return (
        <a
          href={`${base}/guilds/${g.slug}`}
          class="group relative overflow-hidden rounded-xl ring-1 ring-border aspect-video bg-muted hover:ring-primary transition-all"
        >
          {img && (
            <img
              src={img}
              alt={g.name}
              loading="lazy"
              onerror="this.style.display='none'"
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
            />
          )}
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent" />
          <div class="absolute bottom-0 left-0 right-0 p-3">
            <p class="text-white font-medium text-sm leading-tight">{g.name}</p>
            <p class="text-white/70 text-xs">{rankLabel(g.rank)} · {g.score} pts</p>
          </div>
        </a>
      )
    })
  }
</div>
