---
import type { RankedGuild } from "@/types/guild"
import { BASE } from "@/lib/url"

interface Props {
  guilds: RankedGuild[]
  basePath?: string
}

const { guilds, basePath = "guilds" } = Astro.props
const base = BASE
---

<div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
  {
    guilds.map((g) => {
      const shots = g.screenshots ?? []
      const img = shots[Math.floor(Math.random() * shots.length)]
      return (
        <a
          href={`${base}/${basePath}/${g.slug}`}
          class="group relative overflow-hidden rounded-xl ring-1 ring-border aspect-video bg-muted hover:ring-primary transition-all"
        >
          {img && (
            <img
              src={img}
              alt={g.name}
              loading="lazy"
              onerror="this.style.display='none'"
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
            />
          )}
          <div class="absolute inset-0 bg-linear-to-t from-black/70 to-transparent" />
          <div class="absolute bottom-0 left-0 right-0 p-3">
            <p class="text-white font-medium text-sm leading-tight mb-1">{g.name}</p>
            {g.tags && g.tags.length > 0 && (
              <div class="flex flex-wrap gap-1">
                {g.tags.slice(0, 3).map((tag) => (
                  <span class="inline-flex items-center rounded-full bg-black/40 backdrop-blur-sm px-2 py-0.5 text-[10px] text-white/90">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </div>
        </a>
      )
    })
  }
</div>
