---
import Layout from "@/layouts/main.astro"
import { getGuildsSortedByScore, getSolosSortedByScore, getUsers, getBuilderSearchPath, getReactions, getVoterBlacklist } from "@/lib/guilds"
import { builderSlug, thumbUrl } from "@/lib/format"
import { resolveCanonical } from "@/lib/builder-aliases"
import { getNotableBuilders, getAllBuilderSlugs } from "@/lib/builders"
import { tutorialVideos, channels } from "@/lib/videos"
import { getCollection } from "astro:content"
import { BASE } from "@/lib/url"
import { HeartIcon, PenNibIcon, MapTrifoldIcon, UsersThreeIcon, BookOpenIcon } from "@phosphor-icons/react"

const guilds = getGuildsSortedByScore()
const solos = getSolosSortedByScore()
const users = getUsers()

// Builders wall — getAllBuilderSlugs already deduplicates via canonical slug resolution
const builderList = getAllBuilderSlugs().sort((a, b) => a.name.localeCompare(b.name))

// Guild cartographers: scouters sorted by count desc, nickname > globalName > username
const scoutCounts: Record<string, number> = {}
for (const g of [...guilds, ...solos]) {
  if (g.scoutedByDiscordId) scoutCounts[g.scoutedByDiscordId] = (scoutCounts[g.scoutedByDiscordId] ?? 0) + 1
}
const cartographers = Object.entries(scoutCounts)
  .sort(([, a], [, b]) => b - a)
  .map(([id]) => {
    const user = users[id]
    const name = user?.nickname ?? user?.globalName ?? user?.username ?? id
    return { name }
  })

// Tutorial authors → deduplicated by canonical slug
const allArticles = await getCollection("articles", ({ data }) => data.published !== false)
const canonicalSlugToName = new Map<string, string>()
const tutorialCountBySlug = new Map<string, number>()
for (const article of allArticles) {
  for (const author of article.data.authors ?? []) {
    const s = builderSlug(author)
    if (!s) continue
    const canonical = resolveCanonical(s)
    if (!canonicalSlugToName.has(canonical)) canonicalSlugToName.set(canonical, author)
    tutorialCountBySlug.set(canonical, (tutorialCountBySlug.get(canonical) ?? 0) + 1)
  }
}

const notableBuilders = getNotableBuilders(tutorialCountBySlug).filter((b) => b.slug !== builderSlug("Ahlyam"))

// Video creators who also have builds in the showcase — link to their build page
const videoCreatorsWithBuilds = [...new Set(tutorialVideos.map((v) => v.author).filter(Boolean) as string[])]
  .filter((name) => getBuilderSearchPath(name) !== null)

// Merged content creators: tutorial authors + video creators with builds, deduplicated by canonical slug, sorted
const creatorsByCanonical = new Map<string, string>(canonicalSlugToName)
for (const name of videoCreatorsWithBuilds) {
  const s = builderSlug(name)
  if (!s) continue
  const canonical = resolveCanonical(s)
  if (!creatorsByCanonical.has(canonical)) creatorsByCanonical.set(canonical, name)
}
const contentCreators = [...creatorsByCanonical.entries()]
  .map(([slug, name]) => ({ slug, name }))
  .sort((a, b) => a.name.localeCompare(b.name, undefined, { sensitivity: "base" }))

// Critics: users who voted on 4+ unique threads (weight1Threshold)
const CRITIC_THRESHOLD = 4
const reactions = getReactions()
const blacklist = new Set(getVoterBlacklist())
const threadCountById: Record<string, number> = {}
for (const [threadId, emojis] of Object.entries(reactions)) {
  const seen = new Set<string>()
  for (const voters of Object.values(emojis)) {
    for (const id of voters) seen.add(id)
  }
  for (const id of seen) {
    if (!blacklist.has(id)) threadCountById[id] = (threadCountById[id] ?? 0) + 1
  }
}
const critics = Object.entries(threadCountById)
  .filter(([, count]) => count >= CRITIC_THRESHOLD)
  .map(([id]) => {
    const user = users[id]
    return user?.nickname ?? user?.globalName ?? user?.username ?? id
  })
  .filter((name) => name.replace(/\p{Z}|\p{C}/gu, "") !== "")
  .sort((a, b) => a.localeCompare(b, undefined, { sensitivity: "base" }))

const BUILDER_PALETTE = [
  "bg-violet-500/10 text-violet-700 dark:text-violet-300 ring-1 ring-inset ring-violet-500/25 dark:ring-violet-400/25",
  "bg-sky-500/10 text-sky-700 dark:text-sky-300 ring-1 ring-inset ring-sky-500/25 dark:ring-sky-400/25",
  "bg-emerald-500/10 text-emerald-700 dark:text-emerald-300 ring-1 ring-inset ring-emerald-500/25 dark:ring-emerald-400/25",
  "bg-amber-500/10 text-amber-700 dark:text-amber-300 ring-1 ring-inset ring-amber-500/25 dark:ring-amber-400/25",
  "bg-rose-500/10 text-rose-700 dark:text-rose-300 ring-1 ring-inset ring-rose-500/25 dark:ring-rose-400/25",
  "bg-teal-500/10 text-teal-700 dark:text-teal-300 ring-1 ring-inset ring-teal-500/25 dark:ring-teal-400/25",
  "bg-orange-500/10 text-orange-700 dark:text-orange-300 ring-1 ring-inset ring-orange-500/25 dark:ring-orange-400/25",
  "bg-indigo-500/10 text-indigo-700 dark:text-indigo-300 ring-1 ring-inset ring-indigo-500/25 dark:ring-indigo-400/25",
  "bg-pink-500/10 text-pink-700 dark:text-pink-300 ring-1 ring-inset ring-pink-500/25 dark:ring-pink-400/25",
  "bg-cyan-500/10 text-cyan-700 dark:text-cyan-300 ring-1 ring-inset ring-cyan-500/25 dark:ring-cyan-400/25",
]
function builderColor(name: string): string {
  const hash = [...name].reduce((a, c) => a + c.charCodeAt(0), 0)
  return BUILDER_PALETTE[hash % BUILDER_PALETTE.length]
}
---

<Layout
  title="Where Builders Meet | Credits"
  description="The people who make Where Builders Meet possible: builders, tutorial writers, video creators, and the moderators behind the site."
>
  <div class="max-w-4xl space-y-14">

    <!-- Hero -->
    <div class="space-y-3">
      <h1 class="font-heading text-2xl font-semibold flex items-center gap-2.5">
        <HeartIcon weight="duotone" className="size-6 text-rose-400" client:load /> Credits
      </h1>
      <p class="text-sm text-muted-foreground leading-relaxed max-w-2xl">
        Where Builders Meet is built by the community, for the community. This page is a thank you to everyone who contributed their time, creativity, and skill.
      </p>
    </div>

    <!-- Notable Builders -->
    {notableBuilders.length > 0 && (
      <section class="space-y-4">
        <h2 class="font-heading text-xs font-medium text-muted-foreground uppercase tracking-wide flex items-center gap-2">
          <UsersThreeIcon weight="duotone" className="size-4 text-violet-400" client:load /> Notable builders
          <span class="text-muted-foreground/50 font-normal normal-case tracking-normal">{notableBuilders.length}</span>
        </h2>
        <p class="text-sm text-muted-foreground leading-relaxed max-w-2xl">
          Builders who contributed across multiple content types: guild bases, solo builds, blueprints, and tutorials.
        </p>
        <div class="relative">
          <div id="nb-scroll" class="flex gap-3 overflow-x-auto pb-1 snap-x snap-mandatory" style="scrollbar-width: none; -webkit-overflow-scrolling: touch">
            {notableBuilders.map((b) => (
              <a
                href={`${BASE}/builders/${b.slug}`}
                class="snap-start shrink-0 relative w-40 aspect-video rounded-xl overflow-hidden bg-muted ring-1 ring-border hover:ring-primary group transition-all"
                data-umami-event="notable_builder_click"
                data-umami-event-name={b.name}
              >
                {b.coverImage ? (
                  <img
                    src={thumbUrl(b.coverImage, 320, 240)}
                    alt={b.name}
                    loading="lazy"
                    onerror="this.style.display='none'"
                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                  />
                ) : (
                  <div class="absolute inset-0 bg-primary/10 flex items-center justify-center text-2xl font-bold text-primary/30">
                    {b.name[0]?.toUpperCase()}
                  </div>
                )}
                <div class="absolute inset-0 bg-linear-to-t from-black/85 via-black/20 to-transparent" />
                <div class="absolute bottom-0 left-0 right-0 p-2.5">
                  <p class="text-white font-medium text-xs leading-tight mb-1.5 truncate">{b.name}</p>
                  <div class="flex flex-wrap gap-1">
                    {b.guildCount > 0 && (
                      <span class="inline-flex items-center gap-0.5 text-[9px] font-medium px-1.5 py-0.5 rounded-full bg-black/50 backdrop-blur-sm text-violet-200">
                        <img src="/images/logo_1.webp" alt="" aria-hidden="true" class="size-2.5 object-contain" />{b.guildCount}
                      </span>
                    )}
                    {b.soloCount > 0 && (
                      <span class="inline-flex items-center gap-0.5 text-[9px] font-medium px-1.5 py-0.5 rounded-full bg-black/50 backdrop-blur-sm text-teal-200">
                        <img src="/images/logo_2.webp" alt="" aria-hidden="true" class="size-2.5 object-contain" />{b.soloCount}
                      </span>
                    )}
                    {b.blueprintCount > 0 && (
                      <span class="inline-flex items-center gap-0.5 text-[9px] font-medium px-1.5 py-0.5 rounded-full bg-black/50 backdrop-blur-sm text-blue-200">
                        <svg class="size-2.5 shrink-0" viewBox="0 0 256 256" fill="currentColor"><path d="M213.66,82.34l-56-56A8,8,0,0,0,152,24H56A16,16,0,0,0,40,40V216a16,16,0,0,0,16,16H200a16,16,0,0,0,16-16V88A8,8,0,0,0,213.66,82.34ZM160,51.31,188.69,80H160ZM200,216H56V40h88V88a8,8,0,0,0,8,8h48V216Z"/></svg>
                        {b.blueprintCount}
                      </span>
                    )}
                    {b.tutorialCount > 0 && (
                      <span class="inline-flex items-center gap-0.5 text-[9px] font-medium px-1.5 py-0.5 rounded-full bg-black/50 backdrop-blur-sm text-pink-200">
                        <BookOpenIcon weight="fill" className="size-2.5 shrink-0" client:load />{b.tutorialCount}
                      </span>
                    )}
                  </div>
                </div>
              </a>
            ))}
          </div>
          <button id="nb-prev" aria-label="Previous" class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-3 z-10 size-7 rounded-full bg-background border border-border shadow-sm flex items-center justify-center text-muted-foreground hover:text-foreground transition-all opacity-0 pointer-events-none">
            <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
          </button>
          <button id="nb-next" aria-label="Next" class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-3 z-10 size-7 rounded-full bg-background border border-border shadow-sm flex items-center justify-center text-muted-foreground hover:text-foreground transition-all">
            <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </button>
        </div>
        <script is:inline>
          ;(function () {
            const el = document.getElementById("nb-scroll")
            const prev = document.getElementById("nb-prev")
            const next = document.getElementById("nb-next")
            const AMT = 500
            const INTERVAL = 3000
            let timer

            function update() {
              const atStart = el.scrollLeft <= 8
              const atEnd = el.scrollLeft + el.clientWidth >= el.scrollWidth - 8
              prev.style.opacity = atStart ? "0" : "1"
              prev.style.pointerEvents = atStart ? "none" : "auto"
              next.style.opacity = atEnd ? "0" : "1"
              next.style.pointerEvents = atEnd ? "none" : "auto"
            }

            function advance() {
              const atEnd = el.scrollLeft + el.clientWidth >= el.scrollWidth - 8
              if (atEnd) {
                el.scrollTo({ left: 0, behavior: "smooth" })
              } else {
                el.scrollBy({ left: AMT, behavior: "smooth" })
              }
              setTimeout(update, 350)
            }

            function startAuto() { timer = setInterval(advance, INTERVAL) }
            function stopAuto() { clearInterval(timer) }

            prev.addEventListener("click", function () { stopAuto(); el.scrollBy({ left: -AMT, behavior: "smooth" }); setTimeout(update, 350); startAuto() })
            next.addEventListener("click", function () { stopAuto(); el.scrollBy({ left: AMT, behavior: "smooth" }); setTimeout(update, 350); startAuto() })
            el.addEventListener("scroll", update, { passive: true })
            el.addEventListener("mouseenter", stopAuto)
            el.addEventListener("mouseleave", startAuto)

            update()
            startAuto()
          })()
        </script>
      </section>
    )}

    <!-- Content creators -->
    <section class="space-y-4">
      <h2 class="font-heading text-xs font-medium text-muted-foreground uppercase tracking-wide">Content creators</h2>
      <p class="text-sm text-muted-foreground leading-relaxed max-w-2xl">
        Builders who wrote tutorials, guides, or made videos to help the community.
      </p>
      <div class="flex flex-wrap gap-1.5">
        {contentCreators.map(({ slug, name }) => (
          <a
            href={`${BASE}/builders/${slug}`}
            class="inline-flex items-center rounded-full bg-pink-500/10 text-pink-700 dark:text-pink-300 ring-1 ring-inset ring-pink-500/25 dark:ring-pink-400/25 px-2.5 py-0.5 text-xs font-medium transition-opacity hover:opacity-70"
            data-umami-event="credits_creator_click"
            data-umami-event-name={name}
          >
            {name}
          </a>
        ))}
      </div>
    </section>

    <!-- Guild cartographers -->
    <section class="space-y-4">
      <h2 class="font-heading text-xs font-medium text-muted-foreground uppercase tracking-wide">Guild cartographers</h2>
      <p class="text-sm text-muted-foreground leading-relaxed max-w-2xl">
        People who scouted guild bases across Jiang Hu
      </p>
      <div class="flex flex-wrap gap-1.5">
        {cartographers.map(({ name }) => (
          <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-500/10 text-emerald-700 dark:text-emerald-300 ring-1 ring-inset ring-emerald-500/25 dark:ring-emerald-400/25 px-2.5 py-0.5 text-xs font-medium">
            <MapTrifoldIcon weight="fill" className="size-3 shrink-0" client:load />
            {name}
          </span>
        ))}
      </div>
    </section>

    <!-- Critics -->
    <section class="space-y-4">
      <div class="flex items-baseline gap-3">
        <h2 class="font-heading text-xs font-medium text-muted-foreground uppercase tracking-wide">Critics</h2>
        <span class="text-xs text-muted-foreground">{critics.length} critics</span>
      </div>
      <p class="text-sm text-muted-foreground leading-relaxed max-w-2xl">
        Community members who took the time to vote across multiple guild bases.
      </p>
      <div class="flex flex-wrap gap-1.5">
        {critics.map((name) => (
          <span class="inline-flex items-center rounded-full bg-indigo-500/10 text-indigo-700 dark:text-indigo-300 ring-1 ring-inset ring-indigo-500/25 dark:ring-indigo-400/25 px-2.5 py-0.5 text-xs font-medium">
            {name}
          </span>
        ))}
      </div>
    </section>

    <!-- Builders wall -->
    <section class="space-y-4">
      <div class="flex items-baseline gap-3">
        <h2 class="font-heading text-xs font-medium text-muted-foreground uppercase tracking-wide">The builders</h2>
        <span class="text-xs text-muted-foreground">{builderList.length} builders</span>
      </div>
      <p class="text-sm text-muted-foreground leading-relaxed max-w-2xl">
        Every builder referenced for a guild base or solo construction to the showcase.
      </p>
      <div class="flex flex-wrap gap-1.5">
        {builderList.map(({ name, slug }) => (
          <a
            href={`${BASE}/builders/${slug}`}
            class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium transition-opacity hover:opacity-70 ${builderColor(name)}`}
            data-umami-event="credits_builder_click"
            data-umami-event-name={name}
          >
            {name}
          </a>
        ))}
      </div>
      <p class="text-xs text-muted-foreground pt-1">
        Want to be on this wall? <a href={`${BASE}/contribute`} class="text-foreground underline underline-offset-2 hover:text-primary transition-colors" data-umami-event="contribute_cta_click">Submit your build ↗</a>
      </p>
    </section>

    <!-- Moderators (subdued) -->
    <section class="space-y-3 border-t border-border pt-8">
      <h2 class="text-xs font-medium text-muted-foreground/60 uppercase tracking-wide">Moderators</h2>
      <div class="flex flex-wrap gap-3">

        <div class="rounded-lg border border-border/60 bg-muted/30 px-4 py-2.5">
          <p class="text-sm font-medium text-foreground/80">Suisen</p>
          <p class="text-xs text-muted-foreground/70">Moderator · Graphist</p>
        </div>

        <div class="rounded-lg border border-border/60 bg-muted/30 px-4 py-2.5">
          <p class="text-sm font-medium text-foreground/80">Alscend</p>
          <p class="text-xs text-muted-foreground/70">Moderator</p>
        </div>

        <div class="rounded-lg border border-border/60 bg-muted/30 px-4 py-2.5">
          <p class="text-sm font-medium text-foreground/80">Ahlyam</p>
          <p class="text-xs text-muted-foreground/70">Admin · Development</p>
        </div>

      </div>
    </section>

    <p class="text-sm text-muted-foreground border-t border-border pt-6">
      Questions or corrections? <a href="https://discord.gg/Qygt9u26Bn" class="underline hover:text-foreground transition-colors" data-umami-event="discord_cta_click">Find us on Discord.</a>
    </p>

  </div>
</Layout>
