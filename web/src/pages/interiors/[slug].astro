---
import Layout from "@/layouts/main.astro"
import MediaGallery from "@/components/MediaGallery.astro"
import { getInteriorsSortedByDate } from "@/lib/interiors"
import { renderMarkdown } from "@/lib/markdown"
import { BASE } from "@/lib/url"
import { Images } from "lucide-react"

export async function getStaticPaths() {
  const interiors = getInteriorsSortedByDate()
  return interiors.map((it) => ({
    params: { slug: it.slug },
    props: { interior: it },
  }))
}

const { interior: it } = Astro.props
const base = BASE
const ogImage = it.screenshots?.[0]
---

<Layout
  title={`${it.name} — Interior Design | Where Builders Meet`}
  description={it.description ? it.description.slice(0, 160) : `Interior design by ${it.builderName ?? "a builder"} in Where Winds Meet.`}
  image={ogImage}
  fullWidth
>
  <div class="space-y-5">
    <!-- Back -->
    <a
      href={`${base}/interiors`}
      class="inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground transition-colors"
    >
      ← Interiors
    </a>

    <!-- Hero -->
    {ogImage ? (
      <div class="relative rounded-2xl overflow-hidden">
        <div class="aspect-16/8 sm:aspect-16/6">
          <img src={ogImage} alt={it.name} class="w-full h-full object-cover" fetchpriority="high" decoding="async" />
        </div>
        <div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/20 to-transparent" />
        <div class="absolute bottom-0 left-0 right-0 p-5 sm:p-7">
          <h1 class="font-heading text-3xl sm:text-4xl font-bold text-white drop-shadow-sm leading-tight">
            {it.name}
          </h1>
        </div>
      </div>
    ) : (
      <h1 class="font-heading text-3xl sm:text-4xl font-bold leading-tight">{it.name}</h1>
    )}

    <!-- Meta strip -->
    <div class="flex flex-wrap gap-3">
      {it.builderName && (
        <div class="rounded-xl border border-border bg-card px-4 py-2">
          <div class="text-xs text-muted-foreground mb-1">Builder</div>
          <div class="text-sm font-medium">{it.builderName}</div>
        </div>
      )}
      {it.createdAt && (
        <div class="rounded-xl border border-border bg-card px-4 py-2">
          <div class="text-xs text-muted-foreground mb-1">Posted</div>
          <div class="text-sm text-muted-foreground" id="it-created-at">{it.createdAt}</div>
          <script is:inline define:vars={{ createdAt: it.createdAt }}>
            {
              const d = new Date(createdAt.replace(" at ", " "))
              if (!isNaN(d.getTime())) {
                const pad = n => String(n).padStart(2, "0")
                document.getElementById("it-created-at").textContent =
                  `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`
              }
            }
          </script>
        </div>
      )}
    </div>

    <!-- First post content -->
    {it.description && (
      <section>
        <div
          class="max-w-2xl text-sm text-muted-foreground leading-relaxed space-y-2 [&_strong]:text-foreground [&_strong]:font-medium [&_em]:italic"
          set:html={renderMarkdown(it.description)}
        />
      </section>
    )}

    {it.description && (it.screenshots?.length || it.videos?.length) && (
      <div class="border-t border-border" />
    )}

    <!-- Media -->
    {(it.screenshots?.length || it.videos?.length) && (
      <section class="space-y-4">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-muted-foreground flex items-center gap-1.5">
          <Images size={13} /> Screenshots
        </h2>
        <MediaGallery screenshots={it.screenshots} videos={it.videos} />
      </section>
    )}

    <!-- Discord CTA -->
    <div class="rounded-xl border border-border bg-card px-5 py-4 flex items-center justify-between gap-4 flex-wrap">
      <div>
        <p class="text-sm font-medium">Like this design?</p>
        <p class="text-xs text-muted-foreground mt-0.5">Leave a reaction or talk to the builder on Discord.</p>
      </div>
      <a
        href={it.discordThread}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg bg-[#5865F2] hover:bg-[#4752C4] text-white text-sm font-medium px-4 py-2 transition-colors shrink-0"
        data-umami-event="discord_cta_click"
        data-umami-event-source="interior_detail"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.043.03.056a19.9 19.9 0 0 0 5.993 3.03.077.077 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
        View on Discord
      </a>
    </div>
  </div>
</Layout>
