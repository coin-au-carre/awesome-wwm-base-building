---
import Layout from "@/layouts/main.astro"
import { buttonVariants } from "@/components/ui/button"
import { getCollection, render } from "astro:content"
import { BASE } from "@/lib/url"
import { ArrowLeftIcon } from "@phosphor-icons/react"
import { getBuilderSearchPath } from "@/lib/guilds"

type TagKey = "beginner" | "advanced" | "guild" | "solo" | "sightseeing" | "cn"

const TAG_CONFIG: Record<TagKey, { label: string; bg: string; text: string; dot: string }> = {
  beginner: { label: "Beginner", bg: "bg-emerald-500/10", text: "text-emerald-600 dark:text-emerald-400", dot: "bg-emerald-500" },
  advanced: { label: "Advanced", bg: "bg-amber-500/10", text: "text-amber-600 dark:text-amber-400", dot: "bg-amber-500" },
  guild: { label: "Guild", bg: "bg-violet-500/10", text: "text-violet-600 dark:text-violet-400", dot: "bg-violet-500" },
  solo: { label: "Solo", bg: "bg-sky-500/10", text: "text-sky-600 dark:text-sky-400", dot: "bg-sky-500" },
  sightseeing: { label: "Sightseeing", bg: "bg-teal-500/10", text: "text-teal-600 dark:text-teal-400", dot: "bg-teal-500" },
  cn: { label: "CN Content", bg: "bg-rose-500/10", text: "text-rose-600 dark:text-rose-400", dot: "bg-rose-500" },
}

function renderTags(tags: string[] = []) {
  const known: TagKey[] = ["beginner", "advanced", "guild", "solo", "sightseeing", "cn"]
  return tags.filter((t): t is TagKey => known.includes(t as TagKey))
}

export async function getStaticPaths() {
  const entries = await getCollection("articles", ({ data }) => data.published !== false)
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }))
}

const { entry } = Astro.props
const { Content } = await render(entry)

const coverImage = entry.data.image ?? null
const localCover = coverImage?.startsWith("/") ? coverImage : null
const firstImageSrc = localCover ?? entry.body.match(/<img[^>]+src=["']([^"']+)["']/)?.[1] ?? null
const ogImage = firstImageSrc ? `${Astro.url.origin}${firstImageSrc}` : undefined

const datePublished = entry.data.date?.toISOString().slice(0, 10) ?? "2025-01-01"
const keywords = (entry.data.tags ?? []).join(", ") || undefined
const tutorialsUrl = `${Astro.url.origin}/tutorials`
---

<Layout
  title={`${entry.data.title} — Where Winds Meet Building Guide`}
  description={entry.data.description}
  image={ogImage}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": Astro.url.origin },
          { "@type": "ListItem", "position": 2, "name": "Tutorials", "item": tutorialsUrl },
          { "@type": "ListItem", "position": 3, "name": entry.data.title, "item": Astro.url.href },
        ],
      },
      {
        "@type": "Article",
        "headline": entry.data.title,
        "description": entry.data.description,
        "url": Astro.url.href,
        "datePublished": datePublished,
        "dateModified": datePublished,
        ...(ogImage ? { "image": ogImage } : {}),
        "author": (entry.data.authors ?? []).map((name: string) => ({ "@type": "Person", "name": name })),
        ...(keywords ? { "keywords": keywords } : {}),
        "publisher": { "@type": "Organization", "name": "Where Builders Meet", "url": Astro.url.origin },
        "about": { "@type": "VideoGame", "name": "Where Winds Meet" },
        "isPartOf": { "@type": "WebPage", "url": tutorialsUrl },
      },
    ],
  })} />
  <div class="max-w-3xl">
    <a href={`${BASE}/tutorials`} class={buttonVariants({ variant: "ghost", size: "sm" })}>
      <ArrowLeftIcon className="size-4" /> Back to Tutorials
    </a>

    <div class="mt-6 pb-6 border-b border-border space-y-4">
      <div class="flex flex-wrap gap-1.5">
        {renderTags(entry.data.tags).map((t) => {
          const cfg = TAG_CONFIG[t]
          return (
            <span class={`inline-flex items-center gap-1 rounded-full ${cfg.bg} ${cfg.text} px-2 py-0.5 text-xs font-medium`}>
              <span class={`size-1.5 rounded-full ${cfg.dot} inline-block`}></span>{cfg.label}
            </span>
          )
        })}
      </div>
      <h1 class="font-heading text-3xl font-semibold leading-tight">{entry.data.title}</h1>
      {entry.data.description && <p class="text-muted-foreground text-base">{entry.data.description}</p>}
      {entry.data.authors && entry.data.authors.length > 0 && (
        <div class="flex flex-wrap gap-3 pt-1">
          {entry.data.authors.map((name: string) => {
            const searchPath = getBuilderSearchPath(name)
            const initial = name.trim()[0]?.toUpperCase() ?? "?"
            return (
              <div class="flex items-center gap-2.5">
                <div class="size-9 rounded-full bg-primary/10 text-primary flex items-center justify-center text-sm font-bold shrink-0">
                  {initial}
                </div>
                <div class="flex flex-col leading-tight">
                  <span class="text-[11px] text-muted-foreground uppercase tracking-wide">Tutorial by</span>
                  {searchPath ? (
                    <a href={`${BASE}${searchPath}`} class="text-sm font-semibold text-foreground hover:text-primary hover:underline underline-offset-2 transition-colors">{name}</a>
                  ) : (
                    <span class="text-sm font-semibold text-foreground">{name}</span>
                  )}
                </div>
              </div>
            )
          })}
          {entry.data.date && (
            <div class="flex items-center self-end pb-0.5 text-xs text-muted-foreground ml-1">
              {entry.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
            </div>
          )}
        </div>
      )}
    </div>

    <div class="prose prose-lg mt-8">
      <Content />
    </div>
  </div>
</Layout>
