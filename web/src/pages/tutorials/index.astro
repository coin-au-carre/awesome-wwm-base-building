---
import Layout from "@/layouts/main.astro"
import TutorialsFilter from "@/components/TutorialsFilter"
import { BookOpenIcon } from "@phosphor-icons/react"
import { getCollection } from "astro:content"
import { BASE } from "@/lib/url"
import { getBuilderSearchPath } from "@/lib/guilds"

const entries = await getCollection("articles", ({ data }) => data.published !== false)

type TagKey = "beginner" | "advanced" | "guild" | "solo" | "sightseeing" | "cn" | "website"

const TAG_CONFIG: Record<TagKey, { label: string; bg: string; text: string; dot: string; ring: string }> = {
  beginner: { label: "Beginner", bg: "bg-emerald-500/10", text: "text-emerald-700 dark:text-emerald-300", dot: "bg-emerald-500", ring: "ring-1 ring-inset ring-emerald-500/30" },
  advanced: { label: "Advanced", bg: "bg-amber-500/10", text: "text-amber-700 dark:text-amber-300", dot: "bg-amber-500", ring: "ring-1 ring-inset ring-amber-500/30" },
  guild: { label: "Guild", bg: "bg-violet-500/10", text: "text-violet-700 dark:text-violet-300", dot: "bg-violet-500", ring: "ring-1 ring-inset ring-violet-500/30" },
  solo: { label: "Solo", bg: "bg-sky-500/10", text: "text-sky-700 dark:text-sky-300", dot: "bg-sky-500", ring: "ring-1 ring-inset ring-sky-500/30" },
  sightseeing: { label: "Sightseeing", bg: "bg-teal-500/10", text: "text-teal-700 dark:text-teal-300", dot: "bg-teal-500", ring: "ring-1 ring-inset ring-teal-500/30" },
  cn: { label: "CN Content", bg: "bg-rose-500/10", text: "text-rose-700 dark:text-rose-300", dot: "bg-rose-500", ring: "ring-1 ring-inset ring-rose-500/30" },
  website: { label: "Website", bg: "bg-indigo-500/10", text: "text-indigo-700 dark:text-indigo-300", dot: "bg-indigo-500", ring: "ring-1 ring-inset ring-indigo-500/30" },
}

function renderTags(tags: string[] = []) {
  const known: TagKey[] = ["beginner", "advanced", "guild", "solo", "sightseeing", "cn", "website"]
  return tags.filter((t): t is TagKey => known.includes(t as TagKey))
}

const newestSlug = entries.reduce((a, b) =>
  (b.data.date?.getTime() ?? 0) > (a.data.date?.getTime() ?? 0) ? b : a
).id

const guides = entries
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .map((e) => ({
    slug: e.id,
    title: e.data.title,
    description: e.data.description,
    tags: e.data.tags ?? [],
    authors: e.data.authors ?? [],
    image: e.data.image ?? null,
  }))

const allAuthors = [...new Set(guides.flatMap((g) => g.authors))]
const authorPaths: Record<string, string> = {}
for (const name of allAuthors) {
  const path = getBuilderSearchPath(name)
  if (path) { authorPaths[name] = path }
}
---

<Layout
  title="Where Builders Meet | Where Winds Meet Building Guide & Tutorials on how to build"
  description="Step-by-step building guides, construction tips, and how-to tutorials for Where Winds Meet. Learn how to build from the community."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Where Winds Meet Building Tutorials",
    "url": Astro.url.href,
    "itemListElement": guides.map((item, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": item.title,
      "url": `${Astro.url.origin}/tutorials/${item.slug}`,
    })),
  })} />

  <div class="max-w-6xl space-y-8">
    <div class="flex flex-col gap-3">
      <h1 class="font-heading text-2xl font-semibold flex items-center gap-2">
        <BookOpenIcon weight="duotone" className="size-6 text-primary" /> Tutorials
      </h1>
      <p class="text-muted-foreground text-sm">
        Step-by-step building guides written by the community.
        <span class="whitespace-nowrap">
          Have a technique to share? Reach out on <a href="https://discord.gg/Qygt9u26Bn" class="text-foreground underline underline-offset-2 hover:text-primary transition-colors" data-umami-event="discord_cta_click">Discord ↗</a> and we'll publish it here.
        </span>
      </p>
    </div>

    <TutorialsFilter client:load guides={guides} newestSlug={newestSlug} TAG_CONFIG={TAG_CONFIG} authorPaths={authorPaths} />
  </div>
</Layout>
