---
import Layout from "@/layouts/main.astro"
import { BookOpenIcon, PlayCircleIcon } from "@phosphor-icons/react"
import { getCollection } from "astro:content"
import { tutorialVideos, type TutorialVideo } from "@/lib/videos"
import { BASE } from "@/lib/url"

const entries = await getCollection("tutorials")

type GuideItem = {
  kind: "guide"
  slug: string
  title: string
  description: string
  tags: string[]
  authors: string[]
}

type VideoItem = {
  kind: "video"
} & TutorialVideo

type Item = GuideItem | VideoItem

const guides: GuideItem[] = entries
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .map((e) => ({
    kind: "guide" as const,
    slug: e.slug,
    title: e.data.title,
    description: e.data.description,
    tags: e.data.tags ?? [],
    authors: e.data.authors ?? [],
  }))

const videos: VideoItem[] = tutorialVideos.map((v) => ({ kind: "video" as const, ...v }))

const allItems: Item[] = [...guides, ...videos]

function getDifficulty(tags: string[] = []): "beginner" | "advanced" | "other" {
  if (tags.includes("beginner")) return "beginner"
  if (tags.includes("advanced")) return "advanced"
  return "other"
}

const columns = [
  { label: "Beginner", key: "beginner", dot: "bg-emerald-500", items: allItems.filter((i) => getDifficulty(i.tags) === "beginner") },
  { label: "Advanced", key: "advanced", dot: "bg-amber-500", items: allItems.filter((i) => getDifficulty(i.tags) === "advanced") },
].filter((c) => c.items.length > 0)

const otherItems = allItems.filter((i) => getDifficulty(i.tags) === "other")

function youtubeID(url: string): string {
  try {
    const u = new URL(url)
    if (u.hostname === "youtu.be") return u.pathname.slice(1)
    if (u.hostname.includes("youtube.com")) return u.searchParams.get("v") ?? ""
  } catch {}
  return ""
}

function tiktokID(url: string): string {
  try {
    const u = new URL(url)
    if (u.hostname.includes("tiktok.com")) {
      const m = u.pathname.match(/\/video\/(\d+)/)
      return m ? m[1] : ""
    }
  } catch {}
  return ""
}
---

<Layout
  title="Tutorials — Where Builders Meet"
  description="Guides and video tutorials to help you build better in Where Winds Meet."
>
  <div class="max-w-5xl space-y-10">

    <!-- Header -->
    <div class="flex flex-col gap-3">
      <h1 class="font-heading text-2xl font-semibold flex items-center gap-2">
        <BookOpenIcon weight="duotone" className="size-6 text-primary" /> Tutorials
      </h1>
      <p class="text-muted-foreground text-sm">
        Guides and videos to help you build better in Where Winds Meet.
        <span class="whitespace-nowrap">
          Have something to share? <a href="https://discord.gg/Qygt9u26Bn" class="text-foreground underline underline-offset-2 hover:text-primary transition-colors">Join Discord ↗</a>
        </span>
      </p>
    </div>

    <!-- Columns -->
    <div class={`grid grid-cols-1 gap-10 items-start ${columns.length > 1 ? "md:grid-cols-2" : ""}`}>
      {columns.map((col) => (
        <section class="space-y-5">

          <!-- Section header -->
          <div class="flex items-center gap-2">
            <span class={`size-2 rounded-full shrink-0 ${col.dot}`}></span>
            <h2 class="font-heading text-xs font-semibold uppercase tracking-widest text-muted-foreground">{col.label}</h2>
          </div>

          <div class="space-y-6">
            {col.items.map((item) => {

              /* ── Guide card ── */
              if (item.kind === "guide") {
                const nonDiffTags = (item as GuideItem).tags.filter((t) => t !== "beginner" && t !== "advanced")
                return (
                  <a
                    href={`${BASE}/tutorials/${(item as GuideItem).slug}`}
                    class="group flex items-start gap-4 rounded-2xl bg-card ring-1 ring-foreground/10 p-4 hover:ring-primary/30 hover:shadow-md transition-all"
                  >
                    {/* Icon bubble */}
                    <div class="shrink-0 size-9 rounded-xl bg-primary/10 flex items-center justify-center mt-0.5">
                      <BookOpenIcon weight="duotone" className="size-4 text-primary" />
                    </div>

                    {/* Content */}
                    <div class="flex-1 min-w-0 space-y-1.5">
                      <div class="flex items-start justify-between gap-2">
                        <p class="text-sm font-medium leading-snug group-hover:text-primary transition-colors">
                          {item.title}
                        </p>
                        <svg class="size-3.5 shrink-0 mt-0.5 text-muted-foreground/50 group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                        </svg>
                      </div>
                      <p class="text-xs text-muted-foreground leading-relaxed">{item.description}</p>
                      <div class="flex flex-wrap items-center gap-1.5 pt-0.5">
                        {nonDiffTags.map((tag) => (
                          <span class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground px-2 py-0.5 text-xs font-medium">{tag}</span>
                        ))}
                        {(item as GuideItem).authors.length > 0 && (
                          <span class="text-xs text-muted-foreground/70">by {(item as GuideItem).authors.join(", ")}</span>
                        )}
                      </div>
                    </div>
                  </a>
                )
              }

              /* ── Video card ── */
              const ytID = youtubeID(item.url)
              const ttID = tiktokID(item.url)
              const isTikTokLink = !ttID && item.url.includes("tiktok.com")
              const embedUrl = ytID
                ? `https://www.youtube.com/embed/${ytID}?autoplay=1`
                : ttID
                ? `https://www.tiktok.com/embed/v2/${ttID}`
                : null
              const thumbUrl = ytID ? `https://img.youtube.com/vi/${ytID}/hqdefault.jpg` : null
              const platform = ytID ? "YouTube" : "TikTok"

              /* External TikTok link (no embeddable ID) */
              if (isTikTokLink) {
                return (
                  <a
                    href={item.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group block overflow-hidden rounded-2xl ring-1 ring-foreground/10 bg-card hover:ring-primary/30 hover:shadow-md transition-all"
                  >
                    <div class="relative aspect-video w-full bg-[#010101] flex items-center justify-center">
                      <svg class="size-10 text-white/80" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.32 6.32 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07Z"/></svg>
                      <div class="absolute top-2 right-2 bg-black/60 backdrop-blur-sm rounded-md px-1.5 py-0.5 text-xs text-white/90 font-medium">TikTok ↗</div>
                    </div>
                    <div class="px-4 py-3">
                      <p class="text-sm font-medium leading-snug">{item.title}</p>
                      {item.description && <p class="text-xs text-muted-foreground mt-0.5">{item.description}</p>}
                    </div>
                  </a>
                )
              }

              return (
                <div class="overflow-hidden rounded-2xl ring-1 ring-foreground/10 bg-card hover:ring-primary/30 hover:shadow-md transition-all">
                  {/* Thumbnail / branded background */}
                  <button
                    type="button"
                    class="video-trigger group relative aspect-video w-full overflow-hidden cursor-pointer block"
                    data-embed={embedUrl}
                    data-title={item.title}
                    data-type={ttID ? "tiktok" : "youtube"}
                  >
                    {thumbUrl ? (
                      <img
                        src={thumbUrl}
                        alt={item.title}
                        class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                      />
                    ) : (
                      /* TikTok branded background */
                      <div class="absolute inset-0 bg-[#010101] flex items-center justify-center">
                        <svg class="size-12 text-white/70" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.32 6.32 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07Z"/></svg>
                      </div>
                    )}

                    {/* Play overlay */}
                    <div class="absolute inset-0 flex items-center justify-center bg-black/20 group-hover:bg-black/40 transition-colors">
                      <div class="flex size-12 items-center justify-center rounded-full bg-white/90 shadow-lg scale-90 group-hover:scale-100 transition-transform">
                        <PlayCircleIcon weight="fill" className="size-7 text-foreground ml-0.5" />
                      </div>
                    </div>

                    {/* Platform badge */}
                    <div class="absolute top-2 right-2 bg-black/60 backdrop-blur-sm rounded-md px-1.5 py-0.5 text-xs text-white/90 font-medium">{platform}</div>
                  </button>

                  {/* Info row */}
                  <div class="px-4 py-3">
                    <p class="text-sm font-medium leading-snug">{item.title}</p>
                    {item.description && <p class="text-xs text-muted-foreground mt-0.5">{item.description}</p>}
                    {item.author && <p class="text-xs text-muted-foreground mt-0.5">by {item.author}</p>}
                  </div>
                </div>
              )
            })}
          </div>
        </section>
      ))}
    </div>

    {otherItems.length > 0 && (
      <section class="space-y-6">
        {otherItems.map((item) => {
          if (item.kind !== "guide") return null
          return (
            <a
              href={`${BASE}/tutorials/${(item as GuideItem).slug}`}
              class="group flex items-start gap-4 rounded-2xl bg-card ring-1 ring-foreground/10 p-4 hover:ring-primary/30 hover:shadow-md transition-all"
            >
              <div class="shrink-0 size-9 rounded-xl bg-primary/10 flex items-center justify-center mt-0.5">
                <svg class="size-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
              </div>
              <div class="flex-1 min-w-0 space-y-1">
                <div class="flex items-start justify-between gap-2">
                  <p class="text-sm font-medium leading-snug group-hover:text-primary transition-colors">{item.title}</p>
                  <svg class="size-3.5 shrink-0 mt-0.5 text-muted-foreground/50 group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
                </div>
                <p class="text-xs text-muted-foreground leading-relaxed">{item.description}</p>
                {(item as GuideItem).authors.length > 0 && (
                  <p class="text-xs text-muted-foreground/70">by {(item as GuideItem).authors.join(", ")}</p>
                )}
              </div>
            </a>
          )
        })}
      </section>
    )}
  </div>

  <!-- Video modal -->
  <div
    id="video-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/85 backdrop-blur-sm p-4"
    role="dialog"
    aria-modal="true"
  >
    <button
      id="video-modal-close"
      class="absolute top-4 right-4 text-white/60 hover:text-white transition-colors p-2 rounded-full hover:bg-white/10"
      aria-label="Close"
    >
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <div id="video-modal-container" class="w-full max-w-3xl">
      <div id="video-modal-inner" class="aspect-video w-full overflow-hidden rounded-2xl bg-black shadow-2xl">
        <iframe
          id="video-modal-iframe"
          src=""
          title=""
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          class="h-full w-full border-0"
        ></iframe>
      </div>
    </div>
  </div>
</Layout>

<script>
  const modal = document.getElementById("video-modal")!
  const container = document.getElementById("video-modal-container")!
  const inner = document.getElementById("video-modal-inner")!
  const iframe = document.getElementById("video-modal-iframe") as HTMLIFrameElement
  const closeBtn = document.getElementById("video-modal-close")!

  function openModal(embedUrl: string, title: string, type: string) {
    iframe.src = embedUrl
    iframe.title = title
    if (type === "tiktok") {
      container.className = "flex justify-center"
      inner.className = "overflow-hidden rounded-2xl bg-black shadow-2xl"
      inner.style.cssText = "height: min(85vh, 640px); aspect-ratio: 9/16; width: auto;"
    } else {
      container.className = "w-full max-w-3xl"
      inner.className = "aspect-video w-full overflow-hidden rounded-2xl bg-black shadow-2xl"
      inner.style.cssText = ""
    }
    modal.classList.remove("hidden")
    modal.classList.add("flex")
    document.body.style.overflow = "hidden"
  }

  function closeModal() {
    iframe.src = ""
    modal.classList.add("hidden")
    modal.classList.remove("flex")
    document.body.style.overflow = ""
  }

  document.querySelectorAll<HTMLButtonElement>(".video-trigger").forEach((btn) => {
    btn.addEventListener("click", () => {
      const embedUrl = btn.dataset.embed
      const title = btn.dataset.title ?? ""
      const type = btn.dataset.type ?? "youtube"
      if (embedUrl) openModal(embedUrl, title, type)
    })
  })

  closeBtn.addEventListener("click", closeModal)
  modal.addEventListener("click", (e) => { if (e.target === modal) closeModal() })
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !modal.classList.contains("hidden")) closeModal()
  })
</script>
