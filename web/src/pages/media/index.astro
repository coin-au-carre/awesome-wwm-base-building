---
import Layout from "@/layouts/main.astro"
import { PlayCircleIcon, TelevisionSimpleIcon } from "@phosphor-icons/react"
import { tutorialVideos, channels, type TutorialVideo } from "@/lib/videos"
import { BASE } from "@/lib/url"
import { getBuilderSearchPath } from "@/lib/guilds"

type VideoItem = {
  kind: "video"
} & TutorialVideo

const videos: VideoItem[] = tutorialVideos.map((v) => ({ kind: "video" as const, ...v }))

type TagKey = "beginner" | "advanced" | "guild" | "solo" | "sightseeing" | "cn"

const TAG_CONFIG: Record<TagKey, { label: string; bg: string; text: string; dot: string; ring: string }> = {
  beginner: { label: "Beginner", bg: "bg-emerald-500/10", text: "text-emerald-700 dark:text-emerald-300", dot: "bg-emerald-500", ring: "ring-1 ring-inset ring-emerald-500/30" },
  advanced: { label: "Advanced", bg: "bg-amber-500/10", text: "text-amber-700 dark:text-amber-300", dot: "bg-amber-500", ring: "ring-1 ring-inset ring-amber-500/30" },
  guild: { label: "Guild", bg: "bg-violet-500/10", text: "text-violet-700 dark:text-violet-300", dot: "bg-violet-500", ring: "ring-1 ring-inset ring-violet-500/30" },
  solo: { label: "Solo", bg: "bg-sky-500/10", text: "text-sky-700 dark:text-sky-300", dot: "bg-sky-500", ring: "ring-1 ring-inset ring-sky-500/30" },
  sightseeing: { label: "Sightseeing", bg: "bg-teal-500/10", text: "text-teal-700 dark:text-teal-300", dot: "bg-teal-500", ring: "ring-1 ring-inset ring-teal-500/30" },
  cn: { label: "CN Content", bg: "bg-rose-500/10", text: "text-rose-700 dark:text-rose-300", dot: "bg-rose-500", ring: "ring-1 ring-inset ring-rose-500/30" },
}

function renderTags(tags: string[] = []) {
  const known: TagKey[] = ["beginner", "advanced", "guild", "solo", "sightseeing", "cn"]
  return tags.filter((t): t is TagKey => known.includes(t as TagKey))
}

function youtubeID(url: string): string {
  try {
    const u = new URL(url)
    if (u.hostname === "youtu.be") return u.pathname.slice(1)
    if (u.hostname.includes("youtube.com")) return u.searchParams.get("v") ?? ""
  } catch {}
  return ""
}

function tiktokID(url: string): string {
  try {
    const u = new URL(url)
    if (u.hostname.includes("tiktok.com")) {
      const m = u.pathname.match(/\/video\/(\d+)/)
      return m ? m[1] : ""
    }
  } catch {}
  return ""
}

const tiktokThumbs: Record<string, string> = {}
await Promise.all(
  tutorialVideos
    .filter((v) => v.url.includes("tiktok.com"))
    .map(async (v) => {
      try {
        const res = await fetch(`https://www.tiktok.com/oembed?url=${encodeURIComponent(v.url)}`)
        if (res.ok) {
          const data = await res.json()
          if (data.thumbnail_url) tiktokThumbs[v.url] = data.thumbnail_url
        }
      } catch {}
    })
)
---

<Layout
  title="Media — Building in Where Winds Meet"
  description="Videos and creator channels about building and decorating in Where Winds Meet."
>
  <div class="max-w-5xl space-y-10">

    <!-- Header -->
    <div class="flex flex-col gap-3">
      <h1 class="font-heading text-2xl font-semibold flex items-center gap-2">
        <TelevisionSimpleIcon weight="duotone" className="size-6 text-primary" /> Media
      </h1>
      <p class="text-muted-foreground text-sm">
        Articles, videos, and creator channels about building in Where Winds Meet.
        <span class="whitespace-nowrap">
          Want to share something? Reach out on <a href="https://discord.gg/Qygt9u26Bn" class="text-foreground underline underline-offset-2 hover:text-primary transition-colors" data-umami-event="discord_cta_click">Discord ↗</a> and we'll publish it here.
        </span>
      </p>
    </div>

    <!-- Video of the Moment -->
    {videos.some((v) => v.featured) && (() => {
      const featured = videos.find((v) => v.featured)!
      const ytID = youtubeID(featured.url)
      const embedUrl = ytID ? `https://www.youtube.com/embed/${ytID}?autoplay=1` : null
      const thumbUrl = ytID ? `https://img.youtube.com/vi/${ytID}/hqdefault.jpg` : null
      return (
        <section class="space-y-4">
          <div class="flex items-center gap-2">
            <svg class="size-4 text-amber-500" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
            <h2 class="font-heading text-xs font-semibold uppercase tracking-widest text-muted-foreground">Video of the Moment</h2>
          </div>
          <div class="overflow-hidden rounded-2xl ring-2 ring-amber-500/40 bg-card shadow-md">
            <div class="flex flex-col sm:flex-row">
              <button
                type="button"
                class="video-trigger group relative w-full sm:w-80 shrink-0 aspect-video sm:aspect-auto sm:h-48 overflow-hidden cursor-pointer"
                data-embed={embedUrl}
                data-title={featured.title}
                data-type="youtube"
              >
                {thumbUrl && (
                  <img
                    src={thumbUrl}
                    alt={featured.title}
                    class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                  />
                )}
                <div class="absolute inset-0 flex items-center justify-center bg-black/20 group-hover:bg-black/40 transition-colors">
                  <div class="flex size-14 items-center justify-center rounded-full bg-white/90 shadow-lg scale-90 group-hover:scale-100 transition-transform">
                    <PlayCircleIcon weight="fill" className="size-8 text-foreground ml-0.5" />
                  </div>
                </div>
                <div class="absolute top-2 left-2 flex items-center gap-1 bg-amber-500 rounded-md px-2 py-0.5 text-xs text-white font-semibold shadow">
                  <svg class="size-3" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
                  Featured
                </div>
              </button>
              <div class="flex flex-col justify-center px-5 py-4 space-y-2">
                <p class="text-base font-semibold leading-snug">{featured.title}</p>
                {featured.description && <p class="text-sm text-muted-foreground">{featured.description}</p>}
                <div class="flex flex-wrap items-center gap-1.5 pt-1">
                  {renderTags(featured.tags).map((t) => {
                    const cfg = TAG_CONFIG[t]
                    return (
                      <span class={`inline-flex items-center gap-1 rounded-full ${cfg.bg} ${cfg.text} ${cfg.ring} px-2 py-0.5 text-xs font-medium`}>
                        <span class={`size-1.5 rounded-full ${cfg.dot} inline-block`}></span>{cfg.label}
                      </span>
                    )
                  })}
                  {featured.author && (() => {
                    const sp = getBuilderSearchPath(featured.author)
                    return sp
                      ? <span class="text-xs text-muted-foreground/70">by <a href={`${BASE}${sp}`} class="hover:text-foreground underline underline-offset-2 transition-colors">{featured.author}</a></span>
                      : <span class="text-xs text-muted-foreground/70">by {featured.author}</span>
                  })()}
                </div>
              </div>
            </div>
          </div>
        </section>
      )
    })()}

    <!-- Videos -->
    {videos.length > 0 && (
      <section class="space-y-6">
        <div class="flex items-center gap-2">
          <PlayCircleIcon weight="duotone" className="size-4 text-primary" />
          <h2 class="font-heading text-xs font-semibold uppercase tracking-widest text-muted-foreground">Videos</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {videos.map((item) => {
            const ytID = youtubeID(item.url)
            const ttID = tiktokID(item.url)
            const isTikTokLink = !ttID && item.url.includes("tiktok.com")
            const embedUrl = ytID
              ? `https://www.youtube.com/embed/${ytID}?autoplay=1`
              : ttID
              ? `https://www.tiktok.com/embed/v2/${ttID}`
              : null
            const thumbUrl = ytID
              ? `https://img.youtube.com/vi/${ytID}/hqdefault.jpg`
              : tiktokThumbs[item.url] ?? null
            const platform = ytID ? "YouTube" : "TikTok"

            if (isTikTokLink) {
              return (
                <div class="overflow-hidden rounded-2xl ring-1 ring-foreground/10 bg-card hover:ring-primary/30 hover:shadow-md transition-all">
                  <a
                    href={item.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group relative aspect-video w-full bg-[#010101] overflow-hidden block"
                  >
                    {thumbUrl ? (
                      <img
                        src={thumbUrl}
                        alt={item.title}
                        class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                      />
                    ) : (
                      <div class="absolute inset-0 flex items-center justify-center">
                        <svg class="size-10 text-white/80" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.32 6.32 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07Z"/></svg>
                      </div>
                    )}
                    <div class="absolute top-2 right-2 bg-black/60 backdrop-blur-sm rounded-md px-1.5 py-0.5 text-xs text-white/90 font-medium">TikTok ↗</div>
                  </a>
                  <div class="px-4 py-3 space-y-1">
                    <p class="text-sm font-medium leading-snug">{item.title}</p>
                    {item.description && <p class="text-xs text-muted-foreground">{item.description}</p>}
                    <div class="flex flex-wrap items-center gap-1.5 pt-0.5">
                      {renderTags(item.tags).map((t) => {
                        const cfg = TAG_CONFIG[t]
                        return (
                          <span class={`inline-flex items-center gap-1 rounded-full ${cfg.bg} ${cfg.text} ${cfg.ring} px-2 py-0.5 text-xs font-medium`}>
                            <span class={`size-1.5 rounded-full ${cfg.dot} inline-block`}></span>{cfg.label}
                          </span>
                        )
                      })}
                      {item.author && (() => {
                        const sp = getBuilderSearchPath(item.author)
                        return sp
                          ? <span class="text-xs text-muted-foreground/70">by <a href={`${BASE}${sp}`} class="hover:text-foreground underline underline-offset-2 transition-colors">{item.author}</a></span>
                          : <span class="text-xs text-muted-foreground/70">by {item.author}</span>
                      })()}
                    </div>
                  </div>
                </div>
              )
            }

            return (
              <div class="overflow-hidden rounded-2xl ring-1 ring-foreground/10 bg-card hover:ring-primary/30 hover:shadow-md transition-all">
                <button
                  type="button"
                  class="video-trigger group relative aspect-video w-full overflow-hidden cursor-pointer block"
                  data-embed={embedUrl}
                  data-title={item.title}
                  data-type={ttID ? "tiktok" : "youtube"}
                >
                  {thumbUrl ? (
                    <img
                      src={thumbUrl}
                      alt={item.title}
                      class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                    />
                  ) : (
                    <div class="absolute inset-0 bg-[#010101] flex items-center justify-center">
                      <svg class="size-12 text-white/70" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.32 6.32 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07Z"/></svg>
                    </div>
                  )}
                  <div class="absolute inset-0 flex items-center justify-center bg-black/20 group-hover:bg-black/40 transition-colors">
                    <div class="flex size-12 items-center justify-center rounded-full bg-white/90 shadow-lg scale-90 group-hover:scale-100 transition-transform">
                      <PlayCircleIcon weight="fill" className="size-7 text-foreground ml-0.5" />
                    </div>
                  </div>
                  <div class="absolute top-2 right-2 bg-black/60 backdrop-blur-sm rounded-md px-1.5 py-0.5 text-xs text-white/90 font-medium">{platform}</div>
                </button>
                <div class="px-4 py-3 space-y-1">
                  <p class="text-sm font-medium leading-snug">{item.title}</p>
                  {item.description && <p class="text-xs text-muted-foreground">{item.description}</p>}
                  <div class="flex flex-wrap items-center gap-1.5 pt-0.5">
                    {renderTags(item.tags).map((t) => {
                      const cfg = TAG_CONFIG[t]
                      return (
                        <span class={`inline-flex items-center gap-1 rounded-full ${cfg.bg} ${cfg.text} ${cfg.ring} px-2 py-0.5 text-xs font-medium`}>
                          <span class={`size-1.5 rounded-full ${cfg.dot} inline-block`}></span>{cfg.label}
                        </span>
                      )
                    })}
                    {item.author && (() => {
                      const sp = getBuilderSearchPath(item.author)
                      return sp
                        ? <span class="text-xs text-muted-foreground/70">by <a href={`${BASE}${sp}`} class="hover:text-foreground underline underline-offset-2 transition-colors">{item.author}</a></span>
                        : <span class="text-xs text-muted-foreground/70">by {item.author}</span>
                    })()}
                  </div>
                </div>
              </div>
            )
          })}
        </div>
      </section>
    )}

    <!-- Channels -->
    <section class="space-y-6">
      <div class="flex items-center gap-2">
        <svg class="size-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
          <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="currentColor" stroke="none"/>
        </svg>
        <h2 class="font-heading text-xs font-semibold uppercase tracking-widest text-muted-foreground">Recommended Channels</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {channels.map((ch) => (
          <a
            href={ch.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-4 rounded-2xl bg-card ring-1 ring-foreground/10 p-4 hover:ring-primary/30 hover:shadow-md transition-all"
          >
            <div class="shrink-0 size-10 rounded-full bg-red-500/10 flex items-center justify-center">
              <svg class="size-5 text-red-500" viewBox="0 0 24 24" fill="currentColor">
                <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
                <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="white" stroke="none"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium group-hover:text-primary transition-colors">{ch.name}</p>
              {ch.handle && <p class="text-xs text-muted-foreground">{ch.handle}</p>}
            </div>
            <svg class="size-3.5 shrink-0 text-muted-foreground/50 group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        ))}
      </div>
    </section>

  </div>

  <!-- Video modal -->
  <div
    id="video-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/85 backdrop-blur-sm p-4"
    role="dialog"
    aria-modal="true"
  >
    <button
      id="video-modal-close"
      class="absolute top-4 right-4 text-white/60 hover:text-white transition-colors p-2 rounded-full hover:bg-white/10"
      aria-label="Close"
    >
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <div id="video-modal-container" class="w-full max-w-3xl">
      <div id="video-modal-inner" class="aspect-video w-full overflow-hidden rounded-2xl bg-black shadow-2xl">
        <iframe
          id="video-modal-iframe"
          src=""
          title=""
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          class="h-full w-full border-0"
        ></iframe>
      </div>
    </div>
  </div>
</Layout>

<script>
  const modal = document.getElementById("video-modal")!
  const container = document.getElementById("video-modal-container")!
  const inner = document.getElementById("video-modal-inner")!
  const iframe = document.getElementById("video-modal-iframe") as HTMLIFrameElement
  const closeBtn = document.getElementById("video-modal-close")!

  function openModal(embedUrl: string, title: string, type: string) {
    iframe.src = embedUrl
    iframe.title = title
    if (type === "tiktok") {
      container.className = "flex justify-center"
      inner.className = "overflow-hidden rounded-2xl bg-black shadow-2xl"
      inner.style.cssText = "height: min(85vh, 640px); aspect-ratio: 9/16; width: auto;"
    } else {
      container.className = "w-full max-w-3xl"
      inner.className = "aspect-video w-full overflow-hidden rounded-2xl bg-black shadow-2xl"
      inner.style.cssText = ""
    }
    modal.classList.remove("hidden")
    modal.classList.add("flex")
    document.body.style.overflow = "hidden"
  }

  function closeModal() {
    iframe.src = ""
    modal.classList.add("hidden")
    modal.classList.remove("flex")
    document.body.style.overflow = ""
  }

  document.querySelectorAll<HTMLButtonElement>(".video-trigger").forEach((btn) => {
    btn.addEventListener("click", () => {
      const embedUrl = btn.dataset.embed
      const title = btn.dataset.title ?? ""
      const type = btn.dataset.type ?? "youtube"
      if (embedUrl) openModal(embedUrl, title, type)
    })
  })

  closeBtn.addEventListener("click", closeModal)
  modal.addEventListener("click", (e) => { if (e.target === modal) closeModal() })
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !modal.classList.contains("hidden")) closeModal()
  })
</script>
