---
import Layout from "@/layouts/main.astro"
import MediaGallery from "@/components/MediaGallery.astro"
import { Badge } from "@/components/ui/badge"
import { buttonVariants } from "@/components/ui/button"
import { Table, TableBody, TableCell, TableRow } from "@/components/ui/table"
import { getSolosSortedByScore } from "@/lib/guilds"
import { rankLabel } from "@/lib/slugify"
import { renderMarkdown } from "@/lib/markdown"
import { BASE } from "@/lib/url"

export async function getStaticPaths() {
  const solos = getSolosSortedByScore()
  return solos.map((g) => ({
    params: { slug: g.slug },
    props: { solo: g },
  }))
}

const { solo: g } = Astro.props
const base = BASE
const randomScreenshot = g.screenshots?.length
  ? g.screenshots[Math.floor(Math.random() * g.screenshots.length)]
  : undefined
---

<Layout
  title={`${g.name} — A Where Winds Meet construction`}
  description={g.lore?.slice(0, 160) ?? `Solo build showcase for ${g.name} in Where Winds Meet.`}
  image={randomScreenshot}
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      headline: `${g.name} — Solo Build`,
      description: g.lore?.slice(0, 160) ?? `Solo build showcase for ${g.name} in Where Winds Meet.`,
      image: g.screenshots?.[0] ?? undefined,
      url: Astro.url.href,
      author: g.builders?.map((name: string) => ({ "@type": "Person", name })) ?? [],
    })}
  />
  <div class="max-w-5xl space-y-8">
    <a
      href={`${base}/solo`}
      class="inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground transition-colors"
    >
      ← Solo construction
    </a>

    <div>
      <h1 class="font-heading text-2xl font-semibold">{g.guildName || g.name}</h1>
      <div class="flex flex-wrap gap-1.5 mt-2">
        {
          g.tags?.map((tag) => (
            <Badge variant="secondary">{tag}</Badge>
          ))
        }
      </div>
    </div>

    <div class="rounded-xl ring-1 ring-border overflow-hidden">
      <Table>
        <TableBody>
          <TableRow>
            <TableCell className="text-muted-foreground font-medium w-32">🔨 Builder</TableCell>
            <TableCell>{g.builders.join(", ") || "—"}</TableCell>
          </TableRow>
          <TableRow>
            <TableCell className="text-muted-foreground font-medium">⭐ Score</TableCell>
            <TableCell className="font-semibold font-mono">{g.score}</TableCell>
          </TableRow>
          <TableRow>
            <TableCell className="text-muted-foreground font-medium">🏆 Rank</TableCell>
            <TableCell>{rankLabel(g.rank)}</TableCell>
          </TableRow>
          {g.discordThread && (
            <TableRow>
              <TableCell className="text-muted-foreground font-medium">💬 Discord</TableCell>
              <TableCell>
                <a href="https://discord.gg/Qygt9u26Bn" class="underline hover:text-foreground transition-colors mr-3">
                  Join server
                </a>
                <a href={g.discordThread} class="underline hover:text-foreground transition-colors">
                  View thread
                </a>
              </TableCell>
            </TableRow>
          )}
        </TableBody>
      </Table>
    </div>

    {
      g.lore && (
        <section>
          <h2 class="font-heading text-base font-medium mb-2">📜 Lore</h2>
          <div
            class="text-sm text-muted-foreground leading-relaxed space-y-2 [&_strong]:text-foreground [&_strong]:font-medium"
            set:html={renderMarkdown(g.lore)}
          />
        </section>
      )
    }

    {
      g.whatToVisit && (
        <section>
          <h2 class="font-heading text-base font-medium mb-2">🗺️ What to Visit</h2>
          <div
            class="text-sm leading-relaxed space-y-3 [&_ul]:space-y-1.5 [&_li]:flex [&_li]:gap-2 [&_li]:before:content-['·'] [&_li]:before:text-muted-foreground [&_strong]:font-semibold"
            set:html={renderMarkdown(g.whatToVisit)}
          />
        </section>
      )
    }

    <section class="space-y-6">
      <h2 class="font-heading text-base font-medium">🎬 Media</h2>
      <MediaGallery screenshots={g.screenshots} videos={g.videos} />
    </section>

    {g.discordThread && (
      <div class="flex flex-wrap gap-3">
        <a href={g.discordThread} target="_blank" rel="noopener noreferrer" class={buttonVariants({ size: "lg" })}>Vote on Discord ↗</a>
        <a href="https://discord.gg/Qygt9u26Bn" target="_blank" rel="noopener noreferrer" class={buttonVariants({ variant: "outline", size: "lg" })}>Join server ↗</a>
      </div>
    )}
  </div>
</Layout>
