---
import Layout from "@/layouts/main.astro"
import MediaGallery from "@/components/MediaGallery.astro"
import { Badge } from "@/components/ui/badge"
import { buttonVariants } from "@/components/ui/button"
import { getSolosSortedByScore, formatBuilderName } from "@/lib/guilds"
import { rankLabel } from "@/lib/slugify"
import { renderMarkdown } from "@/lib/markdown"
import { BASE } from "@/lib/url"
import { BookOpen, MapPin, Images } from "lucide-react"

export async function getStaticPaths() {
  const solos = getSolosSortedByScore()
  return solos.map((g) => ({
    params: { slug: g.slug },
    props: { solo: g },
  }))
}

const { solo: g } = Astro.props
const base = BASE
const ogImage = g.coverImage ?? g.screenshots?.[0]
---

<Layout
  title={`${g.name} — A Where Winds Meet construction`}
  description={g.lore?.slice(0, 160) ?? `Solo build showcase for ${g.name} in Where Winds Meet.`}
  image={ogImage}
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      headline: `${g.name} — Solo Build`,
      description: g.lore?.slice(0, 160) ?? `Solo build showcase for ${g.name} in Where Winds Meet.`,
      image: [
        ...(g.coverImage ? [g.coverImage] : []),
        ...((g.screenshots ?? []).filter((s: string) => s !== g.coverImage)),
      ].filter(Boolean),
      datePublished: g.lastModified ?? "2025-01-01",
      dateModified: g.lastModified ?? "2025-01-01",
      url: Astro.url.href,
      keywords: g.tags?.join(", "),
      author: g.builders?.map((name: string) => ({ "@type": "Person", name })) ?? [],
      publisher: { "@type": "Organization", name: "Where Builders Meet", url: "https://www.wherebuildersmeet.com" },
      about: { "@type": "VideoGame", name: "Where Winds Meet" },
    })}
  />

  <div class="max-w-5xl space-y-5">
    <!-- Back -->
    <a
      href={`${base}/solo`}
      class="inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground transition-colors"
    >
      ← Solo construction
    </a>

    <!-- Hero -->
    {ogImage ? (
      <div class="relative rounded-2xl overflow-hidden">
        <div class="aspect-16/7">
          <img src={ogImage} alt={g.guildName || g.name} class="w-full h-full object-cover" />
        </div>
        <div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/20 to-transparent" />
        <div class="absolute bottom-0 left-0 right-0 p-5 sm:p-7">
          <div class="flex items-end justify-between gap-4">
            <div>
              <h1 class="font-heading text-3xl sm:text-4xl font-bold text-white drop-shadow-sm leading-tight">
                {g.guildName || g.name}
              </h1>
              {g.guildName && g.guildName !== g.name && (
                <p class="text-white/60 text-sm mt-0.5">{g.name}</p>
              )}
              {g.tags && g.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-3">
                  {g.tags.map((tag: string) => (
                    <span class="text-xs px-2.5 py-0.5 rounded-full bg-white/15 text-white border border-white/25 backdrop-blur-sm">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
            <button
              id="share-btn"
              title="Copy link"
              class="text-white/70 hover:text-white transition-colors p-2 rounded-lg bg-white/10 hover:bg-white/20 backdrop-blur-sm cursor-pointer shrink-0"
            >
              <svg id="share-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              <svg id="check-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden" style="color: rgb(74 222 128)"><polyline points="20 6 9 17 4 12"/></svg>
            </button>
          </div>
        </div>
      </div>
    ) : (
      <div class="flex items-start justify-between gap-4">
        <div>
          <h1 class="font-heading text-3xl sm:text-4xl font-bold leading-tight">
            {g.guildName || g.name}
          </h1>
          {g.guildName && g.guildName !== g.name && (
            <p class="text-muted-foreground text-sm mt-0.5">{g.name}</p>
          )}
          {g.tags && g.tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mt-3">
              {g.tags.map((tag: string) => <Badge variant="secondary">{tag}</Badge>)}
            </div>
          )}
        </div>
        <button
          id="share-btn"
          title="Copy link"
          class="text-muted-foreground hover:text-foreground transition-colors p-2 rounded-lg hover:bg-muted cursor-pointer shrink-0"
        >
          <svg id="share-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          <svg id="check-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden text-green-500"><polyline points="20 6 9 17 4 12"/></svg>
        </button>
      </div>
    )}

    <script is:inline>
      document.getElementById("share-btn").addEventListener("click", async () => {
        const shareIcon = document.getElementById("share-icon")
        const checkIcon = document.getElementById("check-icon")
        const url = window.location.href
        try {
          if (navigator.share) {
            await navigator.share({ title: document.title, url })
          } else {
            await navigator.clipboard.writeText(url)
            window.umami?.track("share_url_copied", { type: "solo" })
            shareIcon.classList.add("hidden")
            checkIcon.classList.remove("hidden")
            setTimeout(() => {
              shareIcon.classList.remove("hidden")
              checkIcon.classList.add("hidden")
            }, 2000)
          }
        } catch {}
      })
    </script>

    <!-- Stats strip -->
    <div class="flex flex-wrap gap-3">
      <div class="rounded-xl border border-border bg-card px-4 py-2 min-w-35 flex-1">
        <div class="text-xs text-muted-foreground mb-1">Builder</div>
        <div class="text-sm font-medium">{g.builders?.map(formatBuilderName).filter(Boolean).join(", ") || "—"}</div>
      </div>
      <div class="rounded-xl border border-border bg-card px-4 py-2">
        <div class="flex gap-5">
          <div>
            <div class="text-xs text-muted-foreground mb-1">Score</div>
            <div class="text-sm font-bold font-mono tabular-nums">{g.score}</div>
          </div>
          <div class="border-l border-border pl-5">
            <div class="text-xs text-muted-foreground mb-1">Rank</div>
            <div class="text-sm font-semibold">{rankLabel(g.rank)}</div>
          </div>
        </div>
      </div>
      {g.lastModified && (
        <div class="rounded-xl border border-border bg-card px-4 py-2">
          <div class="text-xs text-muted-foreground mb-1">Updated</div>
          <div class="text-sm text-muted-foreground">{g.lastModified}</div>
        </div>
      )}
      {g.discordThread && (
        <div class="rounded-xl border border-border bg-card px-4 py-2 flex flex-row items-center gap-2">
          <a href="https://discord.gg/Qygt9u26Bn" target="_blank" rel="noopener noreferrer" class={buttonVariants({ variant: "secondary", size: "sm" })} data-umami-event="discord_cta_click">
            Join server ↗
          </a>
          <a href={g.discordThread} target="_blank" rel="noopener noreferrer" class={buttonVariants({ size: "sm" })} data-umami-event="discord_cta_click">
            Vote ↗
          </a>
        </div>
      )}
    </div>

    <!-- Lore -->
    {g.lore && (
      <section class="space-y-3">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-muted-foreground flex items-center gap-1.5"><BookOpen size={13} />Lore</h2>
        <div class="border-l-2 border-border pl-4">
          <div
            class="text-sm text-muted-foreground leading-relaxed space-y-2 [&_strong]:text-foreground [&_strong]:font-medium"
            set:html={renderMarkdown(g.lore)}
          />
        </div>
      </section>
    )}

    <!-- What to Visit -->
    {g.whatToVisit && (
      <section class="space-y-3">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-muted-foreground flex items-center gap-1.5"><MapPin size={13} />What to Visit</h2>
        <div class="rounded-xl bg-muted/40 border border-border px-5 py-4">
          <div
            class="text-sm leading-relaxed space-y-3 [&_ul]:space-y-1.5 [&_li]:flex [&_li]:gap-2 [&_li]:before:content-['·'] [&_li]:before:text-muted-foreground [&_strong]:font-semibold"
            set:html={renderMarkdown(g.whatToVisit)}
          />
        </div>
      </section>
    )}

    <div class="border-t border-border" />

    <!-- Media -->
    <section class="space-y-4">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-muted-foreground flex items-center gap-1.5"><Images size={13} />Media</h2>
      <MediaGallery screenshots={g.screenshots} screenshotSections={g.screenshotSections} videos={g.videos} />
    </section>

    <!-- Discord CTA banner -->
    {g.discordThread && (
      <div class="rounded-2xl bg-muted/50 border border-border px-6 py-5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
          <p class="font-semibold">Like what you see?</p>
          <p class="text-sm text-muted-foreground mt-0.5">Vote for this build on Discord or join the community.</p>
        </div>
        <div class="flex flex-wrap gap-2 shrink-0">
          <a href="https://discord.gg/Qygt9u26Bn" target="_blank" rel="noopener noreferrer" class={buttonVariants({ variant: "secondary" })} data-umami-event="discord_cta_click">
            Join server ↗
          </a>
          <a href={g.discordThread} target="_blank" rel="noopener noreferrer" class={buttonVariants({})} data-umami-event="discord_cta_click">
            Vote ↗
          </a>
        </div>
      </div>
    )}
  </div>
</Layout>
