---
import Layout from "@/layouts/main.astro"
import MediaGallery from "@/components/MediaGallery.astro"
import { Badge } from "@/components/ui/badge"
import { buttonVariants } from "@/components/ui/button"
import { getSolosSortedByScore } from "@/lib/guilds"
import { rankLabel } from "@/lib/slugify"
import { renderMarkdown } from "@/lib/markdown"
import { BASE } from "@/lib/url"

export async function getStaticPaths() {
  const solos = getSolosSortedByScore()
  return solos.map((g) => ({
    params: { slug: g.slug },
    props: { solo: g },
  }))
}

const { solo: g } = Astro.props
const base = BASE
const ogImage = g.coverImage ?? g.screenshots?.[0]
---

<Layout
  title={`${g.name} — A Where Winds Meet construction`}
  description={g.lore?.slice(0, 160) ?? `Solo build showcase for ${g.name} in Where Winds Meet.`}
  image={ogImage}
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      headline: `${g.name} — Solo Build`,
      description: g.lore?.slice(0, 160) ?? `Solo build showcase for ${g.name} in Where Winds Meet.`,
      ...(ogImage ? { image: [{ "@type": "ImageObject", url: ogImage, width: 1280, height: 720 }] } : {}),
      datePublished: "2025-01-01",
      url: Astro.url.href,
      author: g.builders?.map((name: string) => ({ "@type": "Person", name })) ?? [],
      publisher: { "@type": "Organization", name: "Where Builders Meet", url: "https://www.wherebuildersmeet.com" },
    })}
  />
  <div class="max-w-5xl space-y-8">
    <a
      href={`${base}/solo`}
      class="inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground transition-colors"
    >
      ← Solo construction
    </a>

    <div>
      <div class="flex items-center gap-2">
        <h1 class="font-heading text-2xl font-semibold">{g.guildName || g.name}</h1>
        <button id="share-btn" title="Copy link" class="text-muted-foreground hover:text-foreground transition-colors p-1 rounded cursor-pointer">
          <svg id="share-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          <svg id="check-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden text-green-500"><polyline points="20 6 9 17 4 12"/></svg>
        </button>
      </div>
      <div class="flex flex-wrap gap-1.5 mt-2">
        {
          g.tags?.map((tag) => (
            <Badge variant="secondary">{tag}</Badge>
          ))
        }
      </div>
    </div>
    <script is:inline>
      document.getElementById("share-btn").addEventListener("click", async () => {
        const shareIcon = document.getElementById("share-icon")
        const checkIcon = document.getElementById("check-icon")
        const url = window.location.href
        try {
          if (navigator.share) {
            await navigator.share({ title: document.title, url })
          } else {
            await navigator.clipboard.writeText(url)
            shareIcon.classList.add("hidden")
            checkIcon.classList.remove("hidden")
            checkIcon.classList.add("text-green-500")
            setTimeout(() => {
              shareIcon.classList.remove("hidden")
              checkIcon.classList.add("hidden")
            }, 2000)
          }
        } catch {}
      })
    </script>

    <!-- Metadata card -->
    <div class="rounded-xl ring-1 ring-border overflow-hidden flex flex-col sm:flex-row">
      {ogImage && (
        <div class="sm:w-2/5 shrink-0 aspect-video sm:aspect-auto">
          <img src={ogImage} alt={g.name} class="w-full h-full object-cover" />
        </div>
      )}
      <div class="divide-y divide-border flex-1">
        <div class="flex items-center gap-3 px-4 py-3">
          <span class="text-muted-foreground text-sm w-24 shrink-0">🔨 Builder</span>
          <span class="text-sm font-medium">{g.builders.join(", ") || "—"}</span>
        </div>
        <div class="flex items-center gap-3 px-4 py-3">
          <span class="text-muted-foreground text-sm w-24 shrink-0">⭐ Score</span>
          <span class="text-sm font-semibold font-mono">{g.score}</span>
        </div>
        <div class="flex items-center gap-3 px-4 py-3">
          <span class="text-muted-foreground text-sm w-24 shrink-0">🏆 Rank</span>
          <span class="text-sm">{rankLabel(g.rank)}</span>
        </div>
        {g.discordThread && (
          <div class="flex items-center gap-3 px-4 py-3">
            <span class="text-muted-foreground text-sm w-24 shrink-0">💬 Discord</span>
            <div class="flex flex-wrap gap-2">
              <a href="https://discord.gg/Qygt9u26Bn" target="_blank" rel="noopener noreferrer" class={buttonVariants({ variant: "secondary", size: "sm" })}>
                Join server ↗
              </a>
              <a href={g.discordThread} target="_blank" rel="noopener noreferrer" class={buttonVariants({ size: "sm" })}>
                Vote ↗
              </a>
            </div>
          </div>
        )}
      </div>
    </div>

    {
      g.lore && (
        <section>
          <h2 class="font-heading text-base font-medium mb-2">📜 Lore</h2>
          <div
            class="text-sm text-muted-foreground leading-relaxed space-y-2 [&_strong]:text-foreground [&_strong]:font-medium"
            set:html={renderMarkdown(g.lore)}
          />
        </section>
      )
    }

    {
      g.whatToVisit && (
        <section>
          <h2 class="font-heading text-base font-medium mb-2">🗺️ What to Visit</h2>
          <div
            class="text-sm leading-relaxed space-y-3 [&_ul]:space-y-1.5 [&_li]:flex [&_li]:gap-2 [&_li]:before:content-['·'] [&_li]:before:text-muted-foreground [&_strong]:font-semibold"
            set:html={renderMarkdown(g.whatToVisit)}
          />
        </section>
      )
    }

    <section class="space-y-6">
      <h2 class="font-heading text-base font-medium">🎬 Media</h2>
      <MediaGallery screenshots={g.screenshots} screenshotSections={g.screenshotSections} videos={g.videos} />
    </section>

    {g.discordThread && (
      <div class="flex flex-wrap gap-3">
        <a href="https://discord.gg/Qygt9u26Bn" target="_blank" rel="noopener noreferrer" class={buttonVariants({ variant: "secondary", size: "lg" })}>Join server ↗</a>
        <a href={g.discordThread} target="_blank" rel="noopener noreferrer" class={buttonVariants({ size: "lg" })}>Vote on Discord ↗</a>
      </div>
    )}
  </div>
</Layout>
