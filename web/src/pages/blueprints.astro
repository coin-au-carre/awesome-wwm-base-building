---
import Layout from "@/layouts/main.astro"
import { BlueprintGrid } from "@/components/BlueprintGrid"
import { buttonVariants } from "@/components/ui/button"
import { Card, CardContent } from "@/components/ui/card"
import { Badge } from "@/components/ui/badge"
import { getBlueprintsSortedByScore, getAllBlueprintTags, hasBlueprints } from "@/lib/blueprints"
import { getLastSyncDate } from "@/lib/guilds"
import { BASE } from "@/lib/url"
import { BlueprintIcon, ArrowsClockwiseIcon, InfoIcon } from "@phosphor-icons/react"

const blueprints = getBlueprintsSortedByScore()
const allTags = getAllBlueprintTags()
const lastSync = getLastSyncDate()
const isEmpty = !hasBlueprints()
const ogImage = blueprints.map((bp) => bp.coverImage ?? bp.screenshots?.[0]).find(Boolean)
---

<Layout
  title="Where Builders Meet | Blueprints & Diagrams for Where Winds Meet"
  description="Browse community-shared blueprints and construction diagrams for Where Winds Meet. Filter by free or pay-to-build, style, and more."
  image={ogImage}
>
  <div class="space-y-6">

   
    <div class="flex flex-col gap-3">
      <div class="flex items-center gap-3 flex-wrap">
        <h1 class="font-heading text-2xl font-semibold mb-1 flex items-center gap-2">
          <BlueprintIcon weight="duotone" className="size-6 text-primary" />
          Blueprints
        </h1>
        <Badge variant="secondary">{blueprints.length} blueprint{blueprints.length !== 1 ? "s" : ""}</Badge>
        {!isEmpty && (
          <Badge variant="outline" className="font-normal text-muted-foreground gap-1.5">
            <ArrowsClockwiseIcon weight="fill" className="size-3 text-green-500" /> Last sync: <span id="last-sync-date">{lastSync}</span>
          </Badge>
        )}
        {!isEmpty && lastSync && (
          <script is:inline define:vars={{ lastSync }}>
            const d = new Date(lastSync)
            const pad = n => String(n).padStart(2, "0")
            document.getElementById("last-sync-date").textContent = `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}`
          </script>
        )}
      </div>
      <!-- <p class="text-muted-foreground text-sm">
        Community-shared construction diagrams. <span class="whitespace-nowrap">Share yours on <a href="https://discord.gg/Qygt9u26Bn" class="text-foreground underline underline-offset-2 hover:text-primary transition-colors" data-umami-event="discord_cta_click">Discord ↗</a></span>
      </p> -->
       <!-- How it works banner -->
    <div class="rounded-xl border border-blue-500/30 bg-blue-500/5 px-5 py-4 flex items-start gap-3">
      <InfoIcon weight="duotone" className="size-5 shrink-0 text-blue-500 mt-0.5" />
      <div class="space-y-1">
        <p class="font-medium text-sm">How blueprints work</p>
        <p class="text-sm text-muted-foreground leading-relaxed">
          A builder places a pre-made diagram in your world. You remove the outline on the diagram, then build on top of it to recreate the structure.
        </p>
      </div>
    </div>
    </div>

    {
      isEmpty && (
        <div class="rounded-xl border border-dashed border-amber-500/50 bg-amber-500/5 px-6 py-4 flex items-start gap-3">
          <InfoIcon weight="duotone" className="size-5 shrink-0 text-amber-500" />
          <div>
            <p class="font-medium text-sm">Work in progress</p>
            <p class="text-sm text-muted-foreground mt-0.5">
              Blueprint sharing is a new feature. We're collecting submissions — check back soon or{" "}
              <a href="https://discord.gg/Qygt9u26Bn" class="underline hover:text-foreground transition-colors" data-umami-event="discord_cta_click">
                join the Discord
              </a>{" "}
              to be notified.
            </p>
          </div>
        </div>
      )
    }

    <!-- Grid with filters -->
    {
      blueprints.length > 0 && (
        <section>
          <BlueprintGrid client:load blueprints={blueprints} allTags={allTags} />
        </section>
      )
    }

    {
      isEmpty && (
        <Card>
          <CardContent className="flex flex-col sm:flex-row items-start sm:items-center gap-4">
            <div class="flex-1">
              <p class="font-medium text-sm">Want to share a blueprint?</p>
              <p class="text-sm text-muted-foreground mt-0.5">
                 Post in <span class="font-medium text-foreground">#blueprint-sharing</span> on the Discord server.
              </p>
            </div>
            <a
              href="https://discord.gg/Qygt9u26Bn"
              target="_blank"
              rel="noopener noreferrer"
              class={`shrink-0 ${buttonVariants({ size: "lg" })}`}
              data-umami-event="discord_cta_click"
            >
              Join Discord ↗
            </a>
          </CardContent>
        </Card>
      )
    }
  </div>
</Layout>
