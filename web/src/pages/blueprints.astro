---
import Layout from "@/layouts/main.astro"
import { BlueprintPageTabs } from "@/components/BlueprintPageTabs"
import { buttonVariants } from "@/components/ui/button"
import { Card, CardContent } from "@/components/ui/card"
import { Badge } from "@/components/ui/badge"
import { getBlueprintsSortedByScore, getAllBlueprintTags, hasBlueprints } from "@/lib/blueprints"
import { getBuilderProfile } from "@/lib/builders"
import { getLastSyncDate } from "@/lib/guilds"
import { formatSyncDate } from "@/lib/dates"
import { thumbUrl, builderSlug, slugify } from "@/lib/format"
import { resolveCanonical } from "@/lib/builder-aliases"
import { BASE } from "@/lib/url"
import { BlueprintIcon, ArrowsClockwiseIcon, InfoIcon } from "@phosphor-icons/react"

const blueprints = getBlueprintsSortedByScore()
const allTags = getAllBlueprintTags()
const lastSync = getLastSyncDate()
const isEmpty = !hasBlueprints()
const ogImage = blueprints.map((bp) => bp.coverImage ?? bp.screenshots?.[0]).find(Boolean)

const builderSeen = new Set<string>()
const builderCards = blueprints
  .filter((bp) => bp.builderName)
  .reduce<{ name: string; slug: string; blueprints: { name: string; slug: string; coverImage?: string; isFree?: boolean; isPayToBuild?: boolean; price?: string }[] }[]>((acc, bp) => {
    const slug = resolveCanonical(builderSlug(bp.builderName!))
    if (!slug) return acc
    const profile = getBuilderProfile(slug)
    if (builderSeen.has(slug)) return acc
    builderSeen.add(slug)
    const builderBlueprints = (profile?.blueprints ?? [bp]).map((b) => ({
      name: b.name,
      slug: b.slug ?? slugify(b.name),
      coverImage: (b.coverImage ?? b.screenshots?.[0]) ? thumbUrl(b.coverImage ?? b.screenshots![0]) : undefined,
      isFree: b.isFree,
      isPayToBuild: b.isPayToBuild,
      price: b.price,
    }))
    acc.push({
      name: profile?.name ?? bp.builderName!,
      slug,
      blueprints: builderBlueprints,
    })
    return acc
  }, [])
---

<Layout
  title="Where Builders Meet | Blueprints & Diagrams for Where Winds Meet"
  description="Browse community-shared blueprints and construction diagrams for Where Winds Meet. Filter by free or pay-to-build, style, and more."
  image={ogImage}
>
  <div class="space-y-6">
    <div class="flex flex-col gap-3">
      <div class="flex items-center gap-3 flex-wrap">
        <h1 class="font-heading text-2xl font-semibold mb-1 flex items-center gap-2">
          <BlueprintIcon weight="duotone" className="size-6 text-primary" />
          Blueprints
        </h1>
        <Badge variant="secondary">{blueprints.length} blueprint{blueprints.length !== 1 ? "s" : ""}</Badge>
        {!isEmpty && lastSync && (
          <Badge variant="outline" className="font-normal text-muted-foreground gap-1.5">
            <ArrowsClockwiseIcon weight="fill" className="size-3 text-green-500" /> {formatSyncDate(lastSync)}
          </Badge>
        )}
      </div>
       <!-- How it works banner -->
    <div class="rounded-xl border border-blue-500/30 bg-blue-500/5 px-5 py-4 flex items-start gap-3">
      <InfoIcon weight="duotone" className="size-5 shrink-0 text-blue-500 mt-0.5" />
      <div class="space-y-1">
        <p class="font-medium text-sm">How blueprints work</p>
        <p class="text-sm text-muted-foreground leading-relaxed">
          A builder places a pre-made diagram in your world. You generally provide the materials and you build the components of the diagram yourself to recreate the structure.
        </p>
      </div>
    </div>
    </div>

    {
      isEmpty && (
        <div class="rounded-xl border border-dashed border-amber-500/50 bg-amber-500/5 px-6 py-4 flex items-start gap-3">
          <InfoIcon weight="duotone" className="size-5 shrink-0 text-amber-500" />
          <div>
            <p class="font-medium text-sm">Work in progress</p>
            <p class="text-sm text-muted-foreground mt-0.5">
              Blueprint sharing is a new feature. We're collecting submissions — check back soon or{" "}
              <a href="https://discord.gg/Qygt9u26Bn" class="underline hover:text-foreground transition-colors" data-umami-event="discord_cta_click">
                join the Discord
              </a>{" "}
              to be notified.
            </p>
          </div>
        </div>
      )
    }

    <!-- Tabs: Blueprints | Builders -->
    {
      !isEmpty && (
        <section>
          <BlueprintPageTabs client:load blueprints={blueprints} allTags={allTags} builders={builderCards} />
        </section>
      )
    }

    <!-- Share your blueprint CTA -->
    <div class="rounded-xl border border-violet-500/30 bg-violet-500/5 px-5 py-4 flex flex-col sm:flex-row sm:items-center gap-3">
      <p class="text-sm flex-1 text-muted-foreground">
        Have a blueprint to share? Post it in <span class="font-medium text-foreground">#blueprint-sharing</span> on the Discord server and it will appear here. See the <a href="https://www.wherebuildersmeet.com/contribute/builder/?mode=blueprint" class="underline underline-offset-2 hover:text-foreground transition-colors">submission guidelines</a>.
      </p>
      <a
        href="https://discord.gg/Qygt9u26Bn"
        target="_blank"
        rel="noopener noreferrer"
        class={`shrink-0 ${buttonVariants({ variant: "outline", size: "sm" })}`}
        data-umami-event="discord_cta_click"
      >
        Share on Discord ↗
      </a>
    </div>

    {
      isEmpty && (
        <Card>
          <CardContent className="flex flex-col sm:flex-row items-start sm:items-center gap-4">
            <div class="flex-1">
              <p class="font-medium text-sm">Want to share a blueprint?</p>
              <p class="text-sm text-muted-foreground mt-0.5">
                 Post in <span class="font-medium text-foreground">#blueprint-sharing</span> on the Discord server.
              </p>
            </div>
            <a
              href="https://discord.gg/Qygt9u26Bn"
              target="_blank"
              rel="noopener noreferrer"
              class={`shrink-0 ${buttonVariants({ size: "lg" })}`}
              data-umami-event="discord_cta_click"
            >
              Join Discord ↗
            </a>
          </CardContent>
        </Card>
      )
    }
  </div>
</Layout>
