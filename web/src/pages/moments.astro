---
import Layout from "@/layouts/main.astro"
import { ImagesIcon, ArrowSquareOutIcon, ShuffleIcon, SortAscendingIcon } from "@phosphor-icons/react"
import { getWhateverPosts, getWhateverStats } from "@/lib/whatever"
import { getUsers } from "@/lib/guilds"
import { BASE } from "@/lib/url"
import { thumbUrl } from "@/lib/format"

const users = getUsers()

function resolveContent(raw: string): string {
  if (!raw) return ""
  return raw
    .replace(/<@!?(\d+)>/g, (_, id) => {
      const u = users[id]
      if (!u) return ""
      const name = u.nickname ?? u.globalName ?? u.username ?? ""
      return name ? `@${name}` : ""
    })
    .replace(/<a?:([^:>]+):\d+>/g, "")  // strip custom emoji entirely
    .replace(/<[#@&]\d+>/g, "")          // strip channel/role mentions
    .replace(/\s{2,}/g, " ")
    .trim()
}

const posts = getWhateverPosts()
const { totalImages, totalVideos, totalContributors } = getWhateverStats()
const ogImage = posts.flatMap((p) => p.images ?? []).find(Boolean) ?? undefined

// One grid item per image or video. Cap at 2 images for posts with more than 3.
// isPrimary = shown first; extras go at the end so similar shots don't cluster.
const items = posts.flatMap((p) => {
  const rawImages = p.images ?? []
  const images = rawImages.length > 3 ? rawImages.slice(0, 2) : rawImages
  const common = {
    postId: p.id,
    displayName: p.displayName,
    builderPath: p.builderPath,
    content: resolveContent(p.content ?? ""),
    reactions: p.reactions,
    reactionDetails: p.reactionDetails ?? [],
    messageUrl: p.messageUrl,
    postedAt: p.postedAt,
  }
  const hasVideo = (p.videos ?? []).length > 0
  const imgItems = images.map((img, imgIdx) => ({
    ...common,
    kind: "image" as const,
    src: img,
    thumb: thumbUrl(img),
    allImgs: images,
    allThumbs: images.map((s) => thumbUrl(s)),
    isPrimary: imgIdx === 0 && !hasVideo,
  }))
  const videoItems = (p.videos ?? []).map((vid) => ({
    ...common,
    kind: "video" as const,
    src: vid,
    thumb: "",
    allImgs: [] as string[],
    allThumbs: [] as string[],
    isPrimary: true,
  }))
  return [...videoItems, ...imgItems]
})

const FOUR_DAYS_MS = 4 * 24 * 60 * 60 * 1000
const recentCutoff = Date.now() - FOUR_DAYS_MS
const recentTopItems = items
  .filter((item) => item.isPrimary && item.reactions > 0 && item.postedAt && new Date(item.postedAt).getTime() >= recentCutoff)
  .sort((a, b) => new Date(b.postedAt).getTime() - new Date(a.postedAt).getTime())
  .slice(0, 8)
---

<Layout
  title="Where Builders Meet | Moments — Community Screenshots"
  description="Player screenshots from Where Winds Meet shared by the community — landscapes, builds, and memorable moments from the game."
  image={ogImage}
>
  <div class="space-y-6">

    <!-- Header -->
    <div class="flex flex-col gap-2">
      <h1 class="font-heading text-2xl font-semibold flex items-center gap-2">
        <ImagesIcon weight="duotone" className="size-6 text-primary" /> Moments
      </h1>
      <p class="text-muted-foreground text-sm">
        Screenshots and videos shared in <a href="https://discord.gg/Qygt9u26Bn" target="_blank" rel="noopener noreferrer" class="text-foreground underline underline-offset-2 hover:text-primary transition-colors" data-umami-event="discord_cta_click">#whatever-showcase ↗</a> by community members.
      </p>
    </div>

    {items.length === 0 ? (
      <div class="py-20 text-center text-muted-foreground text-sm">
        No screenshots yet. Check back soon!
      </div>
    ) : (
      <>
        <!-- Stats + Controls -->
        <div class="flex items-center justify-between gap-3 flex-wrap">
          <div class="flex items-center gap-3 text-xs text-muted-foreground">
            <span class="inline-flex items-center gap-1.5 bg-muted rounded-full px-2.5 py-1">
              <ImagesIcon weight="duotone" className="size-3" /> {totalImages} screenshots{totalVideos > 0 ? ` · ${totalVideos} videos` : ""}
            </span>
            <span class="inline-flex items-center gap-1.5 bg-muted rounded-full px-2.5 py-1">
              👥 {totalContributors} contributors
            </span>
          </div>
          <div class="flex items-center gap-2">
            <div class="flex rounded-lg overflow-hidden ring-1 ring-border text-xs">
              <button
                id="sort-reactions"
                class="sort-btn px-3 py-1.5 flex items-center gap-1.5 bg-primary text-primary-foreground"
                data-sort="reactions"
                data-umami-event="community_sort"
                data-umami-event-sort="reactions"
              >
                <SortAscendingIcon weight="bold" className="size-3" /> Top
              </button>
              <button
                id="sort-newest"
                class="sort-btn px-3 py-1.5 flex items-center gap-1.5 hover:bg-muted transition-colors"
                data-sort="newest"
                data-umami-event="community_sort"
                data-umami-event-sort="newest"
              >
                Newest
              </button>
            </div>
            <button
              id="shuffle-btn"
              class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg ring-1 ring-border text-xs hover:bg-muted transition-colors"
              data-umami-event="community_shuffle"
            >
              <ShuffleIcon weight="bold" className="size-3" /> Shuffle
            </button>
          </div>
        </div>

        <!-- Recent top picks -->
        {recentTopItems.length > 0 && (
          <div class="space-y-1.5">
            <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground flex items-center gap-1.5">
              <span class="inline-block size-1.5 rounded-full bg-primary animate-pulse" />
              Fresh picks
            </h2>
            <div id="fresh-gallery" class="grid grid-cols-2 sm:grid-cols-4 gap-2">
              {recentTopItems.map((item) => (
                <div
                  class={`gallery-item group relative rounded-xl overflow-hidden bg-muted ring-1 ring-primary/40 hover:ring-primary transition-all ${item.kind === "video" ? "cursor-pointer" : "cursor-zoom-in"}`}
                  data-kind={item.kind}
                  data-post-id={item.postId}
                  data-img={item.src}
                  data-thumb={item.thumb}
                  data-all-imgs={JSON.stringify(item.allImgs)}
                  data-all-thumbs={JSON.stringify(item.allThumbs)}
                  data-display-name={item.displayName}
                  data-builder-path={item.builderPath ?? ""}
                  data-content={item.content}
                  data-reactions={item.reactions}
                  data-reaction-details={JSON.stringify(item.reactionDetails)}
                  data-message-url={item.messageUrl}
                  data-posted-at={item.postedAt}
                  data-primary="1"
                >
                  <span class="absolute top-1.5 right-1.5 z-10 inline-flex items-center gap-1 rounded-full bg-primary/90 px-1.5 py-0.5 text-[10px] font-semibold text-primary-foreground backdrop-blur-sm shadow-sm pointer-events-none">
                    ✦ New
                  </span>
                  {item.kind === "video" ? (
                    <div class="aspect-video relative overflow-hidden">
                      <video src={item.src} preload="metadata" muted playsinline class="w-full h-full object-cover pointer-events-none transition-transform duration-300 group-hover:scale-[1.03]" />
                      <div class="absolute inset-0 flex items-center justify-center bg-black/20 group-hover:bg-black/30 transition-colors">
                        <svg class="size-10 text-white/80 drop-shadow" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M8 5v14l11-7z" />
                        </svg>
                      </div>
                    </div>
                  ) : (
                    <img
                      src={item.thumb}
                      alt={`Screenshot by ${item.displayName}`}
                      loading="eager"
                      decoding="async"
                      onerror="this.closest('.gallery-item').style.display='none'"
                      class="w-full h-auto block transition-transform duration-300 group-hover:scale-[1.03]"
                    />
                  )}
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Gallery -->
        <div id="gallery" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2">
          {items.map((item, i) => (
            <div
              class={`gallery-item group rounded-xl overflow-hidden bg-muted ring-1 ring-border hover:ring-primary transition-all ${item.kind === "video" ? "cursor-pointer" : "cursor-zoom-in"}`}
              data-kind={item.kind}
              data-post-id={item.postId}
              data-img={item.src}
              data-thumb={item.thumb}
              data-all-imgs={JSON.stringify(item.allImgs)}
              data-all-thumbs={JSON.stringify(item.allThumbs)}
              data-display-name={item.displayName}
              data-builder-path={item.builderPath ?? ""}
              data-content={item.content}
              data-reactions={item.reactions}
              data-reaction-details={JSON.stringify(item.reactionDetails)}
              data-message-url={item.messageUrl}
              data-posted-at={item.postedAt}
              data-primary={item.isPrimary ? "1" : "0"}
            >
              {item.kind === "video" ? (
                <div class="aspect-video relative overflow-hidden">
                  <video src={item.src} preload="metadata" muted playsinline class="w-full h-full object-cover pointer-events-none transition-transform duration-300 group-hover:scale-[1.03]" />
                  <div class="absolute inset-0 flex items-center justify-center bg-black/20 group-hover:bg-black/30 transition-colors">
                    <svg class="size-10 text-white/80 drop-shadow" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M8 5v14l11-7z" />
                    </svg>
                  </div>
                </div>
              ) : (
                <img
                  src={item.thumb}
                  alt={`Screenshot by ${item.displayName}`}
                  loading={i < 6 ? "eager" : "lazy"}
                  decoding="async"
                  fetchpriority={i < 2 ? "high" : undefined}
                  onerror="this.closest('.gallery-item').style.display='none'"
                  class="w-full h-auto block transition-transform duration-300 group-hover:scale-[1.03]"
                />
              )}
            </div>
          ))}
        </div>
      </>
    )}
  </div>

  <!-- Lightbox -->
  <div
    id="lightbox"
    class="fixed inset-0 z-50 bg-black/90 backdrop-blur-sm"
    style="display:none;opacity:0;transition:opacity 200ms ease"
    role="dialog"
    aria-modal="true"
  >
    <!-- Image layers (thumb shows instantly, full-res fades in on top) -->
    <div id="lb-img-wrap" class="absolute inset-0 bottom-10">
      <img id="lb-thumb" src="" alt="" class="absolute inset-0 w-full h-full object-contain p-2 select-none" style="opacity:0" />
      <img id="lb-img"   src="" alt="" class="absolute inset-0 w-full h-full object-contain p-2 select-none" style="opacity:0;transition:opacity 300ms ease-out" />
      <!-- Video layer -->
      <video id="lb-video" src="" controls playsinline class="absolute inset-0 w-full h-full object-contain p-2" style="display:none" />
    </div>

    <!-- Speech bubble -->
    <div id="lb-bubble" class="lb-bubble" style="display:none" aria-live="polite"></div>

    <!-- Close -->
    <button
      id="lb-close"
      class="absolute top-4 right-4 z-10 text-white/60 hover:text-white transition-colors p-2 rounded-full hover:bg-white/10"
      aria-label="Close"
    >
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Prev -->
    <button
      id="lb-prev"
      class="absolute left-3 sm:left-6 top-1/2 -translate-y-1/2 z-10 text-white/60 hover:text-white transition-colors p-2 rounded-full hover:bg-white/10"
      aria-label="Previous"
    >
      <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
      </svg>
    </button>

    <!-- Next -->
    <button
      id="lb-next"
      class="absolute right-3 sm:right-6 top-1/2 -translate-y-1/2 z-10 text-white/60 hover:text-white transition-colors p-2 rounded-full hover:bg-white/10"
      aria-label="Next"
    >
      <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
      </svg>
    </button>

    <!-- Caption -->
    <div class="absolute bottom-0 left-0 right-0 z-10 flex items-center justify-center gap-3 px-4 py-2.5 flex-wrap">
      <span id="lb-author-wrap" class="text-sm font-semibold text-white"></span>
      <span id="lb-reactions" class="text-white/50 text-xs"></span>
      <span id="lb-counter" class="text-white/40 text-xs"></span>
      <a
        id="lb-discord-link"
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1 text-xs text-white/50 hover:text-white transition-colors"
        data-umami-event="community_discord_link_click"
      >
        <ArrowSquareOutIcon weight="bold" className="size-3.5" /> Discord
      </a>
    </div>
  </div>
</Layout>

<style>
  @keyframes lb-zoom-in  { from { transform: scale(0.88); } to { transform: scale(1); } }
  @keyframes lb-zoom-out { from { transform: scale(1); }    to { transform: scale(0.88); } }

  .lb-bubble {
    position: absolute;
    bottom: 56px;
    left: 24px;
    z-index: 10;
    max-width: min(320px, calc(100vw - 48px));
    background: rgba(15, 15, 15, 0.82);
    color: #f0f0f0;
    font-size: 0.8125rem;
    line-height: 1.5;
    padding: 10px 14px;
    border-radius: 14px 14px 14px 4px;
    backdrop-filter: blur(6px);
    white-space: pre-wrap;
    word-break: break-word;
    pointer-events: none;
    box-shadow: 0 2px 12px rgba(0,0,0,0.5);
  }

  .lb-bubble::after {
    content: "";
    position: absolute;
    bottom: -8px;
    left: 14px;
    border: 8px solid transparent;
    border-top-color: rgba(15, 15, 15, 0.82);
    border-bottom: 0;
  }
</style>

<script is:inline define:vars={{ BASE }}>
  // Wrap in astro:page-load so the setup re-runs on every client-side navigation.
  // ClientRouter skips re-running identical inline scripts, so top-level setup would
  // be skipped when navigating back to this page, leaving gallery clicks unhooked.
  document.addEventListener("astro:page-load", function setupMomentsPage() {
    const gallery = document.getElementById("gallery")
    if (!gallery) return

    const lightbox = document.getElementById("lightbox")
    const lbImgWrap = document.getElementById("lb-img-wrap")
    const lbThumb = document.getElementById("lb-thumb")
    const lbImg = document.getElementById("lb-img")
    const lbVideo = document.getElementById("lb-video")
    const lbAuthorWrap = document.getElementById("lb-author-wrap")
    const lbReactions = document.getElementById("lb-reactions")
    const lbCounter = document.getElementById("lb-counter")
    const lbLink = document.getElementById("lb-discord-link")
    const lbClose = document.getElementById("lb-close")
    const lbPrev = document.getElementById("lb-prev")
    const lbNext = document.getElementById("lb-next")
    const lbBubble = document.getElementById("lb-bubble")
    const preloaded = new Set()
    let closing = false

    function getItems() {
      return [...gallery.querySelectorAll(".gallery-item")]
    }

    let currentItems = []
    let currentIndex = 0
    let subImages = []
    let subIndex = 0

    function preloadFull(src) {
      if (!src || preloaded.has(src)) return
      preloaded.add(src)
      new Image().src = src
    }

    function renderLightbox() {
      const item = currentItems[currentIndex]
      const isVideo = item.dataset.kind === "video"
      subImages = JSON.parse(item.dataset.allImgs ?? "[]")
      const subThumbs = JSON.parse(item.dataset.allThumbs ?? "[]")

      if (isVideo) {
        lbThumb.style.opacity = "0"
        lbImg.style.opacity = "0"
        lbImg.src = ""
        lbVideo.style.display = "block"
        lbVideo.src = item.dataset.img ?? ""
        lbVideo.play().catch(() => {})
      } else {
        lbVideo.style.display = "none"
        lbVideo.pause()
        lbVideo.src = ""

        const fullSrc = subImages[subIndex] ?? item.dataset.img ?? ""
        const thumbSrc = subThumbs[subIndex] ?? item.dataset.thumb ?? fullSrc

        // 1. Show thumb immediately — already cached from the grid
        lbThumb.style.transition = "none"
        lbThumb.src = thumbSrc
        lbThumb.alt = `Screenshot by ${item.dataset.displayName}`
        lbThumb.style.opacity = "1"

        // 2. Reset full-res layer
        lbImg.style.transition = "none"
        lbImg.style.opacity = "0"
        lbImg.src = ""

        // 3. Load full-res, fade it in on top once ready
        if (fullSrc && fullSrc !== thumbSrc) {
          const captured = { idx: currentIndex, sub: subIndex }
          const full = new Image()
          full.onload = () => {
            if (currentIndex !== captured.idx || subIndex !== captured.sub || closing) return
            lbImg.src = fullSrc
            lbImg.alt = `Screenshot by ${item.dataset.displayName}`
            requestAnimationFrame(() => {
              lbImg.style.transition = "opacity 300ms ease-out"
              lbImg.style.opacity = "1"
              lbThumb.style.transition = "opacity 300ms ease-out 200ms"
              lbThumb.style.opacity = "0"
            })
          }
          full.src = fullSrc
          preloaded.add(fullSrc)
        }

        // Preload neighbours (images only — skip video items)
        const nextSubFull = subImages[subIndex + 1]
        if (nextSubFull) preloadFull(nextSubFull)
        else {
          const nextItem = currentItems[(currentIndex + 1) % currentItems.length]
          if (nextItem && nextItem.dataset.kind !== "video") preloadFull(JSON.parse(nextItem.dataset.allImgs ?? "[]")[0] ?? nextItem.dataset.img)
        }
        const prevSubFull = subImages[subIndex - 1]
        if (!prevSubFull && currentIndex > 0) {
          const prevItem = currentItems[currentIndex - 1]
          if (prevItem && prevItem.dataset.kind !== "video") preloadFull(JSON.parse(prevItem.dataset.allImgs ?? "[]")[0] ?? prevItem.dataset.img)
        }
      }

      const content = item.dataset.content ?? ""
      if (content) {
        lbBubble.textContent = content
        lbBubble.style.display = "block"
      } else {
        lbBubble.style.display = "none"
      }

      const name = item.dataset.displayName ?? ""
      const path = item.dataset.builderPath ?? ""
      if (path) {
        lbAuthorWrap.innerHTML = `<a href="${BASE}${path}" class="hover:underline underline-offset-2 text-white" data-umami-event="community_lb_author_click">${name}</a>`
      } else {
        lbAuthorWrap.textContent = name
      }

      const details = JSON.parse(item.dataset.reactionDetails ?? "[]")
      lbReactions.textContent = details.length > 0
        ? details.map((d) => `${d.emoji} ${d.count}`).join("  ")
        : ""
      lbCounter.textContent = `${currentIndex + 1} / ${currentItems.length}`
      lbLink.href = item.dataset.messageUrl ?? "#"
    }

    function openLightbox(items, idx, imgSrc) {
      currentItems = items
      currentIndex = idx
      closing = false
      const item = items[idx]
      subImages = JSON.parse(item.dataset.allImgs ?? "[]")
      subIndex = imgSrc ? Math.max(subImages.indexOf(imgSrc), 0) : 0
      renderLightbox()
      lightbox.style.display = "flex"
      lightbox.style.flexDirection = "column"
      lbImgWrap.style.animation = "lb-zoom-in 250ms ease-out both"
      requestAnimationFrame(() => requestAnimationFrame(() => { lightbox.style.opacity = "1" }))
      document.body.style.overflow = "hidden"
    }

    function closeLightbox() {
      if (closing) return
      closing = true
      lbImgWrap.style.animation = "lb-zoom-out 200ms ease-in both"
      lightbox.style.opacity = "0"
      setTimeout(() => {
        lightbox.style.display = "none"
        lbImgWrap.style.animation = ""
        lbThumb.style.opacity = "0"
        lbImg.style.opacity = "0"
        lbImg.src = ""
        lbVideo.pause()
        lbVideo.src = ""
        lbVideo.style.display = "none"
        document.body.style.overflow = ""
        closing = false
      }, 200)
    }

    function prevItem() {
      if (subIndex > 0) { subIndex--; renderLightbox(); return }
      currentIndex = (currentIndex - 1 + currentItems.length) % currentItems.length
      subImages = JSON.parse(currentItems[currentIndex].dataset.allImgs ?? "[]")
      subIndex = subImages.length - 1
      renderLightbox()
    }

    function nextItem() {
      if (subIndex < subImages.length - 1) { subIndex++; renderLightbox(); return }
      currentIndex = (currentIndex + 1) % currentItems.length
      subImages = JSON.parse(currentItems[currentIndex].dataset.allImgs ?? "[]")
      subIndex = 0
      renderLightbox()
    }

    gallery.addEventListener("click", (e) => {
      const card = e.target.closest(".gallery-item")
      if (!card) return
      const clickedImg = card.dataset.img
      const items = getItems()
      openLightbox(items, items.indexOf(card), clickedImg)
    })

    const freshGallery = document.getElementById("fresh-gallery")
    if (freshGallery) {
      freshGallery.addEventListener("click", (e) => {
        const card = e.target.closest(".gallery-item")
        if (!card) return
        const postId = card.dataset.postId
        const kind = card.dataset.kind
        const items = getItems()
        const idx = items.findIndex((el) => el.dataset.postId === postId && el.dataset.kind === kind)
        openLightbox(items, idx >= 0 ? idx : 0, card.dataset.img)
      })
    }

    lbClose.addEventListener("click", closeLightbox)
    lbPrev.addEventListener("click", prevItem)
    lbNext.addEventListener("click", nextItem)
    lightbox.addEventListener("click", (e) => { if (e.target === lightbox || e.target === lbImgWrap) closeLightbox() })
    document.addEventListener("keydown", (e) => {
      if (lightbox.style.display === "none") return
      if (e.key === "Escape") closeLightbox()
      if (e.key === "ArrowLeft") prevItem()
      if (e.key === "ArrowRight") nextItem()
    })

    let touchStartX = 0
    lightbox.addEventListener("touchstart", (e) => { touchStartX = e.touches[0].clientX }, { passive: true })
    lightbox.addEventListener("touchend", (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX
      if (Math.abs(dx) < 40) return
      if (dx < 0) nextItem(); else prevItem()
    }, { passive: true })

    const sortReactionsBtn = document.getElementById("sort-reactions")
    const sortNewestBtn = document.getElementById("sort-newest")
    const shuffleBtn = document.getElementById("shuffle-btn")

    function reorder(compareFn) {
      const items = getItems()
      const primary = items.filter((el) => el.dataset.primary === "1")
      const secondary = items.filter((el) => el.dataset.primary !== "1")
      primary.sort(compareFn)
      secondary.sort(compareFn)
      ;[...primary, ...secondary].forEach((el) => gallery.appendChild(el))
    }

    function setActiveSort(active, inactive) {
      active.classList.add("bg-primary", "text-primary-foreground")
      active.classList.remove("hover:bg-muted")
      inactive.classList.remove("bg-primary", "text-primary-foreground")
      inactive.classList.add("hover:bg-muted")
    }

    function sortByReactions() {
      reorder((a, b) => Number(b.dataset.reactions ?? 0) - Number(a.dataset.reactions ?? 0))
      setActiveSort(sortReactionsBtn, sortNewestBtn)
    }

    sortReactionsBtn.addEventListener("click", sortByReactions)
    sortByReactions()

    sortNewestBtn.addEventListener("click", () => {
      reorder((a, b) => (b.dataset.postedAt ?? "").localeCompare(a.dataset.postedAt ?? ""))
      setActiveSort(sortNewestBtn, sortReactionsBtn)
    })

    shuffleBtn.addEventListener("click", () => {
      reorder(() => Math.random() - 0.5)
      ;[sortReactionsBtn, sortNewestBtn].forEach((btn) => {
        btn.classList.remove("bg-primary", "text-primary-foreground")
        btn.classList.add("hover:bg-muted")
      })
    })
  })
</script>
