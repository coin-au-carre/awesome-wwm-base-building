---
import Layout from "@/layouts/main.astro"
import ContributeNav from "@/components/ContributeNav.astro"
import { BASE } from "@/lib/url"
import { Star, Eye, ShieldCheck, Sparkles } from "lucide-react"

const base = BASE

const guidelines = [
  "Voting on your own guild counts as a normal reaction and does not apply the Trusted Eye bonus.",
  "Only react if you've actually looked at the screenshots and visited the guild base. No support votes.",
  "Avoid coordinating votes with other Trusted Eyes on specific builds.",
  "Prioritize guilds with no recognition yet. The goal is to surface hidden gems, not just reward popular builders.",
]

const criteria = [
  ["First impression", "Does it immediately feel impressive or cohesive?"],
  ["Creativity", "Unexpected themes, layouts, or storytelling through builds."],
  ["Technique", "Clever use of layering, furniture tricks, or item combinations."],
  ["Consistency", "Does the style hold up throughout the base, not just in one spot?"],
  ["Atmosphere", "Lighting, color palette, and spatial flow."],
  ["Attention to detail", "Small touches that reward a closer look."],
  ["Theme execution", "How well does the build commit to and deliver on its concept?"],
]
---

<Layout
  title="Where Builders Meet | Voter guide"
  description="How to vote, leave feedback, and earn roles in the Where Builders Meet community."
>
  <div class="max-w-3xl space-y-10">
    <ContributeNav current="voter" />

    <div class="space-y-2">
      <h1 class="font-heading text-2xl font-semibold">Vote & review builds</h1>
      <p class="text-sm text-muted-foreground">
        Your reactions shape the rankings. The more broadly you vote, the more weight each reaction carries.
      </p>
    </div>

    <!-- Core loop -->
    <div class="space-y-6">
      <div class="space-y-1.5">
        <p class="text-sm font-medium text-foreground">Visit, then vote</p>
        <p class="text-sm text-muted-foreground leading-relaxed">
          The best votes come from actually visiting a guild in-game. Screenshots don't always do a base justice: hidden rooms, lighting, and atmosphere are hard to capture. Ask the builder for a tour if you can.
          Once you've been, react to the first post of the thread in <span class="font-medium text-foreground">#guild-base-showcase</span>. See the <a href={base + "/how-it-works"} class="text-foreground underline underline-offset-2 hover:text-primary transition-colors">how it works</a> page for how votes are counted.
        </p>
      </div>

      <div class="space-y-1.5">
        <p class="text-sm font-medium text-foreground">Check your voting spread</p>
        <p class="text-sm text-muted-foreground leading-relaxed">
          The more guilds you vote on, the more weight each of your votes carries in the rankings. Run <code class="rounded bg-muted px-1 py-0.5 font-mono text-xs">/my-votes</code> on the server to see how your reactions are distributed.
        </p>
      </div>

      <div class="space-y-1.5">
        <p class="text-sm font-medium text-foreground">Leave feedback</p>
        <p class="text-sm text-muted-foreground leading-relaxed">
          Reply inside a thread with genuine feedback: what works well, what could be improved, or what inspired you. Builders appreciate detailed feedback far more than just a reaction.
        </p>
      </div>
    </div>

    <div class="border-t border-border" />

    <!-- Critic role -->
    <div class="space-y-3">
      <div class="flex items-center gap-2">
        <Star size={16} className="text-amber-500 shrink-0" />
        <p class="text-sm font-semibold text-foreground">Critic</p>
      </div>
      <p class="text-sm text-muted-foreground leading-relaxed">
        The <span class="font-medium text-foreground">Critic</span> role is awarded automatically by the bot to active voters who engage broadly across many guilds. Keep voting consistently and it will come. Critic reactions carry more voting weight.
      </p>
    </div>

    <!-- Trusted Eye role -->
    <div class="space-y-4">
      <div class="flex items-center gap-2">
        <Eye size={16} className="text-violet-500 shrink-0" />
        <p class="text-sm font-semibold text-foreground">Trusted Eye</p>
      </div>

      <p class="text-sm text-muted-foreground leading-relaxed">
        The <span class="font-medium text-foreground">Trusted Eye</span> role is granted by moderators to members recognized for their expertise and quality feedback. It carries even more voting weight and comes with a few guidelines to keep rankings fair.
      </p>
      <p class="text-sm text-muted-foreground leading-relaxed">
        There's no formal application: moderators sometimes reach out to members who naturally engage broadly and leave thoughtful feedback. You can also DM a moderator if you're motivated to vote fairly. There's no time commitment beyond what you'd already enjoy.
      </p>

      <!-- Guidelines -->
      <div class="rounded-xl ring-1 ring-border overflow-hidden divide-y divide-border">
        {guidelines.map((body) => (
          <div class="flex gap-3 px-4 py-2.5">
            <ShieldCheck size={15} className="text-violet-400 shrink-0 mt-0.5" />
            <p class="text-sm text-muted-foreground">{body}</p>
          </div>
        ))}
      </div>

      <!-- What to look for -->
      <div class="space-y-3">
        <div class="flex items-center gap-1.5">
          <Sparkles size={13} className="text-violet-500 shrink-0" />
          <p class="text-xs font-semibold text-foreground uppercase tracking-wide">What to look for</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-1">
          {criteria.map(([label, desc]) => (
            <div class="flex gap-2 py-1.5 border-b border-border/50 last:border-0">
              <p class="text-xs font-medium text-foreground w-32 shrink-0">{label}</p>
              <p class="text-xs text-muted-foreground leading-snug">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <p class="text-sm text-muted-foreground border-t border-border pt-6">
      Any question? <a href="https://discord.gg/Qygt9u26Bn" class="underline hover:text-foreground transition-colors" data-umami-event="discord_cta_click">Ping us on Discord.</a>
    </p>
  </div>
</Layout>
