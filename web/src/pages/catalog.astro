---
import Layout from "@/layouts/main.astro"
import { buttonVariants } from "@/components/ui/button"
import { readFileSync } from "fs"
import { BookIcon } from "@phosphor-icons/react"

const raw = readFileSync(new URL("../../../catalog/guild/guild_items.json", import.meta.url), "utf-8")
const catalogData = JSON.parse(raw) as Record<string, Record<string, { items: { name: string; filename: string; tags: string[]; styles: string[]; hasVariants: boolean; components?: string[]; diagramRef?: string; buyPlace?: string }[] }>>

type Item = { name: string; filename: string; tags: string[]; styles: string[]; hasVariants: boolean; components?: string[]; diagramRef?: string; buyPlace?: string }
type Subcategory = { name: string; items: Item[] }
type Category = { name: string; subcategories: Subcategory[] }

const categories: Category[] = Object.entries(catalogData)
  .filter(([k]) => k !== "translations")
  .map(([catName, catData]) => ({
    name: catName,
    subcategories: Object.entries(catData)
      .filter(([k]) => k !== "translations")
      .map(([subName, subData]) => ({
        name: subName,
        items: subData.items ?? [],
      })),
  }))

function imgPath(category: string, subcategory: string, filename: string) {
  return `/catalog/${encodeURIComponent(category)}/${encodeURIComponent(subcategory)}/${encodeURIComponent(filename)}`
}

function catIconPath(category: string) {
  return `/catalog/${encodeURIComponent(category)}/icon.png`
}

function variantsImgPath(category: string, subcategory: string, filename: string) {
  return imgPath(category, subcategory, filename.replace(".png", "_variants.png"))
}

const catalogJson = JSON.stringify(
  categories.map((cat) => ({
    name: cat.name,
    subcategories: cat.subcategories.map((sub) => ({
      name: sub.name,
      items: sub.items.map((item) => ({
        name: item.name,
        filename: item.filename,
        tags: item.diagramRef ? [...new Set([...(item.tags ?? []), "diagram"])] : (item.tags ?? []),
        styles: item.styles ?? [],
        hasVariants: item.hasVariants ?? false,
        components: (item.components ?? []).map((c) => imgPath(cat.name, sub.name, c)),
        diagramRef: item.diagramRef ?? "",
        buyPlace: item.buyPlace ?? "",
        category: cat.name,
        subCategory: sub.name,
        img: item.filename ? imgPath(cat.name, sub.name, item.filename) : "",
        variantsImg: item.hasVariants && item.filename
          ? variantsImgPath(cat.name, sub.name, item.filename)
          : "",
      })),
    })),
  }))
)
---

<Layout
  title="Catalog — Where Builders Meet"
  description="A catalog of every buildable item in Where Winds Meet."
>
  <div class="max-w-7xl space-y-5">

    <!-- Header -->
    <div class="flex flex-col gap-3">
      <h1 class="font-heading text-2xl font-semibold flex items-center gap-2"><BookIcon weight="duotone" className="size-6 text-primary" /> Catalog</h1>
      <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
        <p class="text-muted-foreground text-sm">Explore Where Winds Meet guild construction items conveniently</p>
        <div class="flex items-center gap-2 text-xs text-muted-foreground/70">
          <button id="alpha-toggle" class="flex items-center gap-1 hover:text-foreground transition-colors">
            <span id="alpha-toggle-label">What's included</span>
            <svg id="alpha-toggle-chevron" class="w-3 h-3 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <span class="text-muted-foreground/40">·</span>
          <a href="https://discord.gg/Qygt9u26Bn" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:text-foreground transition-colors">Share feedback on Discord</a>
        </div>
      </div>
      <ul id="alpha-features" style="display:none" class="grid gap-1.5 sm:grid-cols-2 pl-1 text-xs text-muted-foreground">
        <li class="flex items-start gap-2"><svg class="mt-0.5 w-3.5 h-3.5 shrink-0 text-primary" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="m5 13 4 4L19 7"/></svg>Follows the same category hierarchy as in-game</li>
        <li class="flex items-start gap-2"><svg class="mt-0.5 w-3.5 h-3.5 shrink-0 text-primary" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="m5 13 4 4L19 7"/></svg>Only relevant variants shown for items with multiple appearances</li>
        <li class="flex items-start gap-2"><svg class="mt-0.5 w-3.5 h-3.5 shrink-0 text-primary" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="m5 13 4 4L19 7"/></svg><span><strong class="text-foreground">Tag and style</strong> system for smarter browsing</span></li>
        <li class="flex items-start gap-2"><svg class="mt-0.5 w-3.5 h-3.5 shrink-0 text-primary" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="m5 13 4 4L19 7"/></svg><span><strong class="text-foreground">#diagram and #solo components</strong> integrated in the catalog</span></li>
        <li class="flex items-start gap-2"><svg class="mt-0.5 w-3.5 h-3.5 shrink-0 text-primary" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="m5 13 4 4L19 7"/></svg>Advanced filtering by name, tag, and style</li>
        <li class="flex items-start gap-2"><svg class="mt-0.5 w-3.5 h-3.5 shrink-0 text-primary" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="m5 13 4 4L19 7"/></svg><span><strong class="text-foreground">Shareable links</strong> preserve your current view</span></li>
      </ul>
    </div>

    <script>
      {
        const toggle = document.getElementById("alpha-toggle")!
        const features = document.getElementById("alpha-features")!
        const chevron = document.getElementById("alpha-toggle-chevron")!
        toggle.addEventListener("click", () => {
          const open = features.style.display === "grid"
          features.style.display = open ? "none" : "grid"
          chevron.style.transform = open ? "" : "rotate(180deg)"
        })
      }
    </script>

    <!-- Permalink bar -->
    <div class="flex items-center gap-2 text-xs text-muted-foreground">
      <span class="shrink-0">Share this view:</span>
      <div class="inline-flex items-center gap-1.5 rounded-full border border-border bg-background px-3 py-1 text-xs shadow-sm min-w-0">
        <svg class="w-3 h-3 shrink-0 text-muted-foreground" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
        </svg>
        <span id="share-breadcrumb" class="truncate min-w-0 text-foreground/80 font-medium max-w-xs"></span>
      </div>
      <button
        id="share-btn"
        class={buttonVariants({ variant: "ghost", size: "sm" }) + " h-6 gap-1 px-2 text-xs text-muted-foreground hover:text-foreground"}
      >
        <svg id="share-icon" class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
        </svg>
        <svg id="share-check" class="w-3 h-3 text-green-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="display:none">
          <path d="m5 13 4 4L19 7"/>
        </svg>
        <span id="share-label">Copy link</span>
      </button>
    </div>

    <!-- Search -->
    <div class="flex items-center gap-3">
    <div class="relative max-w-md flex-1" id="search-wrapper">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        id="catalog-search"
        type="search"
        placeholder="Search by name, #tag or @style…"
        autocomplete="off"
        class="w-full rounded-lg border border-border bg-muted/40 pl-9 pr-9 py-2 text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary/50"
      />
      <button
        id="search-clear"
        aria-label="Clear search"
        style="display:none"
        class="absolute right-2.5 top-1/2 -translate-y-1/2 p-0.5 rounded text-muted-foreground hover:text-foreground transition-colors"
      >
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
      <!-- Autocomplete dropdown -->
      <ul
        id="search-suggestions"
        class="absolute z-20 mt-1 w-full rounded-lg border border-border bg-popover shadow-lg overflow-hidden text-sm"
        style="display:none"
      ></ul>
    </div>
    <button
      id="search-clear-btn"
      style="display:none"
      class="shrink-0 text-sm text-muted-foreground hover:text-foreground transition-colors"
    >Clear</button>
    </div>

    <!-- Quick filters -->
    <div id="quick-filters" class="space-y-3">
      <div id="tag-pills-row" style="display:none">
        <div id="tag-pills" class="flex flex-wrap gap-x-5 gap-y-2"></div>
      </div>
      <div id="style-pills-row" style="display:none">
        <div class="flex flex-col gap-1">
          <span class="text-[10px] font-semibold uppercase tracking-wider text-muted-foreground/70 px-0.5">Styles</span>
          <div id="style-pills" class="flex flex-wrap gap-1"></div>
        </div>
      </div>
    </div>

    <!-- Category tabs -->
    <div class="flex gap-1 border-b border-border overflow-x-auto scrollbar-none" id="cat-tabs">
      {categories.map((cat, i) => (
        <button
          class:list={[
            "cat-tab flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-t border-b-2 transition-colors shrink-0 whitespace-nowrap cursor-pointer",
            i === 0
              ? "border-primary text-primary"
              : "border-transparent text-muted-foreground hover:text-foreground",
          ]}
          data-cat={cat.name}
        >
          <img src={catIconPath(cat.name)} alt="" class="w-6 h-6 object-contain shrink-0" />
          {cat.name}
        </button>
      ))}
    </div>

    <!-- Subcategory tabs (above two-column layout so detail panel aligns with images) -->
    {categories.map((cat, ci) => (
      <div class="cat-panel" data-cat={cat.name} style={ci !== 0 ? "display:none" : ""}>
        <div class="flex flex-wrap gap-1">
          <button
            class="sub-tab px-3 py-1.5 text-sm rounded-md transition-colors text-muted-foreground hover:text-foreground hover:bg-muted/50 cursor-pointer"
            data-cat={cat.name}
            data-sub="__all__"
          >
            All
            <span class="ml-1 text-xs opacity-60">({cat.subcategories.reduce((n, s) => n + s.items.length, 0)})</span>
          </button>
          {cat.subcategories.map((sub, si) => (
            <button
              class:list={[
                "sub-tab px-3 py-1.5 text-sm rounded-md transition-colors cursor-pointer",
                si === 0
                  ? "bg-primary/15 text-primary ring-1 ring-primary/30"
                  : "text-muted-foreground hover:text-foreground hover:bg-muted/50",
              ]}
              data-cat={cat.name}
              data-sub={sub.name}
            >
              {sub.name}
              <span class="ml-1 text-xs opacity-60">({sub.items.length})</span>
            </button>
          ))}
        </div>
      </div>
    ))}

    <!-- Two-column layout: grid + detail panel -->
    <div class="flex flex-col lg:flex-row gap-5 items-start">

      <!-- Left: grid area -->
      <div class="flex-1 min-w-0 space-y-4">

        <!-- Search results -->
        <div id="search-results" style="display:none" class="space-y-2">
          <p id="search-count" class="text-xs text-muted-foreground"></p>
          <div id="search-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-2"></div>
          <p id="search-empty" style="display:none" class="text-sm text-muted-foreground py-8 text-center">No items match your search.</p>
        </div>

        <!-- Category panels -->
        {categories.map((cat, ci) => (
          <div class="cat-panel space-y-4" data-cat={cat.name} style={ci !== 0 ? "display:none" : ""}>

            <!-- Subcategory panels -->
            {cat.subcategories.map((sub, si) => (
              <div
                class="sub-panel"
                data-cat={cat.name}
                data-sub={sub.name}
                style={si !== 0 ? "display:none" : ""}
              >
                <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-2">
                  {sub.items.map((item) => (
                    <div
                      class="item-card group relative rounded-lg overflow-hidden bg-neutral-900 border border-border hover:border-primary/50 transition-colors cursor-pointer"
                      data-name={item.name.toLowerCase()}
                      data-tags={JSON.stringify(item.tags ?? [])}
                      data-img={item.filename ? imgPath(cat.name, sub.name, item.filename) : ""}
                      data-variants-img={item.hasVariants && item.filename ? variantsImgPath(cat.name, sub.name, item.filename) : ""}
                      data-has-variants={item.hasVariants ? "1" : ""}
                      data-styles={JSON.stringify(item.styles ?? [])}
                      data-components={JSON.stringify((item.components ?? []).map((c) => imgPath(cat.name, sub.name, c)))}
                      data-diagram-ref={item.diagramRef ?? ""}
                      data-category={cat.name}
                      data-subcategory={sub.name}
                      data-buy-place={item.buyPlace ?? ""}
                    >
                      {item.filename ? (
                        <img
                          src={imgPath(cat.name, sub.name, item.filename)}
                          alt={item.name || item.filename}
                          class="w-full aspect-square object-cover block"
                          loading="lazy"
                          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
                        />
                      ) : null}
                      <div
                        class="w-full aspect-square bg-neutral-800 items-center justify-center text-muted-foreground text-xs"
                        style={item.filename ? "display:none" : "display:flex"}
                      >
                        No image
                      </div>

                      <div class="absolute top-1.5 right-1.5 flex flex-col items-end gap-1">
                        {item.hasVariants && (
                          <div class="bg-black/70 rounded px-1.5 py-0.5 flex items-center gap-1">
                            <svg class="w-3 h-3 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                              <rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
                              <line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/>
                            </svg>
                            <span class="text-[10px] text-primary font-medium">variants</span>
                          </div>
                        )}
                        {(item.tags ?? []).includes("solo") && (
                          <div class="bg-black/70 rounded px-1.5 py-0.5 flex items-center gap-1">
                            <svg class="w-3 h-3 text-blue-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                              <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
                            </svg>
                            <span class="text-[10px] text-blue-400 font-medium">solo</span>
                          </div>
                        )}
                      </div>

                      <div class="absolute bottom-0 left-0 right-0 bg-linear-to-t from-black/90 via-black/50 to-transparent px-2 pt-6 pb-2">
                        {item.name ? (
                          <p class="text-white text-xs font-medium leading-tight drop-shadow">{item.name}</p>
                        ) : (
                          <p class="text-white/40 text-xs italic leading-tight">Unnamed</p>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        ))}
      </div>

      <!-- Right: detail panel (bottom sheet on mobile, sidebar on desktop) -->
      <div
        id="detail-panel"
        class="fixed bottom-0 inset-x-0 z-50 translate-y-full transition-transform duration-300 rounded-t-2xl border-t border-x border-border bg-background max-h-[85vh] overflow-y-auto lg:sticky lg:inset-auto lg:z-auto lg:w-80 lg:shrink-0 lg:top-20 lg:self-start lg:translate-y-0 lg:transition-none lg:rounded-none lg:border-0 lg:bg-transparent lg:max-h-none lg:overflow-visible"
      >
        <!-- Mobile drag handle + close -->
        <div class="lg:hidden">
          <div class="flex justify-center pt-2 pb-1">
            <div class="w-8 h-1 rounded-full bg-muted-foreground/30"></div>
          </div>
          <div class="flex items-center justify-between px-4 pb-2">
            <span class="text-sm font-medium">Item details</span>
            <button id="detail-close" class="p-1 rounded-md text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6 6 18M6 6l12 12"/></svg>
            </button>
          </div>
        </div>

        <!-- Empty state -->
        <div id="detail-empty" class="rounded-xl border border-dashed border-border p-6 text-center text-sm text-muted-foreground hidden lg:block">
          Click an item to see details
        </div>

        <!-- Populated state -->
        <div id="detail-content" style="display:none" class="rounded-xl border border-border overflow-hidden">
          <div class="bg-neutral-900">
            <img id="detail-img" src="" alt="" class="w-full object-contain max-h-48" />
          </div>
          <div class="p-4 space-y-3">
            <div>
              <h3 id="detail-name" class="font-semibold text-sm leading-snug"></h3>
              <p id="detail-location" class="text-xs text-muted-foreground mt-0.5"></p>
              <p id="detail-position" class="text-[10px] text-muted-foreground/50 mt-0.5"></p>
            </div>

            <div id="detail-tags-section" style="display:none">
              <p class="text-xs text-muted-foreground mb-1.5">Tags</p>
              <div id="detail-tags" class="flex flex-wrap gap-1.5"></div>
            </div>

            <div id="detail-styles-section" style="display:none">
              <p class="text-xs text-muted-foreground mb-1.5">Styles</p>
              <div id="detail-styles" class="flex flex-wrap gap-1.5"></div>
            </div>

            <div id="detail-solo-section" style="display:none" class="rounded-lg bg-muted/50 border border-border px-3 py-2.5 flex items-start gap-2">
              <svg class="w-3.5 h-3.5 text-blue-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
              </svg>
              <div class="min-w-0">
                <p class="text-xs font-medium text-foreground">Solo unlock required</p>
                <p id="detail-buy-place" class="text-xs text-muted-foreground mt-0.5 leading-snug"></p>
              </div>
            </div>

            <div id="detail-diagram-ref-section" style="display:none">
              <p class="text-xs text-muted-foreground mb-2">Part of: <span id="detail-diagram-ref-name" class="text-foreground font-medium"></span></p>
              <img id="detail-diagram-ref-img" src="" alt="" class="w-full object-cover rounded-lg max-h-40" />
              <p class="text-xs text-muted-foreground mt-1">Thanks to <span class="text-foreground">izanagi</span> for the screenshot</p>
            </div>

            <div id="detail-variants-section" style="display:none">
              <p class="text-xs text-muted-foreground mb-2">Variants</p>
              <div class="bg-neutral-900 rounded-lg overflow-hidden cursor-zoom-in" id="detail-variants-thumb">
                <img id="detail-variants-img" src="" alt="Variants" class="w-full object-contain" />
              </div>
            </div>

            <div id="detail-components-section" style="display:none">
              <p class="text-xs text-muted-foreground mb-2">Components</p>
              <div id="detail-components" class="grid grid-cols-2 gap-1.5"></div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Mobile detail backdrop -->
  <div id="detail-backdrop" class="fixed inset-0 z-40 bg-black/50 backdrop-blur-sm lg:hidden" style="display:none"></div>

  <!-- Variants / component lightbox -->
  <div
    id="variants-lightbox"
    class="fixed inset-0 z-50 bg-black/80 backdrop-blur-sm flex flex-col items-center justify-center gap-3 p-4 cursor-zoom-out"
    style="display:none"
  >
    <img id="lightbox-img" src="" alt="Variants" class="max-w-full max-h-[80vh] object-contain rounded-lg shadow-2xl" />
    <div id="lightbox-caption" class="text-center" style="display:none">
      <p id="lightbox-component-name" class="text-sm font-medium text-white capitalize"></p>
      <p id="lightbox-master-name" class="text-xs text-white/60 mt-0.5"></p>
      <p id="lightbox-diagram-credit" class="text-xs text-white/40 mt-0.5" style="display:none">Thanks to <span class="text-white/60">izanagi</span> for the diagram</p>
    </div>
  </div>
</Layout>

<style>
  .cat-tab img {
    filter: brightness(0) opacity(0.6);
    transition: filter 0.2s ease;
  }
  .cat-tab.border-primary img {
    filter: brightness(0) saturate(100%) invert(60%) sepia(80%) saturate(600%) hue-rotate(340deg) drop-shadow(0 0 2px rgba(255, 120, 20, 0.35));
    opacity: 1;
  }
</style>

<script is:inline type="application/json" id="catalog-data" set:html={catalogJson} />

<script>
  // ── types & data ─────────────────────────────────────────────────────────────

  type CatalogItem = { name: string; filename: string; tags: string[]; styles: string[]; hasVariants: boolean; components: string[]; diagramRef: string; buyPlace: string; category: string; subCategory: string; img: string; variantsImg: string }
  type CatalogSub  = { name: string; items: CatalogItem[] }
  type CatalogCat  = { name: string; subcategories: CatalogSub[] }

  const catalog: CatalogCat[] = JSON.parse(
    document.getElementById("catalog-data")!.textContent!
  )

  function hashStr(s: string): number {
    let h = 5381
    for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) & 0xffffff
    return Math.abs(h)
  }

  const tagColors: Record<string, string> = {
    bath:              "hsl(190,60%,30%)",
    bed:               "hsl(270,40%,36%)",
    carpet:            "hsl(340,50%,33%)",
    chair:             "hsl(28,52%,30%)",
    diagram:           "hsl(215,60%,33%)",
    door:              "hsl(24,52%,28%)",
    floor:             "hsl(30,20%,32%)",
    frame:             "hsl(0,0%,36%)",
    gate:              "hsl(200,28%,30%)",
    guardrail:         "hsl(44,58%,30%)",
    interactive:       "hsl(140,52%,26%)",
    lamp:              "hsl(38,75%,30%)",
    "large component": "hsl(0,0%,26%)",
    plant:             "hsl(118,48%,26%)",
    roof:              "hsl(14,58%,33%)",
    stairs:            "hsl(238,14%,38%)",
    statue:            "hsl(38,28%,38%)",
    table:             "hsl(28,48%,30%)",
    variants:          "hsl(278,46%,36%)",
    wall:              "hsl(210,14%,36%)",
    window:            "hsl(200,58%,30%)",
  }

  const styleColors: Record<string, string> = {
    red:    "hsl(0,80%,38%)",
    snow:   "hsl(202,48%,33%)",
    stone:  "hsl(28,12%,36%)",
    wood:   "hsl(26,58%,28%)",
    desert: "hsl(38,55%,35%)",
  }

  function tagStyle(tag: string): string {
    const bg = tagColors[tag] ?? `hsl(${hashStr(tag) % 360},50%,35%)`
    return `background-color:${bg};color:#fff`
  }

  function styleBg(style: string): string {
    return styleColors[style] ?? `hsl(${hashStr(style) % 360},50%,35%)`
  }

  // ── detail panel ─────────────────────────────────────────────────────────────

  const detailPanel       = document.getElementById("detail-panel") as HTMLDivElement
  const detailBackdrop    = document.getElementById("detail-backdrop") as HTMLDivElement

  function isMobile() { return window.innerWidth < 1024 }

  function openMobileSheet() {
    detailPanel.classList.remove("translate-y-full")
    detailPanel.classList.add("translate-y-0")
    detailBackdrop.style.display = ""
    document.body.style.overflow = "hidden"
  }

  function closeMobileSheet() {
    detailPanel.classList.add("translate-y-full")
    detailPanel.classList.remove("translate-y-0")
    detailBackdrop.style.display = "none"
    document.body.style.overflow = ""
  }

  document.getElementById("detail-close")?.addEventListener("click", closeMobileSheet)
  detailBackdrop.addEventListener("click", closeMobileSheet)

  const detailEmpty       = document.getElementById("detail-empty") as HTMLDivElement
  const detailContent     = document.getElementById("detail-content") as HTMLDivElement
  const detailImg         = document.getElementById("detail-img") as HTMLImageElement
  const detailName        = document.getElementById("detail-name") as HTMLElement
  const detailLocation    = document.getElementById("detail-location") as HTMLElement
  const detailPosition    = document.getElementById("detail-position") as HTMLElement
  const detailTagsSection    = document.getElementById("detail-tags-section") as HTMLDivElement
  const detailTags           = document.getElementById("detail-tags") as HTMLDivElement
  const detailStylesSection  = document.getElementById("detail-styles-section") as HTMLDivElement
  const detailStyles         = document.getElementById("detail-styles") as HTMLDivElement
  const detailDiagramRefSection = document.getElementById("detail-diagram-ref-section") as HTMLDivElement
  const detailDiagramRefImg     = document.getElementById("detail-diagram-ref-img") as HTMLImageElement
  const detailDiagramRefName    = document.getElementById("detail-diagram-ref-name") as HTMLSpanElement
  const detailVariants          = document.getElementById("detail-variants-section") as HTMLDivElement
  const detailVariantsImg       = document.getElementById("detail-variants-img") as HTMLImageElement
  const detailComponentsSection = document.getElementById("detail-components-section") as HTMLDivElement
  const detailComponents        = document.getElementById("detail-components") as HTMLDivElement
  const detailSoloSection       = document.getElementById("detail-solo-section") as HTMLDivElement
  const detailBuyPlace          = document.getElementById("detail-buy-place") as HTMLElement

  function showDetail(item: { name: string; img: string; tags: string[]; styles: string[]; hasVariants: boolean; variantsImg: string; components: string[]; diagramRef: string; buyPlace: string; category: string; subCategory: string }) {
    detailName.textContent = item.name || "Unnamed"
    detailLocation.textContent = item.category && item.subCategory ? `${item.category} › ${item.subCategory}` : ""
    const filenameFromImg = item.img ? decodeURIComponent(item.img.split("/").pop() ?? "") : ""
    const posMatch = filenameFromImg.match(/_(\d+)_(\d+)\.png$/)
    detailPosition.textContent = posMatch ? `row ${posMatch[1]}, col ${posMatch[2]}` : ""

    detailImg.src = item.img
    detailImg.alt = item.name
    detailImg.style.display = item.img ? "" : "none"

    detailTags.innerHTML = ""
    if (item.tags.length > 0) {
      detailTagsSection.style.display = ""
      item.tags.forEach((tag) => {
        const badge = document.createElement("button")
        badge.className = "inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md text-xs font-medium cursor-pointer bg-muted/60 border border-border text-foreground hover:bg-muted transition-colors"

        const dot = document.createElement("span")
        dot.className = "w-2 h-2 rounded-full shrink-0"
        dot.style.backgroundColor = tagColors[tag] ?? `hsl(${hashStr(tag) % 360},50%,35%)`
        badge.appendChild(dot)

        badge.appendChild(document.createTextNode(`#${tag}`))
        badge.addEventListener("click", () => {
          if (isMobile()) closeMobileSheet()
          pillClickHandler("#", tag)
        })
        detailTags.appendChild(badge)
      })
    } else {
      detailTagsSection.style.display = "none"
    }

    detailStyles.innerHTML = ""
    if (item.styles.length > 0) {
      detailStylesSection.style.display = ""
      item.styles.forEach((style) => {
        const badge = document.createElement("button")
        badge.className = "inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium cursor-pointer hover:opacity-80 transition-opacity"
        badge.setAttribute("style", `background-color:${styleBg(style)};color:#fff`)
        badge.textContent = style
        badge.addEventListener("click", () => {
          if (isMobile()) closeMobileSheet()
          pillClickHandler("@", style)
        })
        detailStyles.appendChild(badge)
      })
    } else {
      detailStylesSection.style.display = "none"
    }

    if (item.tags.includes("solo") && item.buyPlace) {
      detailBuyPlace.textContent = `Unlock at: ${item.buyPlace}`
      detailSoloSection.style.display = ""
    } else {
      detailSoloSection.style.display = "none"
    }

    if (item.diagramRef) {
      const master = catalog.flatMap((c) => c.subcategories.flatMap((s) => s.items)).find((i) => i.name === item.diagramRef)
      detailDiagramRefName.textContent = item.diagramRef
      detailDiagramRefImg.src = master?.img ?? ""
      detailDiagramRefImg.alt = item.diagramRef
      detailDiagramRefImg.style.display = master?.img ? "" : "none"
      detailDiagramRefSection.style.display = ""
    } else {
      detailDiagramRefSection.style.display = "none"
    }

    if (item.hasVariants && item.variantsImg) {
      detailVariantsImg.src = item.variantsImg
      detailVariants.style.display = ""
    } else {
      detailVariants.style.display = "none"
    }

    detailComponents.innerHTML = ""
    if (item.components.length > 0) {
      detailComponentsSection.style.display = ""
      item.components.forEach((src) => {
        const file = src.split("/").pop() ?? ""
        const label = file.replace(/\.[^.]+$/, "").split("_").pop() ?? file

        const wrap = document.createElement("div")
        wrap.className = "relative bg-neutral-900 rounded overflow-hidden cursor-zoom-in"
        wrap.addEventListener("click", () => openLightbox(src, label, item.name || undefined))

        const img = document.createElement("img")
        img.src = src
        img.alt = label
        img.className = "w-full object-contain"
        img.loading = "lazy"
        wrap.appendChild(img)

        const nameEl = document.createElement("p")
        nameEl.className = "absolute bottom-0 left-0 right-0 px-1.5 py-1 text-[10px] font-medium text-white text-center bg-black/60 capitalize leading-tight"
        nameEl.textContent = label
        wrap.appendChild(nameEl)

        detailComponents.appendChild(wrap)
      })
    } else {
      detailComponentsSection.style.display = "none"
    }

    detailEmpty.style.display = "none"
    detailContent.style.display = ""

    if (isMobile()) openMobileSheet()
  }

  // ── card click ───────────────────────────────────────────────────────────────

  function attachCardClick(card: HTMLElement) {
    card.addEventListener("click", () => {
      // Highlight selected card
      document.querySelectorAll<HTMLElement>(".item-card").forEach((c) => {
        c.classList.toggle("ring-2", c === card)
        c.classList.toggle("ring-primary", c === card)
      })
      const itemName = card.querySelector<HTMLElement>("p")?.textContent?.trim() ?? ""
      ;(window as any).umami?.track("catalog_item_click", { name: itemName, category: card.dataset.category ?? "" })
      showDetail({
        name:        itemName,
        img:         card.dataset.img ?? "",
        tags:        JSON.parse(card.dataset.tags ?? "[]"),
        styles:      JSON.parse(card.dataset.styles ?? "[]"),
        hasVariants: card.dataset.hasVariants === "1",
        variantsImg: card.dataset.variantsImg ?? "",
        components:  JSON.parse(card.dataset.components ?? "[]"),
        diagramRef:  card.dataset.diagramRef ?? "",
        buyPlace:    card.dataset.buyPlace ?? "",
        category:    card.dataset.category ?? "",
        subCategory: card.dataset.subcategory ?? "",
      })
    })
  }

  document.querySelectorAll<HTMLElement>(".item-card").forEach(attachCardClick)

  // ── tab switching ────────────────────────────────────────────────────────────

  const catTabs   = document.querySelectorAll<HTMLButtonElement>(".cat-tab")
  const catPanels = document.querySelectorAll<HTMLDivElement>(".cat-panel")
  const subTabs   = document.querySelectorAll<HTMLButtonElement>(".sub-tab")
  const subPanels = document.querySelectorAll<HTMLDivElement>(".sub-panel")

  let activeCat = catTabs[0]?.dataset.cat ?? ""

  const activeSubByCat: Record<string, string> = {}
  catalog.forEach((cat) => {
    if (cat.subcategories.length > 0) activeSubByCat[cat.name] = cat.subcategories[0].name
  })

  const shareBreadcrumb = document.getElementById("share-breadcrumb") as HTMLElement

  function syncUrl() {
    const p = new URLSearchParams()
    const raw = searchInput.value.trim()
    const isPrefixOnly = raw === "#" || raw === "@"
    const q = isPrefixOnly ? "" : raw
    if (q) {
      p.set("q", q)
      shareBreadcrumb.textContent = q
    } else {
      if (activeCat) p.set("cat", activeCat)
      const sub = activeSubByCat[activeCat]
      if (sub) p.set("sub", sub)
      shareBreadcrumb.textContent = sub && sub !== "__all__"
        ? `${activeCat} › ${sub}`
        : activeCat || "All"
    }
    const qs = p.toString()
    history.replaceState(null, "", qs ? `?${qs}` : location.pathname)
  }

  // ── share button ─────────────────────────────────────────────────────────────

  const shareBtn   = document.getElementById("share-btn") as HTMLButtonElement
  const shareIcon  = document.getElementById("share-icon") as HTMLElement
  const shareCheck = document.getElementById("share-check") as HTMLElement
  const shareLabel = document.getElementById("share-label") as HTMLSpanElement
  let shareResetTimer: ReturnType<typeof setTimeout> | null = null

  shareBtn.addEventListener("click", () => {
    navigator.clipboard.writeText(location.href).then(() => {
      ;(window as any).umami?.track("share_url_copied", { type: "catalog" })
      shareIcon.style.display = "none"
      shareCheck.style.display = ""
      shareLabel.textContent = "Copied!"
      if (shareResetTimer) clearTimeout(shareResetTimer)
      shareResetTimer = setTimeout(() => {
        shareIcon.style.display = ""
        shareCheck.style.display = "none"
        shareLabel.textContent = "Copy"
      }, 2000)
    })
  })

  catTabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      activeCat = tab.dataset.cat!
      ;(window as any).umami?.track("catalog_category_click", { category: activeCat })
      catTabs.forEach((t) => {
        const on = t.dataset.cat === activeCat
        t.classList.toggle("border-primary", on)
        t.classList.toggle("text-primary", on)
        t.classList.toggle("border-transparent", !on)
        t.classList.toggle("text-muted-foreground", !on)
      })
      catPanels.forEach((p) => {
        p.style.display = p.dataset.cat === activeCat ? "" : "none"
      })
      runSearch((document.getElementById("catalog-search") as HTMLInputElement).value)
      syncUrl()
    })
  })

  subTabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const cat = tab.dataset.cat!
      const sub = tab.dataset.sub!
      subTabs.forEach((t) => {
        if (t.dataset.cat !== cat) return
        const on = t.dataset.sub === sub
        t.classList.toggle("bg-primary/15", on)
        t.classList.toggle("text-primary", on)
        t.classList.toggle("ring-1", on)
        t.classList.toggle("ring-primary/30", on)
        t.classList.toggle("text-muted-foreground", !on)
        t.classList.toggle("hover:text-foreground", !on)
        t.classList.toggle("hover:bg-muted/50", !on)
      })
      subPanels.forEach((p) => {
        if (p.dataset.cat !== cat) return
        p.style.display = (sub === "__all__" || p.dataset.sub === sub) ? "" : "none"
      })
      activeSubByCat[cat] = sub
      syncUrl()
    })
  })

  // ── search ───────────────────────────────────────────────────────────────────

  const searchInput       = document.getElementById("catalog-search") as HTMLInputElement
  const searchClear       = document.getElementById("search-clear") as HTMLButtonElement
  const searchClearBtn    = document.getElementById("search-clear-btn") as HTMLButtonElement
  const searchResults     = document.getElementById("search-results") as HTMLDivElement
  const searchGrid        = document.getElementById("search-grid") as HTMLDivElement
  const searchCount       = document.getElementById("search-count") as HTMLParagraphElement
  const searchEmpty       = document.getElementById("search-empty") as HTMLParagraphElement
  const searchSuggestions = document.getElementById("search-suggestions") as HTMLUListElement
  const catTabsEl         = document.getElementById("cat-tabs") as HTMLDivElement

  function setSearchActive(active: boolean) {
    searchClear.style.display = active ? "" : "none"
    searchClearBtn.style.display = active ? "" : "none"
    catTabsEl.classList.toggle("opacity-40", active)
    catTabsEl.classList.toggle("pointer-events-none", active)
  }

  // Build flat lists of all unique tags and styles across the whole catalog
  const allTags: string[] = [...new Set(
    catalog.flatMap((cat) => cat.subcategories.flatMap((sub) => sub.items.flatMap((item) => item.tags)))
  )].filter(Boolean).sort()

  const allStyles: string[] = [...new Set(
    catalog.flatMap((cat) => cat.subcategories.flatMap((sub) => sub.items.flatMap((item) => item.styles)))
  )].filter(Boolean).sort()

  // ── quick filter pills ───────────────────────────────────────────────────────

  const tagPillsRow  = document.getElementById("tag-pills-row") as HTMLDivElement
  const stylePillsRow = document.getElementById("style-pills-row") as HTMLDivElement
  const tagPillsEl   = document.getElementById("tag-pills") as HTMLDivElement
  const stylePillsEl = document.getElementById("style-pills") as HTMLDivElement

  function updatePillActiveStates() {
    const raw     = searchInput.value.trim()
    const isTag   = raw.startsWith("#")
    const isStyle = raw.startsWith("@")
    const q       = raw.slice(isTag || isStyle ? 1 : 0).trim()
    const activeTag   = isTag   && q ? q : null
    const activeStyle = isStyle && q ? q : null
    const dim = raw.length > 0

    tagPillsEl.querySelectorAll<HTMLButtonElement>("button[data-value]").forEach((btn) => {
      const on = activeTag === btn.dataset.value
      btn.classList.toggle("ring-2", on)
      btn.classList.toggle("ring-primary/70", on)
      btn.classList.toggle("opacity-40", dim && !on)
    })
    stylePillsEl.querySelectorAll<HTMLButtonElement>("button[data-value]").forEach((btn) => {
      const on = activeStyle === btn.dataset.value
      btn.classList.toggle("ring-2", on)
      btn.classList.toggle("ring-white/60", on)
      btn.classList.toggle("opacity-40", dim && !on)
    })
  }

  function pillClickHandler(prefix: "#" | "@", value: string) {
    const target = `${prefix}${value}`
    const isSame = searchInput.value.trim() === target
    const newVal = isSame ? "" : target
    searchInput.value = newVal
    hideSuggestions()
    runSearch(newVal)
    syncUrl()
    updatePillActiveStates()
  }

  const recommendedTags = new Set(["chair", "table", "must-try", "stairs", "diagram", "food/drink", "interactive"])

  // Group order: structural → furniture → misc. Tags not listed fall into a final group.
  const tagGroupDefs: { label: string; tags: string[] }[] = [
    { label: "Structure",   tags: ["wall", "floor", "ceiling", "roof", "stairs", "guardrail", "door/gate", "window/frame", "railing"] },
    { label: "Accessories", tags: ["interactive", "statue", "lamp", "plant"] },
    { label: "Furniture",   tags: ["bed", "carpet", "chair", "table", "bath"] },
  ]
  const tagGroupIndex: Record<string, number> = {}
  const tagPositionInGroup: Record<string, number> = {}
  tagGroupDefs.forEach(({ tags }, gi) => {
    tags.forEach((tag, ti) => {
      tagGroupIndex[tag] = gi
      tagPositionInGroup[tag] = ti
    })
  })

  if (allTags.length > 0) {
    tagPillsRow.style.display = ""

    // Bucket tags into groups
    const buckets: string[][] = tagGroupDefs.map(() => [])
    const overflow: string[] = []
    allTags.forEach((tag) => {
      const gi = tagGroupIndex[tag]
      if (gi !== undefined) buckets[gi].push(tag)
      else overflow.push(tag)
    })
    buckets.forEach((b) => b.sort((a, b) => {
      const aRec = recommendedTags.has(a) ? 0 : 1
      const bRec = recommendedTags.has(b) ? 0 : 1
      if (aRec !== bRec) return aRec - bRec
      return (tagPositionInGroup[a] ?? 999) - (tagPositionInGroup[b] ?? 999)
    }))
    overflow.sort((a, b) => a.localeCompare(b))

    const groupsToRender = [
      ...tagGroupDefs.map((def, gi) => ({ label: def.label, tags: buckets[gi] })),
      ...(overflow.length > 0 ? [{ label: "Other", tags: overflow }] : []),
    ].filter((g) => g.tags.length > 0)

    groupsToRender.forEach(({ label, tags }) => {
      const col = document.createElement("div")
      col.className = "flex flex-col gap-1"

      const heading = document.createElement("span")
      heading.className = "text-[10px] font-semibold uppercase tracking-wider text-muted-foreground/70 px-0.5"
      heading.textContent = label
      col.appendChild(heading)

      const pills = document.createElement("div")
      pills.className = "flex flex-wrap gap-1"
      col.appendChild(pills)

      tags.forEach((tag) => {
        const btn = document.createElement("button")
        const isRec = recommendedTags.has(tag)
        btn.className = isRec
          ? "inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md text-xs font-medium transition-opacity cursor-pointer bg-muted/60 border border-yellow-400/60 text-foreground hover:bg-muted hover:border-yellow-400"
          : "inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md text-xs font-medium transition-opacity cursor-pointer bg-muted/60 border border-border text-foreground hover:bg-muted"
        btn.dataset.value = tag

        if (isRec) {
          const star = document.createElementNS("http://www.w3.org/2000/svg", "svg")
          star.setAttribute("class", "w-3 h-3 shrink-0 text-yellow-400")
          star.setAttribute("fill", "currentColor")
          star.setAttribute("viewBox", "0 0 24 24")
          const path = document.createElementNS("http://www.w3.org/2000/svg", "path")
          path.setAttribute("d", "M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z")
          star.appendChild(path)
          btn.appendChild(star)
        } else {
          const dot = document.createElement("span")
          dot.className = "w-2 h-2 rounded-full shrink-0"
          dot.style.backgroundColor = tagColors[tag] ?? `hsl(${hashStr(tag) % 360},50%,35%)`
          btn.appendChild(dot)
        }

        btn.appendChild(document.createTextNode(`#${tag}`))
        btn.addEventListener("click", () => pillClickHandler("#", tag))
        pills.appendChild(btn)
      })

      tagPillsEl.appendChild(col)
    })
  }

  if (allStyles.length > 0) {
    stylePillsRow.style.display = ""
    allStyles.forEach((style) => {
      const btn = document.createElement("button")
      btn.className = "inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium transition-opacity cursor-pointer"
      btn.setAttribute("style", `background-color:${styleBg(style)};color:#fff`)
      btn.dataset.value = style
      btn.textContent = `@${style}`
      btn.addEventListener("click", () => pillClickHandler("@", style))
      stylePillsEl.appendChild(btn)
    })
  }

  let activeSuggestionIdx = -1

  function hideSuggestions() {
    searchSuggestions.style.display = "none"
    searchSuggestions.innerHTML = ""
    activeSuggestionIdx = -1
  }

  function showSuggestions(items: { label: string; value: string; isTag: boolean; isStyle?: boolean }[]) {
    if (items.length === 0) { hideSuggestions(); return }
    searchSuggestions.innerHTML = ""
    activeSuggestionIdx = -1
    items.forEach((s) => {
      const li = document.createElement("li")
      li.className = "flex items-center gap-2 px-3 py-2 cursor-pointer hover:bg-muted/60 transition-colors"
      if (s.isStyle) {
        li.innerHTML = `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium" style="background-color:${styleBg(s.label)};color:#fff">@${s.label}</span>`
      } else if (s.isTag) {
        li.innerHTML = `<span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md text-xs font-medium bg-muted/60 border border-border text-foreground"><span class="w-2 h-2 rounded-full shrink-0" style="background-color:${tagColors[s.label] ?? `hsl(${hashStr(s.label) % 360},50%,35%)`}"></span>#${s.label}</span>`
      } else {
        li.innerHTML = `<span class="text-sm">${s.label}</span>`
      }
      li.addEventListener("mousedown", (e) => {
        e.preventDefault()
        searchInput.value = s.value
        hideSuggestions()
        runSearch(s.value)
        syncUrl()
      })
      searchSuggestions.appendChild(li)
    })
    searchSuggestions.style.display = ""
  }

  const deaccent = (s: string) => s.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase()

  function updateSuggestions(raw: string) {
    const isTag   = raw.startsWith("#")
    const isStyle = raw.startsWith("@")
    const q = deaccent(raw.slice(isTag || isStyle ? 1 : 0).trim())

    if (!q && !isTag && !isStyle) { hideSuggestions(); return }

    if (isStyle) {
      const matches = (q ? allStyles.filter((s) => deaccent(s).includes(q)) : allStyles)
        .slice(0, 12)
        .map((s) => ({ label: s, value: `@${s}`, isTag: false, isStyle: true }))
      showSuggestions(matches)
    } else if (isTag) {
      const matches = (q ? allTags.filter((t) => deaccent(t).includes(q)) : allTags)
        .slice(0, 12)
        .map((t) => ({ label: t, value: `#${t}`, isTag: true }))
      showSuggestions(matches)
    } else {
      const seen = new Set<string>()
      const matches: { label: string; value: string; isTag: boolean }[] = []
      catalog.forEach((cat) => {
        cat.subcategories.forEach((sub) => {
          sub.items.forEach((item) => {
            if (item.name && deaccent(item.name).includes(q) && !seen.has(item.name)) {
              seen.add(item.name)
              matches.push({ label: item.name, value: item.name, isTag: false })
            }
          })
        })
      })
      showSuggestions(matches.slice(0, 8))
    }
  }

  function buildCard(item: CatalogItem): HTMLElement {
    const card = document.createElement("div")
    card.className =
      "item-card group relative rounded-lg overflow-hidden bg-neutral-900 border border-border hover:border-primary/50 transition-colors cursor-pointer"
    card.dataset.img         = item.img
    card.dataset.tags        = JSON.stringify(item.tags)
    card.dataset.styles      = JSON.stringify(item.styles)
    card.dataset.hasVariants = item.hasVariants ? "1" : ""
    card.dataset.variantsImg = item.variantsImg
    card.dataset.components  = JSON.stringify(item.components ?? [])
    card.dataset.diagramRef  = item.diagramRef ?? ""
    card.dataset.buyPlace    = item.buyPlace ?? ""
    card.dataset.category    = item.category
    card.dataset.subcategory = item.subCategory

    if (item.img) {
      const img = document.createElement("img")
      img.src = item.img
      img.alt = item.name || item.filename
      img.className = "w-full aspect-square object-cover block"
      img.loading = "lazy"
      img.onerror = () => {
        img.style.display = "none"
        placeholder.style.display = "flex"
      }
      card.appendChild(img)
    }

    const placeholder = document.createElement("div")
    placeholder.className =
      "w-full aspect-square bg-neutral-800 items-center justify-center text-muted-foreground text-xs"
    placeholder.style.display = item.img ? "none" : "flex"
    placeholder.textContent = "No image"
    card.appendChild(placeholder)

    if (item.hasVariants || item.tags.includes("solo")) {
      const stack = document.createElement("div")
      stack.className = "absolute top-1.5 right-1.5 flex flex-col items-end gap-1"

      if (item.hasVariants) {
        const badge = document.createElement("div")
        badge.className = "bg-black/70 rounded px-1.5 py-0.5 flex items-center gap-1"
        badge.innerHTML = `<svg class="w-3 h-3 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg><span class="text-[10px] text-primary font-medium">variants</span>`
        stack.appendChild(badge)
      }

      if (item.tags.includes("solo")) {
        const soloBadge = document.createElement("div")
        soloBadge.className = "bg-black/70 rounded px-1.5 py-0.5 flex items-center gap-1"
        soloBadge.innerHTML = `<svg class="w-3 h-3 text-blue-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg><span class="text-[10px] text-blue-400 font-medium">solo</span>`
        stack.appendChild(soloBadge)
      }

      card.appendChild(stack)
    }

    const overlay = document.createElement("div")
    overlay.className =
      "absolute bottom-0 left-0 right-0 bg-linear-to-t from-black/90 via-black/50 to-transparent px-2 pt-6 pb-2"

    const nameEl = document.createElement("p")
    nameEl.className = item.name
      ? "text-white text-xs font-medium leading-tight drop-shadow"
      : "text-white/40 text-xs italic leading-tight"
    nameEl.textContent = item.name || "Unnamed"
    overlay.appendChild(nameEl)
    card.appendChild(overlay)

    attachCardClick(card)
    return card
  }

  function runSearch(query: string) {
    const raw      = query.trim()
    const isTag    = raw.startsWith("#")
    const isStyle  = raw.startsWith("@")
    const q        = deaccent(raw.slice(isTag || isStyle ? 1 : 0).trim())

    if (!q) {
      setSearchActive(false)
      searchResults.style.display = "none"
      catPanels.forEach((p) => {
        p.style.display = p.dataset.cat === activeCat ? "" : "none"
      })
      return
    }

    setSearchActive(true)

    catPanels.forEach((p) => (p.style.display = "none"))
    searchResults.style.display = ""

    const matches: CatalogItem[] = []
    catalog.forEach((cat) => {
      cat.subcategories.forEach((sub) => {
        sub.items.forEach((item) => {
          const hit = isStyle
            ? item.styles.some((s) => deaccent(s).includes(q))
            : isTag
            ? item.tags.some((t) => deaccent(t).includes(q))
            : deaccent(item.name).includes(q) || item.tags.some((t) => deaccent(t).includes(q))
          if (hit) matches.push(item)
        })
      })
    })

    searchGrid.innerHTML = ""
    if (matches.length === 0) {
      searchEmpty.style.display = ""
      searchGrid.style.display = "none"
      searchCount.textContent = ""
    } else {
      searchEmpty.style.display = "none"
      searchGrid.style.display = ""
      searchCount.textContent = `${matches.length} result${matches.length !== 1 ? "s" : ""} across all categories`
      matches.forEach((item) => searchGrid.appendChild(buildCard(item)))
    }
  }

  function doClearSearch() {
    searchInput.value = ""
    hideSuggestions()
    runSearch("")
    syncUrl()
    updatePillActiveStates()
    searchInput.focus()
  }

  searchClear.addEventListener("click", doClearSearch)
  searchClearBtn.addEventListener("click", doClearSearch)

  let catalogSearchTimer: ReturnType<typeof setTimeout> | null = null
  searchInput.addEventListener("input", (e) => {
    const val = (e.target as HTMLInputElement).value
    updateSuggestions(val)
    runSearch(val)
    syncUrl()
    updatePillActiveStates()
    if (catalogSearchTimer) clearTimeout(catalogSearchTimer)
    if (val.trim()) {
      catalogSearchTimer = setTimeout(() => {
        ;(window as any).umami?.track("catalog_search", { query: val.trim() })
      }, 1500)
    }
  })

  searchInput.addEventListener("keydown", (e) => {
    const items = searchSuggestions.querySelectorAll<HTMLLIElement>("li")
    if (!items.length) return
    if (e.key === "ArrowDown") {
      e.preventDefault()
      activeSuggestionIdx = Math.min(activeSuggestionIdx + 1, items.length - 1)
    } else if (e.key === "ArrowUp") {
      e.preventDefault()
      activeSuggestionIdx = Math.max(activeSuggestionIdx - 1, 0)
    } else if (e.key === "Enter" && activeSuggestionIdx >= 0) {
      e.preventDefault()
      items[activeSuggestionIdx].dispatchEvent(new MouseEvent("mousedown"))
      return
    } else if (e.key === "Escape") {
      hideSuggestions()
      return
    } else {
      return
    }
    items.forEach((li, i) => li.classList.toggle("bg-muted/60", i === activeSuggestionIdx))
  })

  searchInput.addEventListener("blur", () => {
    // small delay so mousedown on a suggestion fires first
    setTimeout(hideSuggestions, 150)
  })

  searchInput.addEventListener("focus", () => {
    if (searchInput.value) updateSuggestions(searchInput.value)
  })

  // ── variants / component lightbox ────────────────────────────────────────────

  const lightbox             = document.getElementById("variants-lightbox") as HTMLDivElement
  const lightboxImg          = document.getElementById("lightbox-img") as HTMLImageElement
  const lightboxCaption      = document.getElementById("lightbox-caption") as HTMLDivElement
  const lightboxComponentName = document.getElementById("lightbox-component-name") as HTMLParagraphElement
  const lightboxMasterName   = document.getElementById("lightbox-master-name") as HTMLParagraphElement
  const lightboxDiagramCredit = document.getElementById("lightbox-diagram-credit") as HTMLParagraphElement

  function openLightbox(src: string, componentName?: string, masterName?: string) {
    lightboxImg.src = src
    lightboxImg.alt = componentName ?? ""
    if (componentName || masterName) {
      lightboxComponentName.textContent = componentName ?? ""
      lightboxMasterName.textContent = masterName ? `Part of: ${masterName}` : ""
      lightboxDiagramCredit.style.display = masterName ? "" : "none"
      lightboxCaption.style.display = ""
    } else {
      lightboxCaption.style.display = "none"
    }
    lightbox.style.display = "flex"
  }

  function closeLightbox() {
    lightbox.style.display = "none"
    lightboxImg.src = ""
    lightboxCaption.style.display = "none"
  }

  document.getElementById("detail-variants-thumb")!.addEventListener("click", () => {
    openLightbox(detailVariantsImg.src)
  })

  lightbox.addEventListener("click", closeLightbox)

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeLightbox()
  })

  // ── URL param initialization ──────────────────────────────────────────────────
  ;(function initFromParams() {
    const params = new URLSearchParams(location.search)
    const initQ   = params.get("q")
    const initCat = params.get("cat")
    const initSub = params.get("sub")

    if (initQ) {
      searchInput.value = initQ
      runSearch(initQ)
      updatePillActiveStates()
      return
    }
    if (initCat) {
      const tab = [...catTabs].find((t) => t.dataset.cat === initCat)
      if (tab) tab.click()
    }
    if (initSub) {
      const tab = [...subTabs].find((t) => t.dataset.cat === activeCat && t.dataset.sub === initSub)
      if (tab) tab.click()
    }
  })()

  // ── TODO progress toggle ──────────────────────────────────────────────────────

  const todoToggle  = document.getElementById("todo-toggle") as HTMLButtonElement
  const todoPanel   = document.getElementById("todo-panel") as HTMLDivElement
  const todoChevron = document.getElementById("todo-chevron") as unknown as SVGElement

  todoToggle.addEventListener("click", () => {
    const open = todoPanel.style.display !== "none"
    todoPanel.style.display = open ? "none" : ""
    todoChevron.style.transform = open ? "" : "rotate(180deg)"
  })
</script>
