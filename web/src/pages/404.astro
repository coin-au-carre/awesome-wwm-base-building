---
import Layout from "@/layouts/main.astro"
import { buttonVariants } from "@/components/ui/button"
import { BASE } from "@/lib/url"

const base = BASE
---

<Layout
  title="404 — Page Not Found"
  description="This page doesn't exist."
>
  <div class="max-w-3xl space-y-6">
    <div>
      <h1 class="font-heading text-2xl font-semibold mb-1">🏚️ 404 — Page Not Found</h1>
      <p class="text-muted-foreground text-sm">This page doesn't exist or was moved.</p>
    </div>

    <a href={`${base}/`} class={buttonVariants({ variant: "outline", size: "lg" })}>← Back to Guilds</a>
  </div>
</Layout>
