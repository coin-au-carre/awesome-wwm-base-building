---
import Layout from "@/layouts/main.astro"

const base = import.meta.env.BASE_URL.replace(/\/$/, "")
---

<Layout
  title="404 — Page Not Found"
  description="This page doesn't exist."
>
  <div class="max-w-3xl space-y-6">
    <div>
      <h1 class="font-heading text-2xl font-semibold mb-1">🏚️ 404 — Page Not Found</h1>
      <p class="text-muted-foreground text-sm">This page doesn't exist or was moved.</p>
    </div>

    <a
      href={`${base}/`}
      class="inline-flex items-center gap-1.5 rounded-full border border-border px-4 py-2 text-sm font-medium hover:bg-muted transition-colors"
    >
      ← Back to Guild Bases
    </a>
  </div>
</Layout>
