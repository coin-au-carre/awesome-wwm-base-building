---
import Layout from "@/layouts/main.astro"
import { PatchNotes } from "@/components/PatchNotes"
import type { Patch } from "@/components/PatchNotes"
import { NewspaperIcon } from "@phosphor-icons/react"
import { readFileSync } from "fs"
import { resolve } from "path"

let patches: Patch[] = []
try {
  patches = JSON.parse(readFileSync(resolve(process.cwd(), "..", "data/patches.json"), "utf-8"))
} catch {
  // data/patches.json not yet generated — page renders empty
}

const SHEET_URL =
  "https://docs.google.com/spreadsheets/d/e/2PACX-1vQYRYkRj4HdlI1m7Sl4pfpyINlTW2GvwTtuUZJl2XnN0gbtR_S3OLg--Zk4a0td1NV8mz3ulUO8aU-4/pubhtml?gid=1954115521&single=true"
---

<Layout
  title="Where Builders Meet | Updates"
  description="Building features and mechanics added each version of Where Winds Meet, curated by the community."
>
  <div class="max-w-5xl space-y-6">
    <div class="flex flex-col gap-2">
      <h1 class="font-heading text-2xl font-semibold flex items-center gap-2">
        <NewspaperIcon weight="duotone" className="size-6 text-primary" /> Updates
      </h1>
      <p class="text-muted-foreground text-sm">
        Building features and mechanics added each version, organized by the community from{" "}
        <a
          href={SHEET_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="text-foreground underline underline-offset-2 hover:text-primary transition-colors"
          data-umami-event="patches_sheet_open"
        >
          our shared spreadsheet ↗
        </a>. Know something that's missing or incorrect? Help us on{" "}
        <a
          href="https://discord.gg/Qygt9u26Bn"
          target="_blank"
          rel="noopener noreferrer"
          class="text-foreground underline underline-offset-2 hover:text-primary transition-colors"
          data-umami-event="discord_cta_click"
        >
          Discord ↗
        </a>.
      </p>
    </div>
    <PatchNotes patches={patches} client:load />
  </div>
</Layout>
