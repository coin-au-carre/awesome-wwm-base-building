---
import Layout from "@/layouts/main.astro"
import MediaGallery from "@/components/MediaGallery.astro"
import { getGuildsSortedByScore } from "@/lib/guilds"
import { rankLabel } from "@/lib/slugify"

export async function getStaticPaths() {
  const guilds = getGuildsSortedByScore()
  return guilds.map((g) => ({
    params: { slug: g.slug },
    props: { guild: g },
  }))
}

const { guild: g } = Astro.props
const base = import.meta.env.BASE_URL.replace(/\/$/, "")

/** Render a subset of markdown: bold, bullet lists, blank-line paragraphs. */
function renderMarkdown(text: string): string {
  const bold = (s: string) => s.replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")

  const paragraphs = text.trim().split(/\n{2,}/)
  return paragraphs
    .map((block) => {
      const lines = block.split("\n").map((l) => l.trimEnd())
      const isList = lines.every((l) => /^[-*]\s/.test(l.trim()) || l.trim() === "")
      if (isList) {
        const items = lines
          .filter((l) => /^[-*]\s/.test(l.trim()))
          .map((l) => `<li>${bold(l.trim().replace(/^[-*]\s/, ""))}</li>`)
          .join("")
        return `<ul class="space-y-1.5 list-none">${items}</ul>`
      }
      return `<p>${bold(lines.join("<br>"))}</p>`
    })
    .join("\n")
}
---

<Layout
  title={`${g.name} — Where Builders Meet`}
  description={g.lore?.slice(0, 160) ?? `Guild base showcase for ${g.name} in Where Winds Meet.`}
>
  <div class="max-w-3xl space-y-8">
    <!-- Back -->
    <a
      href={base + "/"}
      class="inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground transition-colors"
    >
      ← All guilds
    </a>

    <!-- Header -->
    <div>
      <h1 class="font-heading text-2xl font-semibold">{g.guildName || g.name}</h1>
      <div class="flex flex-wrap gap-1.5 mt-2">
        {
          g.tags?.map((tag) => (
            <span class="inline-flex items-center rounded-full bg-muted px-2.5 py-0.5 text-xs font-medium text-muted-foreground">
              {tag}
            </span>
          ))
        }
      </div>
    </div>

    <!-- Metadata table -->
    <div class="overflow-x-auto rounded-xl ring-1 ring-border">
      <table class="w-full text-sm">
        <tbody>
          {
            g.id && (
              <tr class="border-b border-border">
                <td class="px-4 py-2.5 text-muted-foreground font-medium w-32">🆔 Guild ID</td>
                <td class="px-4 py-2.5">{g.id}</td>
              </tr>
            )
          }
          <tr class="border-b border-border">
            <td class="px-4 py-2.5 text-muted-foreground font-medium">🔨 Builders</td>
            <td class="px-4 py-2.5">{g.builders?.join(", ") || "—"}</td>
          </tr>
          <tr class="border-b border-border">
            <td class="px-4 py-2.5 text-muted-foreground font-medium">⭐ Score</td>
            <td class="px-4 py-2.5 font-semibold font-mono">{g.score}</td>
          </tr>
          <tr class="border-b border-border">
            <td class="px-4 py-2.5 text-muted-foreground font-medium">🏆 Rank</td>
            <td class="px-4 py-2.5">{rankLabel(g.rank)}</td>
          </tr>
          {
            g.discordThread && (
              <tr>
                <td class="px-4 py-2.5 text-muted-foreground font-medium">💬 Discord</td>
                <td class="px-4 py-2.5">
                  <a
                    href="https://discord.gg/Qygt9u26Bn"
                    class="underline hover:text-foreground transition-colors mr-3"
                  >
                    Join server
                  </a>
                  <a
                    href={g.discordThread}
                    class="underline hover:text-foreground transition-colors"
                  >
                    View thread
                  </a>
                </td>
              </tr>
            )
          }
        </tbody>
      </table>
    </div>

    <!-- Lore -->
    {
      g.lore && (
        <section>
          <h2 class="font-heading text-base font-medium mb-2">📜 Lore</h2>
          <div
            class="text-sm text-muted-foreground leading-relaxed prose-sm space-y-2 [&_strong]:text-foreground [&_strong]:font-medium"
            set:html={renderMarkdown(g.lore)}
          />
        </section>
      )
    }

    <!-- What to Visit -->
    {
      g.whatToVisit && (
        <section>
          <h2 class="font-heading text-base font-medium mb-2">🗺️ What to Visit</h2>
          <div
            class="text-sm leading-relaxed space-y-3 [&_ul]:space-y-1.5 [&_li]:flex [&_li]:gap-2 [&_li]:before:content-['·'] [&_li]:before:text-muted-foreground [&_strong]:font-semibold"
            set:html={renderMarkdown(g.whatToVisit)}
          />
        </section>
      )
    }

    <!-- Media -->
    <section class="space-y-6">
      <h2 class="font-heading text-base font-medium">🎬 Media</h2>
      <MediaGallery screenshots={g.screenshots} videos={g.videos} />
    </section>
  </div>
</Layout>
