---
import Layout from "@/layouts/main.astro"
import MediaGallery from "@/components/MediaGallery.astro"
import { Badge } from "@/components/ui/badge"
import { buttonVariants } from "@/components/ui/button"
import { Card, CardContent } from "@/components/ui/card"
import { getGuildsSortedByScore, formatBuilderName, getUsers, getGuildBuilds } from "@/lib/guilds"
import { getTier } from "@/lib/scoring"
import { stripGuildShowcase } from "@/lib/format"
import { renderMarkdown } from "@/lib/markdown"
import { BASE } from "@/lib/url"
import { BookOpen, MapPin, Images, Layers } from "lucide-react"

export async function getStaticPaths() {
  const guilds = getGuildsSortedByScore()
  return guilds.map((g) => ({
    params: { slug: g.slug },
    props: { guild: g },
  }))
}

const { guild: g } = Astro.props
const base = BASE
const totalGuilds = getGuildsSortedByScore().length
const tier = getTier(g.rank, totalGuilds, g.score)
const AHLYAM_ID = "149790526076354561"
const WINDXP_ID = "721510597958828183"
const enteredByAhlyam = g.posterDiscordId === AHLYAM_ID || g.posterDiscordId === WINDXP_ID
const ogImage = g.coverImage ?? g.screenshots?.[0]

const users = getUsers()
const scoutUser = g.scoutedByDiscordId ? users[g.scoutedByDiscordId] : undefined
const scoutName = scoutUser?.nickname ?? scoutUser?.globalName ?? scoutUser?.username

const siblingBuilds = getGuildBuilds(g.name).filter((b) => b.slug !== g.slug)

const guildDisplayName = stripGuildShowcase(g.guildName || g.name)
const buildersStr = g.builders?.map(formatBuilderName).filter(Boolean).join(", ")
const tagsStr = g.tags?.slice(0, 3).join(", ")
const fallbackDesc = [
  buildersStr ? `Built by ${buildersStr}` : guildDisplayName,
  tagsStr ? ` (${tagsStr})` : "",
  ". Community-voted guild base showcase.",
].join("")
const pageDesc = g.lore ? g.lore.slice(0, 160) : fallbackDesc
const schemaKeywords = ["Where Winds Meet", "guild base", "construction", "base building", ...(g.tags ?? [])].join(", ")
---

<Layout
  title={`${g.name} - A Where Winds Meet guild base`}
  description={pageDesc}
  image={ogImage}
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      headline: `${g.name} — Guild Base`,
      description: pageDesc,
      image: [
        ...(g.coverImage ? [g.coverImage] : []),
        ...((g.screenshots ?? []).filter((s: string) => s !== g.coverImage)),
      ].filter(Boolean),
      datePublished: g.createdAt ?? g.lastModified ?? "2025-01-01",
      dateModified: g.lastModified ?? g.createdAt ?? "2025-01-01",
      url: Astro.url.href,
      keywords: schemaKeywords,
      author: g.builders?.map((name: string) => ({ "@type": "Person", name })) ?? [],
      publisher: { "@type": "Organization", name: "Where Builders Meet", url: "https://www.wherebuildersmeet.com" },
      about: { "@type": "VideoGame", name: "Where Winds Meet" },
    })}
  />
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Where Builders Meet", item: "https://www.wherebuildersmeet.com" },
        { "@type": "ListItem", position: 2, name: "Guild Bases", item: Astro.url.origin },
        { "@type": "ListItem", position: 3, name: g.name, item: Astro.url.href },
      ],
    })}
  />

  <div class="space-y-5">
    <!-- Back -->
    <a
      href={base + "/"}
      class="inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground transition-colors"
    >
      ← All Where Winds Meet guild bases
    </a>

    <!-- Hero -->
    {ogImage ? (
      <div class="relative rounded-2xl overflow-hidden">
        <div class="aspect-16/8 sm:aspect-16/6">
          <img src={ogImage} alt={stripGuildShowcase(g.guildName || g.name)} class="w-full h-full object-cover" />
        </div>
        <div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/20 to-transparent" />
        <div class="absolute bottom-0 left-0 right-0 p-5 sm:p-7">
          <div class="flex items-end justify-between gap-4">
            <div>
              <h1 class="font-heading text-3xl sm:text-4xl font-bold text-white drop-shadow-sm leading-tight">
                {stripGuildShowcase(g.guildName || g.name)}
              </h1>
              {g.guildName && g.guildName !== g.name && (
                <p class="text-white/80 text-sm mt-0.5">{stripGuildShowcase(g.name)}</p>
              )}
              {g.buildTitle && (
                <p class="text-white/75 text-sm mt-1 italic flex items-center gap-2">
                  {g.buildTitle}
                  {g.isCurrent && <span class="not-italic text-[10px] font-semibold bg-emerald-500/30 text-emerald-200 border border-emerald-400/40 rounded-full px-2 py-0.5">current</span>}
                </p>
              )}
              {g.tags && g.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-3">
                  {g.tags.map((tag: string) => (
                    <span class="text-xs px-2.5 py-0.5 rounded-full bg-white/15 text-white border border-white/25 backdrop-blur-sm">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
            <button
              id="share-btn"
              title="Copy link"
              class="text-white/70 hover:text-white transition-colors p-2 rounded-lg bg-white/10 hover:bg-white/20 backdrop-blur-sm cursor-pointer shrink-0"
            >
              <svg id="share-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              <svg id="check-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden" style="color: rgb(74 222 128)"><polyline points="20 6 9 17 4 12"/></svg>
            </button>
          </div>
        </div>
      </div>
    ) : (
      <div class="flex items-start justify-between gap-4">
        <div>
          <h1 class="font-heading text-3xl sm:text-4xl font-bold leading-tight">
            {stripGuildShowcase(g.guildName || g.name)}
          </h1>
          {g.guildName && g.guildName !== g.name && (
            <p class="text-foreground/60 text-sm mt-0.5">{stripGuildShowcase(g.name)}</p>
          )}
          {g.buildTitle && (
            <p class="text-muted-foreground text-sm mt-1 italic flex items-center gap-2">
              {g.buildTitle}
              {g.isCurrent && <span class="not-italic text-[10px] font-semibold bg-emerald-500/15 text-emerald-600 dark:text-emerald-400 border border-emerald-500/30 rounded-full px-2 py-0.5">current</span>}
            </p>
          )}
          {g.tags && g.tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mt-3">
              {g.tags.map((tag: string) => <Badge variant="secondary">{tag}</Badge>)}
            </div>
          )}
        </div>
        <button
          id="share-btn"
          title="Copy link"
          class="text-muted-foreground hover:text-foreground transition-colors p-2 rounded-lg hover:bg-muted cursor-pointer shrink-0"
        >
          <svg id="share-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          <svg id="check-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden text-green-500"><polyline points="20 6 9 17 4 12"/></svg>
        </button>
      </div>
    )}

    <script is:inline>
      document.getElementById("share-btn").addEventListener("click", async () => {
        const shareIcon = document.getElementById("share-icon")
        const checkIcon = document.getElementById("check-icon")
        const url = window.location.href
        try {
          if (navigator.share) {
            await navigator.share({ title: document.title, url })
          } else {
            await navigator.clipboard.writeText(url)
            window.umami?.track("share_url_copied", { type: "guild" })
            shareIcon.classList.add("hidden")
            checkIcon.classList.remove("hidden")
            setTimeout(() => {
              shareIcon.classList.remove("hidden")
              checkIcon.classList.add("hidden")
            }, 2000)
          }
        } catch {}
      })
    </script>

    <!-- Other builds from the same guild -->
    {siblingBuilds.length > 0 && (
      <div class="rounded-xl border border-border bg-card px-4 py-3 space-y-2.5">
        <p class="text-xs font-semibold uppercase tracking-wider text-muted-foreground flex items-center gap-1.5"><Layers size={12} />{siblingBuilds.length + 1} builds from this guild</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          {siblingBuilds.map((b) => {
            const img = b.coverImage ?? b.screenshots?.[0]
            const bTier = getTier(b.rank, totalGuilds, b.score)
            return (
              <a
                href={`${base}/guilds/${b.slug}`}
                class="group flex items-center gap-3 rounded-lg border border-border hover:border-primary/40 hover:bg-muted/50 transition-all px-3 py-2"
                data-umami-event="sibling_build_click"
                data-umami-event-name={b.name}
              >
                {img ? (
                  <div class="shrink-0 w-16 aspect-video rounded-md overflow-hidden bg-muted">
                    <img src={img} alt={b.buildTitle ?? b.name} class="w-full h-full object-cover" loading="lazy" onerror="this.style.display='none'" />
                  </div>
                ) : (
                  <div class="shrink-0 w-16 aspect-video rounded-md bg-muted flex items-center justify-center">
                    <Layers size={16} className="text-muted-foreground/40" />
                  </div>
                )}
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-medium leading-snug truncate">
                    {b.buildTitle ?? "Default"}
                    {b.isCurrent && <span class="ml-1.5 text-[10px] font-semibold bg-emerald-500/15 text-emerald-600 dark:text-emerald-400 border border-emerald-500/30 rounded-full px-1.5 py-0.5 not-italic">current</span>}
                  </p>
                  <span class={`inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-[11px] mt-0.5 ${bTier.badge}`} style={bTier.badgeStyle}>
                    <span class={`size-1.5 rounded-full shrink-0 ${bTier.dot}`} />
                    {bTier.label}
                  </span>
                </div>
                <svg class="size-3.5 shrink-0 text-muted-foreground/30 group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </a>
            )
          })}
        </div>
      </div>
    )}

    <!-- Stats strip -->
    <div class="flex flex-wrap gap-3">
      <div class="rounded-xl border border-border bg-card px-4 py-2 min-w-35 flex-1">
        <div class="text-xs text-muted-foreground mb-1">Builders</div>
        <div class="text-sm font-medium">{g.builders?.map(formatBuilderName).filter(Boolean).join(", ") || "—"}</div>
      </div>
      <div class="rounded-xl border border-border bg-card px-4 py-2">
        <div class="flex gap-5">
          <div>
            <div class="text-xs text-muted-foreground mb-1">Tier</div>
            <span class={`inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-xs ${tier.badge}`} style={tier.badgeStyle}>
              <span class={`size-1.5 rounded-full shrink-0 ${tier.dot}`} />
              {tier.label}
            </span>
          </div>
          <div class="border-l border-border pl-5">
            <div class="text-xs text-muted-foreground mb-1">Score</div>
            <div class="text-sm font-mono tabular-nums text-muted-foreground">{g.score}</div>
          </div>
        </div>
      </div>
      {g.id && (
        <div class="rounded-xl border border-border bg-card px-4 py-2">
          <div class="text-xs text-muted-foreground mb-1">Guild ID</div>
          <div
            class="inline-flex items-center gap-1.5 rounded-full border border-border bg-muted/50 px-3 py-1 text-sm text-muted-foreground font-mono ring-1 ring-inset ring-border/60 cursor-pointer select-none"
            style="transition: color 0.4s ease, border-color 0.4s ease, background-color 0.4s ease"
            onclick={`navigator.clipboard.writeText('${g.id}'); this.style.color='#4ade80'; this.style.borderColor='#4ade8066'; this.style.backgroundColor='#4ade8011'; setTimeout(() => { this.style.color=''; this.style.borderColor=''; this.style.backgroundColor=''; }, 800)`}
            title="Copy guild ID"
          >
            {g.id}
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 256 256" fill="currentColor"><path d="M216,32H88a8,8,0,0,0-8,8V80H40a8,8,0,0,0-8,8V216a8,8,0,0,0,8,8H168a8,8,0,0,0,8-8V176h40a8,8,0,0,0,8-8V40A8,8,0,0,0,216,32ZM160,208H48V96H160Zm48-48H176V88a8,8,0,0,0-8-8H96V48H208Z"/></svg>
          </div>
        </div>
      )}
      {g.hostedAtGuildName && (
        <div class="rounded-xl border border-border bg-card px-4 py-2">
          <div class="text-xs text-muted-foreground mb-1">Hosted at</div>
          <div class="text-sm font-medium">
            {g.hostedAtGuildName}
            {g.hostedAtGuildId && <span class="ml-1 text-xs text-muted-foreground font-mono">[{g.hostedAtGuildId}]</span>}
          </div>
        </div>
      )}
      {g.createdAt && (
        <div class="rounded-xl border border-border bg-card px-4 py-2">
          <div class="text-xs text-muted-foreground mb-1">Created</div>
          <div class="text-sm text-muted-foreground" id="guild-created-at">{g.createdAt}</div>
          <script is:inline define:vars={{ createdAt: g.createdAt }}>
            {
              const d = new Date(createdAt.replace(" at ", " "))
              if (!isNaN(d.getTime())) {
                const pad = n => String(n).padStart(2, "0")
                document.getElementById("guild-created-at").textContent = `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`
              }
            }
          </script>
        </div>
      )}
      {g.lastModified && (
        <div class="rounded-xl border border-border bg-card px-4 py-2">
          <div class="text-xs text-muted-foreground mb-1">Updated</div>
          <div class="text-sm text-muted-foreground" id="guild-last-modified">{g.lastModified}</div>
          <script is:inline define:vars={{ lastModified: g.lastModified }}>
            {
              const d = new Date(lastModified.replace(" at ", " "))
              if (!isNaN(d.getTime())) {
                const pad = n => String(n).padStart(2, "0")
                document.getElementById("guild-last-modified").textContent = `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}`
              }
            }
          </script>
        </div>
      )}
      {g.discordThread && (
        <div class="rounded-xl border border-border bg-card px-4 py-2 flex flex-row items-center gap-2">
          <a href="https://discord.gg/Qygt9u26Bn" target="_blank" rel="noopener noreferrer" class={buttonVariants({ variant: "secondary", size: "sm" })} data-umami-event="discord_cta_click">
            Join server ↗
          </a>
          <a href={g.discordThread} target="_blank" rel="noopener noreferrer" class={buttonVariants({ size: "sm" })} data-umami-event="discord_cta_click">
            Vote ↗
          </a>
        </div>
      )}
    </div>

    <!-- Lore -->
    {g.lore && (
      <section class="space-y-3">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-muted-foreground flex items-center gap-1.5"><BookOpen size={13} />Lore</h2>
        <div class="border-l-2 border-border pl-4">
          <div
            class="text-sm text-muted-foreground leading-relaxed space-y-2 [&_strong]:text-foreground [&_strong]:font-medium"
            set:html={renderMarkdown(g.lore)}
          />
        </div>
      </section>
    )}

    <!-- What to Visit -->
    {g.whatToVisit && (
      <section class="space-y-3">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-muted-foreground flex items-center gap-1.5"><MapPin size={13} />What to Visit</h2>
        <div class="rounded-xl bg-muted/40 border border-border px-5 py-4">
          <div
            class="text-sm leading-relaxed space-y-3 [&_ul]:space-y-1.5 [&_li]:flex [&_li]:gap-2 [&_li]:before:content-['·'] [&_li]:before:text-muted-foreground [&_strong]:font-semibold"
            set:html={renderMarkdown(g.whatToVisit)}
          />
        </div>
      </section>
    )}

    <div class="border-t border-border" />

    <!-- Media -->
    <section class="space-y-4">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-muted-foreground flex items-center gap-1.5"><Images size={13} />Media</h2>
      <MediaGallery screenshots={g.screenshots} screenshotSections={g.screenshotSections} videos={g.videos} />
    </section>

    <!-- Discord CTA banner -->
    {g.discordThread && (
      <div class="rounded-2xl bg-muted/50 border border-border px-6 py-5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
          <p class="font-semibold">Like what you see?</p>
          <p class="text-sm text-muted-foreground mt-0.5">React to the thread on Discord. Votes carry more weight the more guilds you've explored.</p>
        </div>
        <div class="flex flex-wrap gap-2 shrink-0">
          <a href="https://discord.gg/Qygt9u26Bn" target="_blank" rel="noopener noreferrer" class={buttonVariants({ variant: "secondary" })} data-umami-event="discord_cta_click">
            Join server ↗
          </a>
          <a href={g.discordThread} target="_blank" rel="noopener noreferrer" class={buttonVariants({})} data-umami-event="discord_cta_click">
            Vote ↗
          </a>
        </div>
      </div>
    )}

    <!-- Incentive callout -->
    {(enteredByAhlyam || !g.discordThread) && g.name !== "Jenova" && (
      <Card>
        <CardContent className="space-y-2 text-sm">
          <p class="font-medium">Is this your guild?</p>
          <p class="text-muted-foreground">
            This guild lacks more informations and was added by the WBM community{scoutName ? <>, scouted by <span class="font-medium text-foreground">{scoutName}</span></> : ""}. If you're a builder of {stripGuildShowcase(g.guildName || g.name)}, please help us.<br />See the
            <a href={base + "/contribute"} class="underline hover:text-foreground transition-colors">contribute guide</a> to get started. <a href="https://discord.gg/Qygt9u26Bn" target="_blank" rel="noopener noreferrer" class={buttonVariants({ size: "sm" })} data-umami-event="discord_cta_click">Post your base ↗</a>
          </p>
        </CardContent>
      </Card>
    )}
  </div>
</Layout>
