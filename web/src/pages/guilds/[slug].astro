---
import Layout from "@/layouts/main.astro"
import MediaGallery from "@/components/MediaGallery.astro"
import { Badge } from "@/components/ui/badge"
import { buttonVariants } from "@/components/ui/button"
import { Card, CardContent } from "@/components/ui/card"
import { Table, TableBody, TableCell, TableRow } from "@/components/ui/table"
import { getGuildsSortedByScore } from "@/lib/guilds"
import { rankLabel } from "@/lib/slugify"
import { renderMarkdown } from "@/lib/markdown"
import { BASE } from "@/lib/url"

export async function getStaticPaths() {
  const guilds = getGuildsSortedByScore()
  return guilds.map((g) => ({
    params: { slug: g.slug },
    props: { guild: g },
  }))
}

const { guild: g } = Astro.props
const base = BASE
const AHLYAM_ID = "149790526076354561"
const WINDXP_ID = "721510597958828183"
const enteredByAhlyam = g.builderDiscordId === AHLYAM_ID || g.builderDiscordId === WINDXP_ID
const randomScreenshot = g.screenshots?.length
  ? g.screenshots[Math.floor(Math.random() * g.screenshots.length)]
  : undefined
---

<Layout
  title={`${g.name} — A Where Winds Meet guild base`}
  description={g.lore?.slice(0, 160) ?? `Guild base showcase for ${g.name} in Where Winds Meet.`}
  image={randomScreenshot}
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      headline: `${g.name} — Guild Base`,
      description: g.lore?.slice(0, 160) ?? `Guild base showcase for ${g.name} in Where Winds Meet.`,
      image: g.screenshots?.[0] ?? undefined,
      url: Astro.url.href,
      author: g.builders?.map((name) => ({ "@type": "Person", name })) ?? [],
    })}
  />
  <div class="max-w-5xl space-y-8">
    <!-- Back -->
    <a
      href={base + "/"}
      class="inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground transition-colors"
    >
      ← All guilds
    </a>

    <!-- Header -->
    <div>
      <div class="flex items-center gap-2">
        <h1 class="font-heading text-2xl font-semibold">{g.guildName || g.name}</h1>
        <button id="share-btn" title="Copy link" class="text-muted-foreground hover:text-foreground transition-colors p-1 rounded cursor-pointer">
          <svg id="share-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          <svg id="check-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden text-green-500"><polyline points="20 6 9 17 4 12"/></svg>
        </button>
      </div>
      <div class="flex flex-wrap gap-1.5 mt-2">
        {
          g.tags?.map((tag) => (
            <Badge variant="secondary">{tag}</Badge>
          ))
        }
      </div>
    </div>
    <script is:inline>
      document.getElementById("share-btn").addEventListener("click", async () => {
        const shareIcon = document.getElementById("share-icon")
        const checkIcon = document.getElementById("check-icon")
        const url = window.location.href
        try {
          if (navigator.share) {
            await navigator.share({ title: document.title, url })
          } else {
            await navigator.clipboard.writeText(url)
            shareIcon.classList.add("hidden")
            checkIcon.classList.remove("hidden")
            checkIcon.classList.add("text-green-500")
            setTimeout(() => {
              shareIcon.classList.remove("hidden")
              checkIcon.classList.add("hidden")
            }, 2000)
          }
        } catch {}
      })
    </script>

    <!-- Metadata table -->
    <div class="rounded-xl ring-1 ring-border overflow-hidden">
      <Table>
        <TableBody>
          {g.id && (
            <TableRow>
              <TableCell className="text-muted-foreground font-medium w-32">🆔 Guild ID</TableCell>
              <TableCell>{g.id}</TableCell>
            </TableRow>
          )}
          <TableRow>
            <TableCell className="text-muted-foreground font-medium">🔨 Builders</TableCell>
            <TableCell>{g.builders?.join(", ") || "—"}</TableCell>
          </TableRow>
          <TableRow>
            <TableCell className="text-muted-foreground font-medium">⭐ Score</TableCell>
            <TableCell className="font-semibold font-mono">{g.score}</TableCell>
          </TableRow>
          <TableRow>
            <TableCell className="text-muted-foreground font-medium">🏆 Rank</TableCell>
            <TableCell>{rankLabel(g.rank)}</TableCell>
          </TableRow>
          {g.discordThread && (
            <TableRow>
              <TableCell className="text-muted-foreground font-medium">💬 Discord</TableCell>
              <TableCell>
                <div class="flex flex-wrap gap-2">
                  <a href="https://discord.gg/Qygt9u26Bn" target="_blank" rel="noopener noreferrer" class={buttonVariants({ variant: "secondary", size: "sm" })}>
                    Join server ↗
                  </a>
                  <a href={g.discordThread} target="_blank" rel="noopener noreferrer" class={buttonVariants({ size: "sm" })}>
                    Vote ↗
                  </a>
                </div>
              </TableCell>
            </TableRow>
          )}
        </TableBody>
      </Table>
    </div>

    <!-- Lore -->
    {
      g.lore && (
        <section>
          <h2 class="font-heading text-base font-medium mb-2">📜 Lore</h2>
          <div
            class="text-sm text-muted-foreground leading-relaxed prose-sm space-y-2 [&_strong]:text-foreground [&_strong]:font-medium"
            set:html={renderMarkdown(g.lore)}
          />
        </section>
      )
    }

    <!-- What to Visit -->
    {
      g.whatToVisit && (
        <section>
          <h2 class="font-heading text-base font-medium mb-2">🗺️ What to Visit</h2>
          <div
            class="text-sm leading-relaxed space-y-3 [&_ul]:space-y-1.5 [&_li]:flex [&_li]:gap-2 [&_li]:before:content-['·'] [&_li]:before:text-muted-foreground [&_strong]:font-semibold"
            set:html={renderMarkdown(g.whatToVisit)}
          />
        </section>
      )
    }

    <!-- Media -->
    <section class="space-y-6">
      <h2 class="font-heading text-base font-medium">🎬 Media</h2>
      <MediaGallery screenshots={g.screenshots} videos={g.videos} />
    </section>

    <!-- Discord CTA -->
    {g.discordThread && (
      <div class="flex flex-wrap gap-3">
        <a href="https://discord.gg/Qygt9u26Bn" target="_blank" rel="noopener noreferrer" class={buttonVariants({ variant: "secondary", size: "lg" })}>Join server ↗</a>
        <a href={g.discordThread} target="_blank" rel="noopener noreferrer" class={buttonVariants({ size: "lg" })}>Vote on Discord ↗</a>
      </div>
    )}

    <!-- Incentive callout -->
    {(enteredByAhlyam || !g.discordThread) && g.name !== "Jenova" && (
      <Card>
        <CardContent className="space-y-2 text-sm">
          <p class="font-medium">Is this your guild?</p>
          <p class="text-muted-foreground">
            This entry was added by the site maintainer. If you're a builder of {g.guildName || g.name}, you can post your base showcase yourself. See the
            <a href={base + "/contribute"} class="underline hover:text-foreground transition-colors">contribute guide</a> to get started.
          </p>
          <a href="https://discord.gg/Qygt9u26Bn" target="_blank" rel="noopener noreferrer" class={buttonVariants({ size: "lg" })}>Post your base ↗</a>
        </CardContent>
      </Card>
    )}
  </div>
</Layout>
