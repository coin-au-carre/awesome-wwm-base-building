---
import Layout from "@/layouts/main.astro"
import { BuilderProfile } from "@/components/BuilderProfile"
import { BUILDER_IDENTITIES } from "@/lib/builder-aliases"

// Query-string route (?id=<number_id>) rather than a dynamic [id] path
// segment — the site builds statically and this page has no build-time
// list of gallery designer ids to enumerate.

// number_id -> canonicalSlug, same map gallery.astro builds — lets
// BuilderProfile show a "this builder is also on WBM" banner-link to
// their fuller /builders/<slug> page when one exists, rather than
// silently duplicating content across two separate profile pages. See
// docs/builder-identity.md's "merging the two builder-profile systems".
const wbmBuilders: Record<string, string> = Object.fromEntries(
  BUILDER_IDENTITIES.filter((e) => e.neteaseNumberId).map((e) => [e.neteaseNumberId as string, e.canonicalSlug]),
)
---

<Layout
  title="Where Builders Meet | Gallery builder (preview)"
  description="Gallery builder profile — work in progress."
  noindex
  fullWidth
>
  <BuilderProfile client:load wbmBuilders={wbmBuilders} />
</Layout>
