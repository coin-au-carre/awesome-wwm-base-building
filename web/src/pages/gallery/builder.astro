---
import Layout from "@/layouts/main.astro"
import { BuilderProfile } from "@/components/BuilderProfile"
import { BUILDER_IDENTITIES } from "@/lib/builder-aliases"

// Query-string route (?id=<number_id>) rather than a dynamic [id] path
// segment — the site builds statically and this page has no build-time
// list of gallery designer ids to enumerate.

// number_id -> canonicalSlug, for every WBM-linked builder identity —
// lets BuilderProfile redirect straight to their fuller /builders/<slug>
// page instead of duplicating this profile across two URLs. See
// docs/builder-identity.md's "merging the two builder-profile systems".
const wbmSlugs: Record<string, string> = Object.fromEntries(
  BUILDER_IDENTITIES.filter((e) => e.neteaseNumberId).map((e) => [e.neteaseNumberId as string, e.canonicalSlug]),
)
---

<Layout
  title="Where Builders Meet | Gallery builder profile"
  description="A builder's live WWM construction gallery profile."
  fullWidth
>
  <BuilderProfile client:load wbmSlugs={wbmSlugs} />
</Layout>
