---
import Layout from "@/layouts/main.astro"
import { GalleryGrid } from "@/components/GalleryGrid"
import { Badge } from "@/components/ui/badge"
import { readFileSync } from "fs"
import { resolve } from "path"
import type { BuilderIdentity } from "@/lib/builder-aliases"

// noindex + excluded from sitemap (see astro.config.mjs) while in beta —
// this fetches from wbm-relay, a private backend still being built.
// Remove noindex once that's stable enough to go fully public.

// number_id -> canonicalSlug, for gallery cards whose NetEase author is
// also a known WBM builder (see data/builder_identities.json). Requires
// both neteaseNumberId (to match a live gallery plan's author_number_id)
// and discordId (a real linked Discord account, not just a stub entry).
let wbmBuilders: Record<string, string> = {}
try {
  const identities: BuilderIdentity[] = JSON.parse(
    readFileSync(resolve(process.cwd(), "..", "data/builder_identities.json"), "utf-8"),
  )
  wbmBuilders = Object.fromEntries(
    identities.filter((e) => e.neteaseNumberId && e.discordId).map((e) => [e.neteaseNumberId as string, e.canonicalSlug]),
  )
} catch {
  // missing/corrupt file — gallery still works, just without WBM badges
}
---

<Layout
  title="Where Builders Meet | Gallery (beta)"
  description="Live construction diagram gallery — work in progress."
  noindex
  fullWidth
>
  <div class="space-y-6">
    <div class="flex flex-wrap items-center gap-2">
      <h1 class="font-heading text-2xl font-semibold">Gallery Bazaar</h1>
      <Badge variant="outline" className="border-amber-500/50 text-amber-600 dark:text-amber-400">
        Beta
      </Badge>
      <Badge variant="secondary">Work in progress</Badge>
      <p class="text-muted-foreground text-sm">
        A enhanced WWM gallery for builders: faster, practical, more detailed.
      </p>
    </div>
    <GalleryGrid client:load wbmBuilders={wbmBuilders} />
  </div>
</Layout>
