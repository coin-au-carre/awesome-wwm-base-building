---
import Layout from "@/layouts/main.astro"
import { GalleryGrid } from "@/components/GalleryGrid"
import { buttonVariants } from "@/components/ui/button"
import { BUILDER_IDENTITIES } from "@/lib/builder-aliases"
import { url } from "@/lib/url"

// number_id -> canonicalSlug, for gallery cards whose NetEase author is
// also a known WBM builder (see data/builder_identities.json). Only the
// entries with both a neteaseNumberId and an explicit discordId are
// useful here — no name-matching fallback, so this only ever reflects a
// confirmed /wwm-uid link (see builders/index.astro's isWbmBuilder,
// which uses the same strict rule).
const wbmBuilders: Record<string, string> = Object.fromEntries(
  BUILDER_IDENTITIES.filter((e) => e.neteaseNumberId && e.discordId).map((e) => [
    e.neteaseNumberId as string,
    e.canonicalSlug,
  ]),
)
---

<Layout
  title="Where Builders Meet | Gallery"
  description="Browse live WWM construction diagrams — faster and easier to search than the in-game gallery."
  fullWidth
>
  <div class="space-y-6">
    <div class="flex flex-wrap items-center gap-2">
      <h1 class="font-heading text-2xl font-semibold">Gallery Bazaar</h1>
      <p class="text-muted-foreground text-sm">
        A enhanced WWM gallery for builders: faster, practical, more detailed.
      </p>
      <a href={url("/builders")} class={`${buttonVariants({ variant: "outline", size: "sm" })} ml-auto`}>
        Browse the Builders Directory ↗
      </a>
    </div>
    <GalleryGrid client:load wbmBuilders={wbmBuilders} />
  </div>
</Layout>
