---
import Layout from "@/layouts/main.astro"
import { GalleryGrid } from "@/components/GalleryGrid"
import { Badge } from "@/components/ui/badge"
import { BUILDER_IDENTITIES } from "@/lib/builder-aliases"

// noindex + excluded from sitemap (see astro.config.mjs) while in beta —
// this fetches from wbm-relay, a private backend still being built.
// Remove noindex once that's stable enough to go fully public.

// number_id -> canonicalSlug, for gallery cards whose NetEase author is
// also a known WBM builder (see data/builder_identities.json). Only the
// entries with a neteaseNumberId are useful here — everyone else has no
// way to be matched against a live gallery plan's author_number_id.
const wbmBuilders: Record<string, string> = Object.fromEntries(
  BUILDER_IDENTITIES.filter((e) => e.neteaseNumberId).map((e) => [e.neteaseNumberId as string, e.canonicalSlug]),
)
---

<Layout
  title="Where Builders Meet | Gallery (beta)"
  description="Live construction diagram gallery — work in progress."
  noindex
  fullWidth
>
  <div class="space-y-6">
    <div class="flex flex-wrap items-center gap-2">
      <h1 class="font-heading text-2xl font-semibold">Gallery Bazaar</h1>
      <Badge variant="outline" className="border-amber-500/50 text-amber-600 dark:text-amber-400">
        Beta
      </Badge>
      <Badge variant="secondary">Work in progress</Badge>
      <p class="text-muted-foreground text-sm">
        A enhanced WWM gallery for builders: faster, practical, more detailed.
      </p>
    </div>
    <GalleryGrid client:load wbmBuilders={wbmBuilders} />
  </div>
</Layout>
