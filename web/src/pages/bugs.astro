---
import Layout from "@/layouts/main.astro"
import { BugsTable } from "@/components/BugsTable"
import { BugReporter } from "@/components/BugReporter"
import type { Bug } from "@/components/BugsTable"
import { BugIcon, GameControllerIcon, DiscordLogoIcon, XLogoIcon, EnvelopeSimpleIcon } from "@phosphor-icons/react"
import { readFileSync } from "fs"
import { resolve } from "path"

let bugs: Bug[] = []
try {
  bugs = JSON.parse(readFileSync(resolve(process.cwd(), "..", "data/bugs.json"), "utf-8"))
} catch {
  // data/bugs.json not yet generated — page renders with empty table
}

const SHEET_URL =
  "https://docs.google.com/spreadsheets/d/e/2PACX-1vQYRYkRj4HdlI1m7Sl4pfpyINlTW2GvwTtuUZJl2XnN0gbtR_S3OLg--Zk4a0td1NV8mz3ulUO8aU-4/pubhtml?gid=0&single=true"
---

<Layout
  title="Where Builders Meet | Bug Reports"
  description="Community-tracked bugs in Where Winds Meet building and guild base features. Filtered by severity and platform."
>
  <div class="max-w-5xl space-y-6">
    <div class="flex flex-col gap-2">
      <h1 class="font-heading text-2xl font-semibold flex items-center gap-2">
        <BugIcon weight="duotone" className="size-6 text-primary" /> Bug Reports - Where Bugs Meet
      </h1>
      <p class="text-muted-foreground text-sm">
        Community-tracked bugs in Where Winds Meet building features, updated from{" "}
        <a
          href={SHEET_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="text-foreground underline underline-offset-2 hover:text-primary transition-colors"
          data-umami-event="bugs_sheet_open"
        >
          our shared spreadsheet ↗
        </a>. Spot something missing? Report it in{" "}
        <a
          href="https://discord.gg/Qygt9u26Bn"
          target="_blank"
          rel="noopener noreferrer"
          class="text-foreground underline underline-offset-2 hover:text-primary transition-colors"
          data-umami-event="discord_cta_click"
        >
          Discord ↗
        </a>.
      </p>
    </div>
    <BugsTable bugs={bugs} client:load />

    <!-- How to report -->
    <div class="border-t border-border pt-8 space-y-5">
      <div>
        <h2 id="how-to-report" class="font-heading text-lg font-semibold flex items-center gap-2 group/h">
          How to report bugs on Where Winds Meet
          <a href="#how-to-report" class="text-muted-foreground opacity-0 group-hover/h:opacity-100 transition-opacity font-normal text-base" aria-hidden="true">#</a>
        </h2>
        <p class="text-sm text-muted-foreground mt-1">Every report helps. The more players report, the faster issues get fixed.</p>
      </div>
      <ul class="space-y-3 text-sm">
        <li class="flex items-start gap-3">
          <GameControllerIcon weight="duotone" className="size-4 mt-0.5 text-primary shrink-0" />
          <div>
            <span class="font-medium">In-game</span>
            <span class="text-muted-foreground"> · Open Settings → Bug Report. Describe what happened and attach a screenshot if possible.</span>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <DiscordLogoIcon weight="duotone" className="size-4 mt-0.5 text-primary shrink-0" />
          <div>
            <span class="font-medium">Official Discord</span>
            <span class="text-muted-foreground"> · Post in </span>
            <a
              href="https://discord.com/channels/1180042348755963924/1440984503978954897"
              target="_blank"
              rel="noopener noreferrer"
              class="text-foreground underline underline-offset-2 hover:text-primary transition-colors"
              data-umami-event="bugs_report_discord_click"
            >#known-issues-and-progress ↗</a>
            <span class="text-muted-foreground"> with steps to reproduce and your platform.</span>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <XLogoIcon weight="duotone" className="size-4 mt-0.5 text-primary shrink-0" />
          <div>
            <span class="font-medium">X / Twitter</span>
            <span class="text-muted-foreground"> · DM </span>
            <a
              href="https://x.com/WWMSupport"
              target="_blank"
              rel="noopener noreferrer"
              class="text-foreground font-mono underline underline-offset-2 hover:text-primary transition-colors"
              data-umami-event="bugs_report_x_click"
            >@WWMSupport ↗</a>
            <span class="text-muted-foreground"> — attach a video or screenshot for faster triage.</span>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <EnvelopeSimpleIcon weight="duotone" className="size-4 mt-0.5 text-primary shrink-0" />
          <div>
            <span class="font-medium">Email</span>
            <span class="text-muted-foreground"> · Send to </span>
            <span class="font-mono text-foreground">wherewindsmeet@global.netease.com</span>
            <span class="text-muted-foreground"> — use the email builder below to generate a ready-to-send report.</span>
          </div>
        </li>
      </ul>
    </div>

    <div class="flex items-center gap-3 text-xs text-muted-foreground">
      <div class="flex-1 border-t border-border"></div>
      <span class="shrink-0">Email builder</span>
      <div class="flex-1 border-t border-border"></div>
    </div>

    <BugReporter bugs={bugs} client:load />
  </div>
</Layout>
