---
import Layout from "@/layouts/main.astro"
import { BugsTable } from "@/components/BugsTable"
import { BugReporter } from "@/components/BugReporter"
import type { Bug } from "@/components/BugsTable"
import { BugIcon } from "@phosphor-icons/react"
import { readFileSync } from "fs"
import { resolve } from "path"

let bugs: Bug[] = []
try {
  bugs = JSON.parse(readFileSync(resolve(process.cwd(), "..", "data/bugs.json"), "utf-8"))
} catch {
  // data/bugs.json not yet generated — page renders with empty table
}

const SHEET_URL =
  "https://docs.google.com/spreadsheets/d/e/2PACX-1vQYRYkRj4HdlI1m7Sl4pfpyINlTW2GvwTtuUZJl2XnN0gbtR_S3OLg--Zk4a0td1NV8mz3ulUO8aU-4/pubhtml?gid=0&single=true"
---

<Layout
  title="Where Builders Meet | Bug Reports"
  description="Community-tracked bugs in Where Winds Meet building and guild base features. Filtered by severity and platform."
>
  <div class="max-w-5xl space-y-6">
    <div class="flex flex-col gap-2">
      <h1 class="font-heading text-2xl font-semibold flex items-center gap-2">
        <BugIcon weight="duotone" className="size-6 text-primary" /> Bug Reports
      </h1>
      <p class="text-muted-foreground text-sm">
        Community-tracked bugs in Where Winds Meet building features, updated from{" "}
        <a
          href={SHEET_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="text-foreground underline underline-offset-2 hover:text-primary transition-colors"
          data-umami-event="bugs_sheet_open"
        >
          our shared spreadsheet ↗
        </a>. Spot something missing? Report it in{" "}
        <a
          href="https://discord.gg/Qygt9u26Bn"
          target="_blank"
          rel="noopener noreferrer"
          class="text-foreground underline underline-offset-2 hover:text-primary transition-colors"
          data-umami-event="discord_cta_click"
        >
          Discord ↗
        </a>.
      </p>
    </div>
    <BugsTable bugs={bugs} client:load />

    <!-- How to report -->
    <div class="border-t border-border pt-8 space-y-4">
      <div>
        <h2 class="font-heading text-lg font-semibold">How to report bugs</h2>
        <p class="text-sm text-muted-foreground mt-1">Every report helps — the more players report, the faster issues get fixed.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        <div class="rounded-lg border border-border bg-card px-4 py-3 text-sm space-y-0.5">
          <p class="font-medium">In-game</p>
          <p class="text-muted-foreground text-xs">Settings → <span class="text-foreground">Bug Report</span></p>
        </div>
        <a
          href="https://discord.com/channels/1180042348755963924/1440984503978954897"
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-lg border border-border bg-card px-4 py-3 text-sm space-y-0.5 hover:border-primary/40 transition-colors group"
          data-umami-event="bugs_report_discord_click"
        >
          <p class="font-medium flex items-center gap-1.5">Official Discord <span class="text-muted-foreground group-hover:text-primary transition-colors text-xs">↗</span></p>
          <p class="text-muted-foreground text-xs">#known-issues-and-progress</p>
        </a>
        <a
          href="https://x.com/WWMSupport"
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-lg border border-border bg-card px-4 py-3 text-sm space-y-0.5 hover:border-primary/40 transition-colors group"
          data-umami-event="bugs_report_x_click"
        >
          <p class="font-medium flex items-center gap-1.5">X / Twitter <span class="text-muted-foreground group-hover:text-primary transition-colors text-xs">↗</span></p>
          <p class="text-muted-foreground text-xs">DM <span class="text-foreground font-mono">@WWMSupport</span></p>
        </a>
        <div class="rounded-lg border border-border bg-card px-4 py-3 text-sm space-y-0.5">
          <p class="font-medium">Email</p>
          <p class="text-muted-foreground text-xs font-mono">wherewindsmeet@global.netease.com</p>
        </div>
      </div>
    </div>

    <BugReporter bugs={bugs} client:load />
  </div>
</Layout>
