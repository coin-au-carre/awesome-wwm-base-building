---
import Layout from "@/layouts/main.astro"
---

<Layout
  title="Contribute — Awesome WWM Base Building"
  description="How to add your guild base to the showcase."
>
  <div class="max-w-2xl space-y-10">
    <div>
      <h1 class="font-heading text-2xl font-semibold mb-1">🤝 Contribute</h1>
      <p class="text-muted-foreground text-sm">Add your guild base to the showcase.</p>
    </div>

    <section class="space-y-6">
      <h2 class="font-heading text-base font-medium">How to get listed</h2>

      <ol class="space-y-5">
        {
          [
            {
              n: "1",
              title: "Join the Discord",
              body: "All submissions go through our Discord server. Join to get access to the guild base forum.",
              cta: { label: "Join Discord ↗", href: "https://discord.gg/Qygt9u26Bn" },
            },
            {
              n: "2",
              title: "Create a thread in the Guild Base forum",
              body: 'Post in the dedicated forum channel. Your thread title should follow the format: 🏯 GuildName [GuildID]',
            },
            {
              n: "3",
              title: "Fill in your first post",
              body: "The bot reads the first post of your thread. Include the fields below for the best listing.",
            },
            {
              n: "4",
              title: "Add screenshots",
              body: "Attach your base screenshots as images in follow-up posts in the same thread. The bot collects them all.",
            },
            {
              n: "5",
              title: "Wait for the next sync",
              body: "The site syncs twice a day (7:00 and 19:00 UTC). Your guild will appear automatically after the next sync.",
            },
          ].map((step) => (
            <li class="flex gap-4">
              <span class="shrink-0 flex h-7 w-7 items-center justify-center rounded-full bg-primary/10 text-primary text-xs font-semibold">
                {step.n}
              </span>
              <div class="space-y-1">
                <p class="font-medium text-sm">{step.title}</p>
                <p class="text-sm text-muted-foreground">{step.body}</p>
                {step.cta && (
                  <a
                    href={step.cta.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex mt-1 items-center gap-1 text-sm text-primary underline hover:no-underline transition-colors"
                  >
                    {step.cta.label}
                  </a>
                )}
              </div>
            </li>
          ))
        }
      </ol>
    </section>

    <section class="space-y-4">
      <h2 class="font-heading text-base font-medium">Post template</h2>
      <p class="text-sm text-muted-foreground">Copy this into your thread's first post:</p>
      <pre class="rounded-xl bg-muted/60 ring-1 ring-border px-5 py-4 text-xs leading-relaxed overflow-x-auto"><code>🏯 YourGuildName [YourGuildID]
👷 Builders: builder1, builder2

📝 Lore
Write your guild's story here.

🧙 What to visit
- Point of interest 1
- Point of interest 2</code></pre>
    </section>

    <section class="space-y-3">
      <h2 class="font-heading text-base font-medium">Updating your listing</h2>
      <p class="text-sm text-muted-foreground leading-relaxed">
        Edit the first post of your Discord thread at any time. Changes are picked up on the
        next sync. New screenshots added to the thread will appear automatically.
      </p>
    </section>

    <section class="rounded-xl bg-muted/40 ring-1 ring-border px-6 py-5">
      <p class="text-sm">
        Something not working?{" "}
        <a href="https://discord.gg/Qygt9u26Bn" class="underline hover:text-foreground transition-colors">
          Ping us on Discord.
        </a>
      </p>
    </section>
  </div>
</Layout>
