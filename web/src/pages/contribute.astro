---
import Layout from "@/layouts/main.astro"
import ContributeTabs from "@/components/ContributeTabs"
import { Card, CardContent } from "@/components/ui/card"
import { SwordIcon } from "@phosphor-icons/react"
---

<Layout
  title="Contribute — Where Builders Meet"
  description="How to contribute to the showcase — as a builder, a voter, or a developer."
>
  <div class="max-w-3xl space-y-6">
    <div class="flex flex-col gap-3">
      <h1 class="font-heading text-2xl font-semibold flex items-center gap-2"><SwordIcon weight="duotone" className="size-6 text-primary" /> Contribute</h1>
      <p class="text-muted-foreground text-sm">Every builder, explorer, voter, and developer helps the community grow. <span class="whitespace-nowrap">Get started on <a href="https://discord.gg/Qygt9u26Bn" class="text-foreground underline underline-offset-2 hover:text-primary transition-colors" data-umami-event="discord_cta_click">Discord ↗</a></span></p>
    </div>

    <ContributeTabs client:only="react" />

    <Card className="mt-10">
      <CardContent className="text-sm">
        Any question?{" "}
        <a href="https://discord.gg/Qygt9u26Bn" class="underline hover:text-foreground transition-colors" data-umami-event="discord_cta_click">
          Ping us on Discord.
        </a>
      </CardContent>
    </Card>
  </div>
</Layout>
