---
import Layout from "@/layouts/main.astro"
import { Badge } from "@/components/ui/badge"
import { CalendarIcon, MapPinIcon, UsersIcon, ArrowSquareOutIcon, FlaskIcon, CastleTurretIcon } from "@phosphor-icons/react"
import { getUpcomingEvents, EVENT_TYPE_LABELS, EVENT_TYPE_EMOJI } from "@/lib/events"
import type { EventType } from "@/lib/events"
import { BASE } from "@/lib/url"
import { getGuildsSortedByScore } from "@/lib/guilds"

const events = getUpcomingEvents()

const _allGuilds = getGuildsSortedByScore()
const guildSlugById = new Map(_allGuilds.filter((g) => g.id).map((g) => [g.id!, g.slug]))
const guildSlugByName = new Map(_allGuilds.map((g) => [(g.guildName ?? g.name).toLowerCase(), g.slug]))

function formatDescription(text: string): string {
  const escaped = text
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
  const linked = escaped.replace(
    /(https?:\/\/[^\s]+)/g,
    '<a href="$1" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline break-all">$1</a>',
  )
  return linked.replace(/\n/g, "<br>")
}

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString("en-US", {
    weekday: "short",
    month: "short",
    day: "numeric",
    hour: "2-digit",
    minute: "2-digit",
    timeZoneName: "short",
  })
}

const TYPE_COLORS: Record<EventType, string> = {
  tour:     "bg-blue-500/10 text-blue-600 dark:text-blue-400 border-blue-500/20",
  pvp:      "bg-red-500/10 text-red-600 dark:text-red-400 border-red-500/20",
  marriage: "bg-pink-500/10 text-pink-600 dark:text-pink-400 border-pink-500/20",
  dancing:  "bg-purple-500/10 text-purple-600 dark:text-purple-400 border-purple-500/20",
  fashion:  "bg-fuchsia-500/10 text-fuchsia-600 dark:text-fuchsia-400 border-fuchsia-500/20",
  contest:  "bg-yellow-500/10 text-yellow-600 dark:text-yellow-500 border-yellow-500/20",
  other:    "bg-muted text-muted-foreground border-border",
}
---

<Layout
  title="Events — Where Builders Meet"
  description="Upcoming public events in awesome guild bases. Join on Discord."
>
  <div class="max-w-3xl space-y-8">
    <!-- Header -->
    <div class="flex flex-col gap-3">
      <div class="flex items-center gap-3 flex-wrap">
        <h1 class="font-heading text-2xl font-semibold flex items-center gap-2">
          <CalendarIcon weight="duotone" className="size-6 text-primary" /> Events
        </h1>
        <Badge variant="secondary">{events.length} upcoming</Badge>
        <Badge variant="outline" className="font-normal text-muted-foreground gap-1.5 text-xs">
          <FlaskIcon weight="fill" className="size-3 text-yellow-500" /> Alpha
        </Badge>
      </div>
      <p class="text-muted-foreground text-sm">
        Public events organized by WWM players. RSVP on{" "}
        <a href="https://discord.gg/Qygt9u26Bn" class="text-foreground underline underline-offset-2 hover:text-primary transition-colors">
          Discord ↗
        </a>{" "}to get reminders.
      </p>

      <!-- Alpha notice -->
      <div class="rounded-lg border border-yellow-500/30 bg-yellow-500/5 px-4 py-3 text-sm space-y-1">
        <p><span class="font-medium text-foreground">Alpha feature.</span> <span class="text-muted-foreground">Events are synced from Discord regularly.</span></p>
        <p class="text-muted-foreground">Only <span class="font-medium text-foreground">Builder</span> and <span class="font-medium text-foreground">Critic</span> roles can create events. To organise one, create a <span class="font-medium text-foreground">Scheduled Event</span> in the server and use this format in the description:</p>
        <div class="relative mt-2 group">
          <pre id="event-template" class="rounded-md bg-muted px-3 py-2 text-xs font-mono text-foreground leading-relaxed">Guild: Jenova
Guild ID: 10244476 (optional)
Type: pvp  (tour ·  race · marriage · dancing · fashion · contest · other)

Free text description here...</pre>
          <button
            id="copy-template"
            aria-label="Copy template"
            class="absolute top-2 right-2 rounded-md p-1.5 text-muted-foreground hover:text-foreground hover:bg-background/60 transition-colors opacity-0 group-hover:opacity-100 focus:opacity-100"
          >
            <svg id="copy-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
            <svg id="check-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden text-green-500"><polyline points="20 6 9 17 4 12"/></svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Event list -->
    {
      events.length === 0 ? (
        <div class="rounded-xl border border-border bg-muted/30 px-6 py-12 text-center text-muted-foreground">
          <CalendarIcon weight="duotone" className="size-10 mx-auto mb-3 opacity-40" />
          <p class="font-medium text-foreground mb-1">No upcoming events</p>
          <p class="text-sm">Create a Scheduled Event in the Discord server to get started.</p>
        </div>
      ) : (
        <ul class="space-y-4">
          {events.map((event) => (
            <li class="rounded-xl border border-border bg-card overflow-hidden flex flex-col gap-3 hover:border-primary/40 transition-colors">
              {event.image && (
                <img src={event.image} alt={event.name} class="w-full aspect-3/1 object-cover" />
              )}
              <div class:list={["flex flex-col gap-3 px-5 pb-5", event.image ? "pt-4" : "pt-5"]}>
              <!-- Top row: title + join link -->
              <div class="flex items-start justify-between gap-3 flex-wrap">
                <div class="flex items-center gap-2 flex-wrap">
                  <h2 class="font-heading font-semibold text-base">{event.name}</h2>
                  {event.status === "active" && (
                    <Badge variant="default" className="text-xs">Live now</Badge>
                  )}
                </div>
                <a
                  href={event.discordUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="shrink-0 inline-flex items-center gap-1.5 text-xs font-medium text-primary hover:underline"
                >
                  Event on Discord <ArrowSquareOutIcon weight="bold" className="size-3.5" />
                </a>
              </div>

              <!-- Tags row: type + guild -->
              {(event.type || event.guildName) && (
                <div class="flex items-center gap-2 flex-wrap">
                  {event.type && (
                    <span class={`inline-flex items-center gap-1 rounded-full border px-2.5 py-0.5 text-xs font-medium ${TYPE_COLORS[event.type]}`}>
                      {EVENT_TYPE_EMOJI[event.type]} {EVENT_TYPE_LABELS[event.type]}
                    </span>
                  )}
                  {event.guildName && (() => {
                    const slug = (event.guildId ? guildSlugById.get(event.guildId) : undefined)
                      ?? guildSlugByName.get(event.guildName.toLowerCase())
                    return (
                      <span class="inline-flex items-center gap-1 rounded-full border border-border bg-muted/50 px-2.5 py-0.5 text-xs text-foreground font-medium">
                        <CastleTurretIcon weight="duotone" className="size-3 text-muted-foreground" />
                        {slug ? (
                          <a href={`${BASE}/guilds/${slug}`} class="hover:text-primary transition-colors">
                            {event.guildName}
                          </a>
                        ) : (
                          event.guildName
                        )}
                      </span>
                    )
                  })()}
                  {event.guildId && (
                    <span class="inline-flex items-center rounded-full border border-border bg-muted/50 px-2.5 py-0.5 text-xs text-muted-foreground font-mono">
                      #{event.guildId}
                    </span>
                  )}
                </div>
              )}

              {event.description && (
                <p class="text-sm text-muted-foreground leading-relaxed" set:html={formatDescription(event.description)} />
              )}

              <!-- Meta row: date, location, attendees -->
              <div class="flex flex-wrap gap-4 text-sm text-muted-foreground">
                <span class="flex items-center gap-1.5">
                  <CalendarIcon weight="duotone" className="size-4 shrink-0" />
                  {formatDate(event.scheduledStart)}
                  {event.scheduledEnd && ` → ${formatDate(event.scheduledEnd)}`}
                </span>
                {event.location && (
                  <span class="flex items-center gap-1.5">
                    <MapPinIcon weight="duotone" className="size-4 shrink-0" />
                    {event.location}
                  </span>
                )}
                <span class="flex items-center gap-1.5">
                  <UsersIcon weight="duotone" className="size-4 shrink-0" />
                  {event.subscriberCount} interested
                </span>
              </div>
              </div>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</Layout>

<script is:inline>
  const btn = document.getElementById("copy-template")
  const pre = document.getElementById("event-template")
  const copyIcon = document.getElementById("copy-icon")
  const checkIcon = document.getElementById("check-icon")
  if (btn && pre) {
    btn.addEventListener("click", () => {
      navigator.clipboard.writeText(pre.textContent ?? "").then(() => {
        copyIcon.classList.add("hidden")
        checkIcon.classList.remove("hidden")
        checkIcon.classList.add("text-green-500")
        setTimeout(() => {
          copyIcon.classList.remove("hidden")
          checkIcon.classList.add("hidden")
        }, 2000)
      })
    })
  }

</script>
