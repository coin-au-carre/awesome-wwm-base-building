---
import Layout from "@/layouts/main.astro"
import { Badge } from "@/components/ui/badge"
import { CalendarIcon, MapPinIcon, UsersIcon, ArrowSquareOutIcon, CastleTurretIcon, BroadcastIcon, MicrophoneStageIcon } from "@phosphor-icons/react"
import { getUpcomingEvents, EVENT_TYPE_LABELS, EVENT_TYPE_EMOJI } from "@/lib/events"
import type { EventType } from "@/lib/events"
import { BASE } from "@/lib/url"
import { getGuildsSortedByScore, getUsers } from "@/lib/guilds"

const events = getUpcomingEvents()

const BTW_EVENT = {
  url:       "https://discord.com/events/1483447710617960508/1512075806778855574",
  dateLabel: "June 6, 2026 · 20:00 UTC",
  title:     "Beyond the Wall",
  accent:    "with Carni",
  desc:      "Carni streams CN content live: solo world, family business...",
  bg:        "/events/beyond-the-wall/greenzen.jpg",
  thumb:     "/events/beyond-the-wall/luminoushall.jpg",
  status:    "past" as const,
  color:     "pink" as const,
  icon:      "🎙️",
}

const FAIRYTOPIA_EVENT = {
  url:       "https://discord.gg/Qygt9u26Bn",
  dateLabel: "Every monday at 1PM UTC",
  title:     "Fairytopia Tour",
  accent:    "",
  desc:      "Smaller community tour (~10 people) to visit solo world & guilds",
  bg:        "/events/beyond-the-wall/flower_house.jpg",
  thumb:     "",
  status:    "soon" as const,
  color:     "purple" as const,
  icon:      "✨",
}

const PANDA_TOUR_EVENT = {
  url:       "https://discord.gg/Qygt9u26Bn",
  dateLabel: "Every Wednesday at 5 PM UTC",
  title:     "Panda Guild Tour",
  accent:    "",
  desc:      "Community guild tours of fresh builds!",
  bg:        "/events/beyond-the-wall/palace.jpg",
  thumb:     "",
  status:    "soon" as const,
  color:     "amber" as const,
  icon:      "🗺️",
}

const _allGuilds = getGuildsSortedByScore()
const guildSlugById = new Map(_allGuilds.filter((g) => g.id).map((g) => [g.id!, g.slug]))
const guildSlugByName = new Map(_allGuilds.map((g) => [(g.guildName ?? g.name).toLowerCase(), g.slug]))
const guildNameBySlug = new Map(_allGuilds.map((g) => [g.slug, g.guildName ?? g.name]))

const _users = getUsers()

function formatDescription(text: string): string {
  const resolved = text.replace(/<@(\d+)>/g, (_, id) => {
    const u = _users[id]
    return u ? `@${u.nickname ?? u.globalName ?? u.username}` : `<@${id}>`
  })
  const escaped = resolved
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
  // markdown links first: [label](url)
  const mdLinked = escaped.replace(
    /\[([^\]]+)\]\((https?:\/\/[^)]+)\)/g,
    '<a href="$2" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline break-all">$1</a>',
  )
  // bare URLs — skip ones already inside href="..."
  const linked = mdLinked.replace(
    /(?<!href=")(https?:\/\/[^\s<"]+)/g,
    '<a href="$1" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline break-all">$1</a>',
  )
  return linked.replace(/\n/g, "<br>")
}

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString("en-US", {
    weekday: "short",
    month: "short",
    day: "numeric",
    hour: "2-digit",
    minute: "2-digit",
    timeZoneName: "short",
  })
}

const TYPE_COLORS: Record<EventType, string> = {
  tour:     "bg-blue-500/10 text-blue-600 dark:text-blue-400 border-blue-500/20",
  pvp:      "bg-red-500/10 text-red-600 dark:text-red-400 border-red-500/20",
  marriage: "bg-pink-500/10 text-pink-600 dark:text-pink-400 border-pink-500/20",
  dancing:  "bg-purple-500/10 text-purple-600 dark:text-purple-400 border-purple-500/20",
  fashion:  "bg-fuchsia-500/10 text-fuchsia-600 dark:text-fuchsia-400 border-fuchsia-500/20",
  contest:  "bg-yellow-500/10 text-yellow-600 dark:text-yellow-500 border-yellow-500/20",
  race:      "bg-orange-500/10 text-orange-600 dark:text-orange-400 border-orange-500/20",
  streaming: "bg-sky-500/10 text-sky-600 dark:text-sky-400 border-sky-500/20",
  other:     "bg-muted text-muted-foreground border-border",
}
---

<Layout
  title="Where Builders Meet | Upcoming Events in Where Winds Meet Guild Bases"
  description="Upcoming player-organized events in Where Winds Meet guild bases — tours, PvP, contests, and more. Find events open to the community."
>
  <div class="max-w-3xl space-y-8">
    <!-- Header -->
    <div class="flex flex-col gap-3">
      <div class="flex items-center gap-3 flex-wrap">
        <h1 class="font-heading text-2xl font-semibold flex items-center gap-2">
          <CalendarIcon weight="duotone" className="size-6 text-primary" /> Events
        </h1>
        <Badge id="events-count" variant="secondary">{events.length} upcoming</Badge>
      </div>
      <p class="text-muted-foreground text-sm">
        Public events organized by WWM players. RSVP on{" "}
        <a href="https://discord.gg/Qygt9u26Bn" class="text-foreground underline underline-offset-2 hover:text-primary transition-colors" data-umami-event="discord_cta_click">
          Discord ↗
        </a>{" "}to get reminders.
      </p>

      <!-- Post an event -->
      <details class="group rounded-lg border border-yellow-500/30 bg-yellow-500/5 text-sm">
        <summary class="flex cursor-pointer items-center justify-between gap-2 px-4 py-3 marker:content-none">
          <span class="font-medium text-foreground">Want to post an event?</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-muted-foreground transition-transform group-open:rotate-180"><polyline points="6 9 12 15 18 9"/></svg>
        </summary>
        <div class="px-4 pb-3 space-y-3">
          <p class="text-muted-foreground">Requires the <span class="font-medium text-foreground">Builder</span> or <span class="font-medium text-foreground">Critic</span> role in <a href="https://discord.gg/Qygt9u26Bn" target="_blank" rel="noopener noreferrer" class="text-foreground underline underline-offset-2 hover:text-primary transition-colors" data-umami-event="discord_events_cta_click">our Discord ↗</a>. Create a Scheduled Event — the description is yours to write. To tag it, end with <code class="font-mono text-xs bg-muted rounded px-1 py-0.5">Type: tour</code> (or any below):</p>
          <div class="flex flex-wrap gap-2">
            {(Object.keys(TYPE_COLORS) as EventType[]).map((type) => (
              <span class={`inline-flex items-center gap-1.5 rounded-full border px-3 py-1 text-xs font-medium ${TYPE_COLORS[type]}`}>
                {EVENT_TYPE_EMOJI[type]} {EVENT_TYPE_LABELS[type]}
              </span>
            ))}
          </div>
          <p class="text-muted-foreground text-xs">It will appear on this page automatically.</p>
        </div>
      </details>
    </div>

    <!-- WBM Organized Events -->
    <section>
      <h2 class="font-heading text-base font-semibold mb-3 flex items-center gap-2 pl-3 border-l-2 border-violet-500/60">
        <svg class="size-4 text-violet-500 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
        WBM Events
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">

        <!-- Beyond the Wall -->
        <a
          href={BTW_EVENT.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative flex flex-col justify-end rounded-xl overflow-hidden ring-1 ring-pink-500/30 hover:ring-pink-500/60 hover:shadow-lg transition-all h-36 opacity-80 hover:opacity-100"
          data-umami-event="wbm_event_card_click"
          data-umami-event-name="beyond_the_wall"
        >
          <div
            class="absolute inset-0 bg-cover bg-center"
            style={`background-image: url('${BTW_EVENT.bg}'); filter: brightness(0.35) saturate(0.6);`}
          />
          <div class="absolute inset-0 bg-linear-to-t from-black/90 via-black/50 to-black/10" />
          <div class="relative z-10 flex flex-col gap-1 px-4 pb-4 pt-3">
            <div class="flex items-center gap-1.5">
              <span class="size-1.5 rounded-full shrink-0 bg-pink-400/60" />
              <span class="text-[10px] font-semibold uppercase tracking-widest text-pink-400/80">
                Past · {BTW_EVENT.dateLabel}
              </span>
            </div>
            <p class="text-sm font-bold text-white/90 leading-tight drop-shadow">
              {BTW_EVENT.icon} {BTW_EVENT.title} <span class="font-normal text-pink-300">{BTW_EVENT.accent}</span>
            </p>
            <p class="text-xs text-white/55 leading-snug line-clamp-2">{BTW_EVENT.desc}</p>
            <span class="mt-1 self-start inline-flex items-center gap-1 bg-pink-500/15 ring-1 ring-pink-500/30 rounded-full px-2.5 py-0.5 text-[11px] text-pink-300/80">
              View on Discord ↗
            </span>
          </div>
        </a>

        <!-- Panda Guild Tour -->
        <a
          href={PANDA_TOUR_EVENT.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative flex flex-col justify-end rounded-xl overflow-hidden ring-1 ring-amber-500/40 hover:ring-amber-500/70 hover:shadow-lg transition-all h-36"
          data-umami-event="wbm_event_card_click"
          data-umami-event-name="panda_guild_tour"
        >
          <div
            class="absolute inset-0 bg-cover bg-center"
            style={`background-image: url('${PANDA_TOUR_EVENT.bg}'); filter: brightness(0.4) saturate(0.7);`}
          />
          <div class="absolute inset-0 bg-linear-to-t from-black/90 via-black/50 to-black/10" />
          <div class="relative z-10 flex flex-col gap-1 px-4 pb-4 pt-3">
            <div class="flex items-center gap-1.5">
              <span class="size-1.5 rounded-full shrink-0 bg-amber-400 animate-pulse" />
              <span class="text-[10px] font-semibold uppercase tracking-widest text-amber-400">
                {PANDA_TOUR_EVENT.dateLabel}
              </span>
            </div>
            <p class="text-sm font-bold text-white leading-tight drop-shadow">
              {PANDA_TOUR_EVENT.icon} {PANDA_TOUR_EVENT.title}
            </p>
            <p class="text-xs text-white/60 leading-snug line-clamp-2">{PANDA_TOUR_EVENT.desc}</p>
            <span class="mt-1 self-start inline-flex items-center gap-1 bg-amber-500/20 ring-1 ring-amber-500/50 rounded-full px-2.5 py-0.5 text-[11px] font-semibold text-amber-200 group-hover:bg-amber-500/35 transition-colors">
              Follow on Discord ↗
            </span>
          </div>
        </a>

        <!-- Fairytopia Tour -->
        <a
          href={FAIRYTOPIA_EVENT.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative flex flex-col justify-end rounded-xl overflow-hidden ring-1 ring-purple-500/40 hover:ring-purple-500/70 hover:shadow-lg transition-all h-36"
          data-umami-event="wbm_event_card_click"
          data-umami-event-name="fairytopia_tour"
        >
          <div
            class="absolute inset-0 bg-cover bg-center"
            style={`background-image: url('${FAIRYTOPIA_EVENT.bg}'); filter: brightness(0.35) saturate(0.6);`}
          />
          <div class="absolute inset-0 bg-linear-to-t from-black/90 via-black/50 to-black/10" />
          <div class="relative z-10 flex flex-col gap-1 px-4 pb-4 pt-3">
            <div class="flex items-center gap-1.5">
              <span class="size-1.5 rounded-full shrink-0 bg-purple-400 animate-pulse" />
              <span class="text-[10px] font-semibold uppercase tracking-widest text-purple-400">
                Every Monday 1PM UTC
              </span>
            </div>
            <p class="text-sm font-bold text-white leading-tight drop-shadow">
              {FAIRYTOPIA_EVENT.icon} {FAIRYTOPIA_EVENT.title}
            </p>
            <p class="text-xs text-white/60 leading-snug line-clamp-2">{FAIRYTOPIA_EVENT.desc}</p>
            <span class="mt-1 self-start inline-flex items-center gap-1 bg-purple-500/20 ring-1 ring-purple-500/50 rounded-full px-2.5 py-0.5 text-[11px] font-semibold text-purple-200 group-hover:bg-purple-500/35 transition-colors">
              Follow on Discord ↗
            </span>
          </div>
        </a>

      </div>
    </section>

    <!-- Event list -->
    <div id="events-empty" class:list={["rounded-xl border border-border bg-muted/30 px-6 py-12 text-center text-muted-foreground", events.length > 0 && "hidden"]}>
      <CalendarIcon weight="duotone" className="size-10 mx-auto mb-3 opacity-40" />
      <p class="font-medium text-foreground mb-1">No upcoming events</p>
      <p class="text-sm">Create a Scheduled Event in the Discord server to get started.</p>
    </div>
    {events.length > 0 && (
      <ul id="events-list" class="space-y-4">
        {events.map((event) => (
            <li data-event data-end={event.scheduledEnd ?? ""} class="rounded-xl border border-border bg-card overflow-hidden flex flex-col gap-3 hover:border-primary/40 transition-colors">
              {event.image && (
                <img src={event.image} alt={event.name} class="w-full aspect-3/1 object-cover" />
              )}
              <div class:list={["flex flex-col gap-3 px-5 pb-5", event.image ? "pt-4" : "pt-5"]}>
              <!-- Top row: title + join link -->
              <div class="flex items-start justify-between gap-3 flex-wrap">
                <div class="flex items-center gap-2 flex-wrap">
                  <h2 class="font-heading font-semibold text-base">{event.name}</h2>
                  {event.status === "active" && (
                    <Badge variant="default" className="text-xs">Live now</Badge>
                  )}
                </div>
                <a
                  href={event.discordUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="shrink-0 inline-flex items-center gap-1.5 text-xs font-medium text-primary hover:underline"
                >
                  Register on Discord <ArrowSquareOutIcon weight="bold" className="size-3.5" />
                </a>
              </div>

              <!-- Tags row: guild + type -->
              {(event.type || event.guildName || event.guildSlug || event.guildId) && (
                <div class="flex items-center gap-2 flex-wrap">
                  {(event.guildName || event.guildSlug) && (() => {
                    const slug = event.guildSlug
                      ?? (event.guildId ? guildSlugById.get(event.guildId) : undefined)
                      ?? (event.guildName ? guildSlugByName.get(event.guildName.toLowerCase()) : undefined)
                    const displayName = event.guildName
                      ?? (event.guildSlug ? guildNameBySlug.get(event.guildSlug) : undefined)
                      ?? event.guildSlug
                    return (
                      <span class="inline-flex items-center gap-1.5 rounded-full border border-violet-500/20 bg-violet-500/10 px-3 py-1 text-sm text-violet-700 dark:text-violet-300 font-medium ring-1 ring-inset ring-violet-400/20">
                        <CastleTurretIcon weight="duotone" className="size-3.5 shrink-0" />
                        {slug ? (
                          <a href={`${BASE}/guilds/${slug}`} class="hover:text-violet-900 dark:hover:text-violet-100 transition-colors">
                            {displayName}
                          </a>
                        ) : (
                          displayName
                        )}
                      </span>
                    )
                  })()}
                  {event.guildId && (
                    <span
                      class="inline-flex items-center gap-1.5 rounded-full border border-border bg-muted/50 px-3 py-1 text-sm text-muted-foreground font-mono ring-1 ring-inset ring-border/60 cursor-pointer select-none"
                      style="transition: color 0.4s ease, border-color 0.4s ease, background-color 0.4s ease"
                      onclick={`navigator.clipboard.writeText('${event.guildId}'); this.style.color='#4ade80'; this.style.borderColor='#4ade8066'; this.style.backgroundColor='#4ade8011'; setTimeout(() => { this.style.color=''; this.style.borderColor=''; this.style.backgroundColor=''; }, 800)`}
                      title="Copy guild ID"
                    >
                      {event.guildId}
                      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 256 256" fill="currentColor"><path d="M216,32H88a8,8,0,0,0-8,8V80H40a8,8,0,0,0-8,8V216a8,8,0,0,0,8,8H168a8,8,0,0,0,8-8V176h40a8,8,0,0,0,8-8V40A8,8,0,0,0,216,32ZM160,208H48V96H160Zm48-48H176V88a8,8,0,0,0-8-8H96V48H208Z"/></svg>
                    </span>
                  )}
                  {event.type && (
                    <span class={`inline-flex items-center gap-1.5 rounded-full border px-3 py-1 text-sm font-medium ${TYPE_COLORS[event.type]}`}>
                      {EVENT_TYPE_EMOJI[event.type]} {EVENT_TYPE_LABELS[event.type]}
                    </span>
                  )}
                </div>
              )}

              {event.description && (
                <p class="text-sm text-muted-foreground leading-relaxed" set:html={formatDescription(event.description)} />
              )}

              <!-- Meta row: date, location, attendees -->
              <div class="flex flex-wrap gap-4 text-sm text-muted-foreground">
                <span class="flex items-center gap-1.5">
                  <CalendarIcon weight="duotone" className="size-4 shrink-0" />
                  {formatDate(event.scheduledStart)}
                  {event.scheduledEnd && ` → ${formatDate(event.scheduledEnd)}`}
                </span>
                {event.channelType === "voice" && (
                  <span class="flex items-center gap-1.5">
                    <BroadcastIcon weight="duotone" className="size-4 shrink-0" />
                    {event.channelName ?? "Voice channel"}
                  </span>
                )}
                {event.channelType === "stage" && (
                  <span class="flex items-center gap-1.5">
                    <MicrophoneStageIcon weight="duotone" className="size-4 shrink-0" />
                    {event.channelName ?? "Stage channel"}
                  </span>
                )}
                {!event.channelType && event.location && (
                  <span class="flex items-center gap-1.5">
                    <MapPinIcon weight="duotone" className="size-4 shrink-0" />
                    {event.location}
                  </span>
                )}
                <span class="flex items-center gap-1.5">
                  <UsersIcon weight="duotone" className="size-4 shrink-0" />
                  {event.subscriberCount} interested
                </span>
              </div>
              </div>
            </li>
          ))}
        </ul>
    )}
  </div>
</Layout>

<script>
  function init() {
    const now = Date.now()
    let visible = 0
    document.querySelectorAll<HTMLElement>("[data-event]").forEach((el) => {
      const end = el.dataset.end
      if (end && new Date(end).getTime() <= now) {
        el.remove()
      } else {
        visible++
      }
    })
    const badge = document.getElementById("events-count")
    if (badge) badge.textContent = `${visible} upcoming`
    if (visible === 0) {
      document.getElementById("events-list")?.remove()
      document.getElementById("events-empty")?.classList.remove("hidden")
    }
  }
  document.addEventListener("astro:page-load", init)
</script>
