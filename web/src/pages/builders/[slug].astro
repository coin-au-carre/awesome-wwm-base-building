---
import Layout from "@/layouts/main.astro"
import { getCollection } from "astro:content"
import { getAllBuilderSlugs, getBuilderProfile } from "@/lib/builders"
import { builderSlug, stripGuildShowcase, thumbUrl } from "@/lib/format"
import { resolveCanonical, BUILDER_IDENTITIES } from "@/lib/builder-aliases"
import { BASE } from "@/lib/url"
import { BlueprintIcon, BookOpenIcon, CalculatorIcon, CompassIcon, HammerIcon, HouseIcon, MedalIcon, PlayCircleIcon, UsersThreeIcon } from "@phosphor-icons/react"
import { BuilderMedia } from "@/components/BuilderMedia"
import { getGuildsSortedByScore, getSolosSortedByScore, getUsers } from "@/lib/guilds"
import { HOMESTEAD_SHEETS } from "@/lib/homestead-resources"
import { BuilderGallerySection } from "@/components/BuilderGallerySection"
import { BuilderProfileHeader } from "@/components/BuilderProfileHeader"
import { ShareButton } from "@/components/GalleryGrid"
import { BackLink, GalleryLink } from "@/components/BackLink"
import { Badge } from "@/components/ui/badge"
import { buttonVariants } from "@/components/ui/button"

export async function getStaticPaths() {
  const builderSlugs = getAllBuilderSlugs()
  const allArticles = await getCollection("articles", ({ data }) => data.published !== false)

  const slugMap = new Map(builderSlugs.map((b) => [b.slug, b]))
  for (const article of allArticles) {
    for (const authorName of article.data.authors ?? []) {
      const rawSlug = builderSlug(authorName)
      const s = resolveCanonical(rawSlug)
      if (!s) continue
      const existing = slugMap.get(s)
      // Prefer the name whose slug matches the canonical (not an alias form)
      if (!existing || builderSlug(existing.name) !== s) {
        slugMap.set(s, { name: authorName, slug: s })
      }
    }
  }
  for (const sheet of HOMESTEAD_SHEETS) {
    const s = resolveCanonical(builderSlug(sheet.by))
    if (!s) continue
    if (!slugMap.has(s)) slugMap.set(s, { name: sheet.by, slug: s })
  }
  // A builder can register via /wwm-uid before ever having a guild/solo/
  // blueprint credit synced — without this, their page would 404 even
  // though data/builder_identities.json already knows their canonicalSlug
  // (see docs/builder-identity.md's "merging the two builder-profile
  // systems").
  for (const identity of BUILDER_IDENTITIES) {
    if (!slugMap.has(identity.canonicalSlug)) {
      slugMap.set(identity.canonicalSlug, { name: identity.canonicalAlias, slug: identity.canonicalSlug })
    }
  }

  return [...slugMap.values()].map(({ name, slug }) => ({
    params: { slug },
    props: { builderName: name },
  }))
}

const { builderName } = Astro.props
const slug = Astro.params.slug as string
const profile = getBuilderProfile(slug)
const canonical = resolveCanonical(slug)

const allArticles = await getCollection("articles", ({ data }) => data.published !== false)
const tutorials = allArticles.filter((a) =>
  (a.data.authors ?? []).some((n) => resolveCanonical(builderSlug(n)) === canonical)
)


const displayName = profile?.name ?? builderName

// The matching builder_identities.json record, if this builder ever
// registered via /wwm-uid — gives us a real discordId, a linked
// neteaseNumberId (powers the "NetEase Gallery" section below, see
// docs/builder-identity.md), and the properly-cased canonicalAlias/aliases
// (getAllSlugsForCanonical only has the slugified forms, fine for
// matching but not for display).
const identity = BUILDER_IDENTITIES.find((e) => e.canonicalSlug === canonical)
const linkedNumberId = identity?.neteaseNumberId

// Fall back to matching their name slug against the users map when there's
// no registered discordId yet (e.g. only credited via a guild/solo build).
const users = getUsers()
const scoutDiscordId = identity?.discordId ?? Object.entries(users).find(([, u]) => {
  const name = u.nickname ?? u.globalName ?? u.username
  return name && resolveCanonical(builderSlug(name)) === canonical
})?.[0]
const discordName = scoutDiscordId
  ? users[scoutDiscordId]?.nickname ?? users[scoutDiscordId]?.globalName ?? users[scoutDiscordId]?.username
  : undefined
const scoutedGuilds = scoutDiscordId
  ? getGuildsSortedByScore().filter((g) => g.scoutedByDiscordId === scoutDiscordId)
  : []
const scoutedSolos = scoutDiscordId
  ? getSolosSortedByScore().filter((g) => g.scoutedByDiscordId === scoutDiscordId)
  : []
const scoutedCount = scoutedGuilds.length + scoutedSolos.length

const totalCount = (profile?.guilds.length ?? 0) + (profile?.solos.length ?? 0) + (profile?.blueprints.length ?? 0) + (profile?.homesteadSheets.length ?? 0) + tutorials.length

// Properly-cased canonical alias + other aliases from builder_identities.json,
// excluding whichever one is already the display name or the Discord name
// (case-insensitive) — avoids "X also known as X" and "Discord: X also
// known as x".
const aliasNames = [...new Set([identity?.canonicalAlias, ...(identity?.aliases ?? [])])]
  .filter((name): name is string => Boolean(name) && name !== displayName)
  .filter((name) => !discordName || name.toLowerCase() !== discordName.toLowerCase())

// Combined into one line under the name rather than two separate lines —
// omits whichever half (Discord name / aliases) doesn't apply.
const identityLine = [
  discordName && discordName !== displayName ? `Discord: ${discordName}` : null,
  aliasNames.length > 0 ? `also known as ${aliasNames.join(", ")}` : null,
]
  .filter(Boolean)
  .join(" ")

const tagCounts = new Map<string, number>()
for (const g of [...(profile?.guilds ?? []), ...(profile?.solos ?? [])]) {
  for (const tag of g.tags ?? []) tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1)
}
const topTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]).map(([tag]) => tag)
const contributionTypes = [(profile?.guilds.length ?? 0) > 0, (profile?.solos.length ?? 0) > 0, (profile?.blueprints.length ?? 0) > 0, (profile?.homesteadSheets.length ?? 0) > 0, tutorials.length > 0].filter(Boolean).length
const initial = displayName.trim()[0]?.toUpperCase() ?? "?"
const pageDesc = `Builder profile for ${displayName} in Where Winds Meet. ${totalCount} contribution${totalCount !== 1 ? "s" : ""} including guild bases, solo builds, blueprints, and tutorials.`

const ogImage = [...(profile?.guilds ?? []), ...(profile?.solos ?? []), ...(profile?.blueprints ?? [])]
  .map((entry) => entry.coverImage ?? entry.screenshots?.[0])
  .find(Boolean)

---

<Layout
  title={`${displayName} — Builder Profile | Where Builders Meet`}
  description={pageDesc}
  image={ogImage}
  fullWidth
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "ProfilePage",
        "name": `${displayName} — Builder Profile`,
        "description": pageDesc,
        "url": Astro.url.href,
        "mainEntity": {
          "@type": "Person",
          "name": displayName,
          "url": Astro.url.href,
          "description": pageDesc,
        },
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Where Builders Meet", "item": "https://www.wherebuildersmeet.com" },
          { "@type": "ListItem", "position": 2, "name": displayName, "item": Astro.url.href },
        ],
      },
    ],
  })} />
  <div class="space-y-8">
    <!-- Back -->
    <div class="flex flex-wrap items-center gap-2">
      <BackLink client:load />
      <GalleryLink client:load />
      <a href={`${BASE}/builders`} class={buttonVariants({ variant: "outline", size: "sm" })}>
        <UsersThreeIcon weight="bold" className="size-3.5" /> The Builders Directory
      </a>
      <ShareButton client:load label="Share profile" />
      <Badge variant="outline" className="gap-1.5 py-1">
        <img src="/images/logo_1.webp" alt="" aria-hidden="true" class="size-3.5 object-contain" />
        WBM Builder
      </Badge>
    </div>

    <!-- Header -->
    <div class="mb-4">
    <BuilderProfileHeader client:visible numberId={linkedNumberId} slug={slug} displayName={displayName} initial={initial} subtitle={identityLine || undefined}>
        <div class="flex flex-wrap items-center gap-2 mt-2">
          {profile && profile.guilds.length > 0 && (
            <span class="inline-flex items-center gap-1.5 text-xs font-medium rounded-full px-2.5 py-1 bg-violet-500/10 text-violet-600 dark:text-violet-300 ring-1 ring-inset ring-violet-500/25">
              <HammerIcon weight="duotone" className="size-3.5 shrink-0" />
              Guild Base Builder
              <span class="text-[10px] opacity-60 font-normal">· {profile.guilds.length}</span>
            </span>
          )}
          {profile && profile.solos.length > 0 && (
            <span class="inline-flex items-center gap-1.5 text-xs font-medium rounded-full px-2.5 py-1 bg-teal-500/10 text-teal-600 dark:text-teal-300 ring-1 ring-inset ring-teal-500/25">
              <HouseIcon weight="duotone" className="size-3.5 shrink-0" />
              Solo Builder
              <span class="text-[10px] opacity-60 font-normal">· {profile.solos.length}</span>
            </span>
          )}
          {profile && profile.blueprints.length > 0 && (
            <span class="inline-flex items-center gap-1.5 text-xs font-medium rounded-full px-2.5 py-1 bg-blue-500/10 text-blue-600 dark:text-blue-300 ring-1 ring-inset ring-blue-500/25">
              <BlueprintIcon weight="duotone" className="size-3.5 shrink-0" />
              Blueprint Creator
              <span class="text-[10px] opacity-60 font-normal">· {profile.blueprints.length}</span>
            </span>
          )}
          {profile && profile.homesteadSheets.length > 0 && (
            <span class="inline-flex items-center gap-1.5 text-xs font-medium rounded-full px-2.5 py-1 bg-orange-500/10 text-orange-600 dark:text-orange-300 ring-1 ring-inset ring-orange-500/25">
              <CalculatorIcon weight="duotone" className="size-3.5 shrink-0" />
              Homestead Sheet
              <span class="text-[10px] opacity-60 font-normal">· {profile.homesteadSheets.length}</span>
            </span>
          )}
          {tutorials.length > 0 && (
            <span class="inline-flex items-center gap-1.5 text-xs font-medium rounded-full px-2.5 py-1 bg-pink-500/10 text-pink-600 dark:text-pink-300 ring-1 ring-inset ring-pink-500/25">
              <BookOpenIcon weight="duotone" className="size-3.5 shrink-0" />
              Tutorial Author
              <span class="text-[10px] opacity-60 font-normal">· {tutorials.length}</span>
            </span>
          )}
          {contributionTypes >= 2 && (
            <span class="inline-flex items-center gap-1.5 text-xs font-medium rounded-full px-2.5 py-1 bg-amber-500/10 text-amber-600 dark:text-amber-400 ring-1 ring-inset ring-amber-500/25">
              <MedalIcon weight="duotone" className="size-3.5 shrink-0" />
              Community Contributor
            </span>
          )}
          {scoutedCount > 0 && (
            <span class="inline-flex items-center gap-1.5 text-xs font-medium rounded-full px-2.5 py-1 bg-emerald-500/10 text-emerald-600 dark:text-emerald-300 ring-1 ring-inset ring-emerald-500/25">
              <CompassIcon weight="duotone" className="size-3.5 shrink-0" />
              Guild Cartographer
              <span class="text-[10px] opacity-60 font-normal">· {scoutedCount}</span>
            </span>
          )}
        </div>
        {topTags.length > 0 && (
          <div class="flex flex-wrap gap-1.5 mt-3">
            {topTags.map((tag) => (
              <span class="inline-flex items-center rounded-full bg-muted px-2.5 py-0.5 text-[11px] text-muted-foreground ring-1 ring-inset ring-border">{tag}</span>
            ))}
          </div>
        )}
    </BuilderProfileHeader>
    </div>

    <!-- Blueprints -->
    {profile && profile.blueprints.length > 0 && (
      <section>
        <h2 class="font-heading text-base font-medium mb-4 flex items-center gap-2">
          <BlueprintIcon weight="duotone" className="size-4 text-primary" />
          Blueprints
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {profile.blueprints.map((bp) => {
            const img = bp.coverImage ?? bp.screenshots?.[0]
            return (
              <a
                href={`${BASE}/blueprints`}
                class="group flex items-center gap-3 rounded-xl ring-1 ring-border bg-card hover:ring-primary transition-all px-3 py-2.5"
                data-umami-event="builder_profile_blueprint_click"
                data-umami-event-name={bp.name}
              >
                {img ? (
                  <div class="relative shrink-0 w-20 aspect-video rounded-md overflow-hidden bg-muted">
                    <img src={thumbUrl(img)} alt={bp.name} loading="lazy" onerror="this.style.display='none'" class="absolute inset-0 h-full w-full object-cover" />
                  </div>
                ) : (
                  <div class="shrink-0 w-20 aspect-video rounded-md bg-primary/5 flex items-center justify-center">
                    <BlueprintIcon weight="duotone" className="size-5 text-primary/50" />
                  </div>
                )}
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-medium leading-tight">{bp.name}</p>
                  {bp.price && (
                    <p class="text-xs text-muted-foreground mt-0.5">{bp.isFree ? "Free" : bp.price}</p>
                  )}
                </div>
                <svg class="size-3.5 shrink-0 text-muted-foreground/40 group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </a>
            )
          })}
        </div>
      </section>
    )}

    <!-- Media: this builder's own channels/videos from videos.ts (see
         lib/builders.ts's getBuilderProfile for the matching). Distinct
         from the Tutorials section further down, which is site-hosted
         written articles, not external video/channel links. Placed
         ahead of Guild Bases on request. -->
    {profile && profile.channels.length > 0 && (
      <section>
        <h2 class="font-heading text-base font-medium mb-3 flex items-center gap-2">
          <PlayCircleIcon weight="duotone" className="size-4 text-red-500" />
          Media
        </h2>
        <BuilderMedia channels={profile.channels} />
      </section>
    )}

    <!-- Guild bases -->
    {profile && profile.guilds.length > 0 && (
      <section>
        <h2 class="font-heading text-base font-medium mb-4 flex items-center gap-2">
          <img src="/images/logo_1.webp" alt="" aria-hidden="true" class="size-7 object-contain" />
          Guild Bases
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          {profile.guilds.map((g) => {
            const img = g.coverImage ?? g.screenshots?.[0]
            return img ? (
              <a
                href={`${BASE}/guilds/${g.slug}`}
                class="group relative overflow-hidden rounded-xl ring-1 ring-border aspect-video bg-muted hover:ring-primary transition-all"
                data-umami-event="builder_profile_guild_click"
                data-umami-event-name={g.name}
              >
                <img
                  src={thumbUrl(img)}
                  alt={stripGuildShowcase(g.name)}
                  loading="lazy"
                  onerror="this.style.display='none'"
                  class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-linear-to-t from-black/70 to-transparent" />
                <div class="absolute bottom-0 left-0 right-0 p-3">
                  <p class="text-white font-medium text-sm leading-tight mb-1">
                    {stripGuildShowcase(g.name)}
                    {g.buildTitle && <span class="font-normal text-white/55 ml-1">— {g.buildTitle}</span>}
                  </p>
                  {g.tags && g.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1">
                      {g.tags.slice(0, 3).map((tag) => (
                        <span class="inline-flex items-center rounded-full bg-white/10 backdrop-blur-sm px-2 py-0.5 text-[10px] text-white/80">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
              </a>
            ) : (
              <a
                href={`${BASE}/guilds/${g.slug}`}
                class="group flex items-center gap-3 rounded-xl ring-1 ring-border bg-card hover:ring-primary transition-all px-3 py-2.5"
                data-umami-event="builder_profile_guild_click"
                data-umami-event-name={g.name}
              >
                <div class="shrink-0 w-20 aspect-video rounded-md bg-violet-500/10 flex items-center justify-center">
                  <img src="/images/logo_1.webp" alt="" aria-hidden="true" class="size-6 object-contain opacity-70" />
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-medium leading-tight truncate">
                    {stripGuildShowcase(g.name)}
                    {g.buildTitle && <span class="font-normal text-muted-foreground ml-1">— {g.buildTitle}</span>}
                  </p>
                  {g.tags && g.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1 mt-1">
                      {g.tags.slice(0, 3).map((tag) => (
                        <span class="inline-flex items-center rounded-full bg-muted px-2 py-0.5 text-[10px] text-muted-foreground">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
                <svg class="size-3.5 shrink-0 text-muted-foreground/40 group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </a>
            )
          })}
        </div>
      </section>
    )}

    <!-- Solo builds -->
    {profile && profile.solos.length > 0 && (
      <section>
        <h2 class="font-heading text-base font-medium mb-4 flex items-center gap-2">
          <img src="/images/logo_2.webp" alt="" aria-hidden="true" class="size-7 object-contain" />
          Solo Builds
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          {profile.solos.map((g) => {
            const img = g.coverImage ?? g.screenshots?.[0]
            return img ? (
              <a
                href={`${BASE}/solos/${g.slug}`}
                class="group relative overflow-hidden rounded-xl ring-1 ring-border aspect-video bg-muted hover:ring-primary transition-all"
                data-umami-event="builder_profile_solo_click"
                data-umami-event-name={g.name}
              >
                <img
                  src={thumbUrl(img)}
                  alt={g.name}
                  loading="lazy"
                  onerror="this.style.display='none'"
                  class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-linear-to-t from-black/70 to-transparent" />
                <div class="absolute bottom-0 left-0 right-0 p-3">
                  <p class="text-white font-medium text-sm leading-tight mb-1">{g.name}</p>
                  {g.tags && g.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1">
                      {g.tags.slice(0, 3).map((tag) => (
                        <span class="inline-flex items-center rounded-full bg-white/10 backdrop-blur-sm px-2 py-0.5 text-[10px] text-white/80">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
              </a>
            ) : (
              <a
                href={`${BASE}/solos/${g.slug}`}
                class="group flex items-center gap-3 rounded-xl ring-1 ring-border bg-card hover:ring-primary transition-all px-3 py-2.5"
                data-umami-event="builder_profile_solo_click"
                data-umami-event-name={g.name}
              >
                <div class="shrink-0 w-20 aspect-video rounded-md bg-teal-500/10 flex items-center justify-center">
                  <img src="/images/logo_2.webp" alt="" aria-hidden="true" class="size-6 object-contain opacity-70" />
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-medium leading-tight truncate">{g.name}</p>
                  {g.tags && g.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1 mt-1">
                      {g.tags.slice(0, 3).map((tag) => (
                        <span class="inline-flex items-center rounded-full bg-muted px-2 py-0.5 text-[10px] text-muted-foreground">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
                <svg class="size-3.5 shrink-0 text-muted-foreground/40 group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </a>
            )
          })}
        </div>
      </section>
    )}

    <!-- Homestead Sheets -->
    {profile && profile.homesteadSheets.length > 0 && (
      <section>
        <h2 class="font-heading text-base font-medium mb-4 flex items-center gap-2">
          <CalculatorIcon weight="duotone" className="size-4 text-orange-500" />
          Homestead Sheets
        </h2>
        <div class="flex flex-col gap-2">
          {profile.homesteadSheets.map((sheet) => (
            <a
              href={sheet.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-3 rounded-xl ring-1 ring-orange-500/25 bg-card hover:ring-orange-500/50 hover:shadow-sm transition-all px-3 py-2.5"
              data-umami-event="builder_profile_homestead_sheet_click"
              data-umami-event-name={sheet.title}
            >
              <div class="shrink-0 w-20 aspect-video rounded-md bg-orange-500/10 flex items-center justify-center">
                <CalculatorIcon weight="duotone" className="size-5 text-orange-400" />
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium leading-tight">{sheet.title}</p>
                <p class="text-xs text-muted-foreground mt-0.5">{sheet.description}</p>
              </div>
              <svg class="size-3.5 shrink-0 text-muted-foreground/40 group-hover:text-orange-500 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Tutorials -->
    {tutorials.length > 0 && (
      <section>
        <h2 class="font-heading text-base font-medium mb-4 flex items-center gap-2">
          <BookOpenIcon weight="duotone" className="size-4 text-pink-500" />
          Tutorials
        </h2>
        <div class="flex flex-col gap-2">
          {tutorials.map((article) => {
            const body = article.body ?? ""
            const ytID = body.match(/youtube\.com\/embed\/([^"?\s]+)/)?.[1] ?? ""
            const firstImg = body.match(/<img[^>]+src=["']([^"']+)["']/)?.[1] ?? ""
            const thumb = ytID ? `https://img.youtube.com/vi/${ytID}/hqdefault.jpg` : (article.data.image ?? firstImg)
            return (
              <a
                href={`${BASE}/tutorials/${article.id}`}
                class="group flex items-center gap-3 rounded-xl ring-1 ring-pink-500/25 bg-card hover:ring-pink-500/50 hover:shadow-sm transition-all px-3 py-2.5"
                data-umami-event="builder_profile_tutorial_click"
                data-umami-event-name={article.data.title}
              >
                {thumb ? (
                  <div class="relative shrink-0 w-20 aspect-video rounded-md overflow-hidden bg-black">
                    <img src={thumb} alt={article.data.title} loading="lazy" class="absolute inset-0 h-full w-full object-cover" />
                  </div>
                ) : (
                  <div class="shrink-0 w-20 aspect-video rounded-md bg-pink-500/10 flex items-center justify-center">
                    <BookOpenIcon weight="duotone" className="size-5 text-pink-400" />
                  </div>
                )}
                <div class="flex-1 min-w-0">
                  <p class="text-xs font-medium leading-snug line-clamp-2">{article.data.title}</p>
                  {article.data.description && (
                    <p class="text-[11px] text-muted-foreground/70 mt-0.5 line-clamp-1">{article.data.description}</p>
                  )}
                </div>
                <svg class="size-3.5 shrink-0 text-muted-foreground/40 group-hover:text-pink-500 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </a>
            )
          })}
        </div>
      </section>
    )}

    <!-- Scouted -->
    {scoutedCount > 0 && (
      <section>
        <h2 class="font-heading text-base font-medium mb-3 flex items-center gap-2">
          <CompassIcon weight="duotone" className="size-4 text-emerald-500" />
          Scouted
        </h2>
        <div class="flex flex-wrap gap-1.5">
          {[...scoutedGuilds.map((g) => ({ g, base: "guilds" })), ...scoutedSolos.map((g) => ({ g, base: "solos" }))].map(({ g, base }) => (
            <a
              href={`${BASE}/${base}/${g.slug}`}
              class="inline-flex items-center rounded-full bg-emerald-500/10 text-emerald-700 dark:text-emerald-300 ring-1 ring-inset ring-emerald-500/25 px-2.5 py-0.5 text-xs font-medium transition-opacity hover:opacity-70"
              data-umami-event="builder_profile_scouted_click"
              data-umami-event-name={g.name}
            >
              {stripGuildShowcase(g.name)}
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- NetEase Gallery -->
    {linkedNumberId && (
      <section>
        <h2 class="font-heading text-base font-medium mb-4 flex items-center gap-2">
          <img src="/images/logo_3.webp" alt="" aria-hidden="true" class="size-6 object-contain" />
          WWM Gallery
        </h2>
        <BuilderGallerySection client:visible numberId={linkedNumberId} />
      </section>
    )}

    {totalCount === 0 && !linkedNumberId && (
      <div class="text-center py-12 text-muted-foreground text-sm">
        No contributions found for this builder.
      </div>
    )}
  </div>
</Layout>
