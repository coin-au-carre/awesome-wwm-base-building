---
import Layout from "@/layouts/main.astro"
import { getCollection } from "astro:content"
import { getBuilderRoster, getBuilderProfile } from "@/lib/builders"
import { builderSlug } from "@/lib/format"
import { resolveCanonical, BUILDER_IDENTITIES } from "@/lib/builder-aliases"
import { getUsers, getDiscordIdBySlug } from "@/lib/guilds"
import { BuildersDirectory, type BuilderDirectoryEntry } from "@/components/BuildersDirectory"

// Tutorials per canonical slug — same author-matching pattern as
// credits.astro, but keeping the article itself (not just a count) so
// the directory's detail panel can link straight to each one.
const allArticles = await getCollection("articles", ({ data }) => data.published !== false)
const tutorialsBySlug = new Map<string, { title: string; id: string }[]>()
for (const article of allArticles) {
  for (const author of article.data.authors ?? []) {
    const s = builderSlug(author)
    if (!s) continue
    const canonical = resolveCanonical(s)
    const list = tutorialsBySlug.get(canonical) ?? []
    list.push({ title: article.data.title, id: article.id })
    tutorialsBySlug.set(canonical, list)
  }
}
const tutorialCountBySlug = new Map([...tutorialsBySlug].map(([s, list]) => [s, list.length]))

// Every builder with at least one credited contribution.
const roster = getBuilderRoster(tutorialCountBySlug)
const rosterBySlug = new Map(roster.map((r) => [r.slug, r]))

// A builder can register via /wwm-uid before ever having a guild/solo/
// blueprint/homestead/tutorial credit synced — include them too (zero
// contributions), same reasoning as builders/[slug].astro's
// getStaticPaths loop, so the directory matches exactly what has a
// profile page.
for (const identity of BUILDER_IDENTITIES) {
  if (!rosterBySlug.has(identity.canonicalSlug)) {
    rosterBySlug.set(identity.canonicalSlug, {
      name: identity.canonicalAlias,
      slug: identity.canonicalSlug,
      guildCount: 0,
      soloCount: 0,
      blueprintCount: 0,
      homesteadSheetCount: 0,
      tutorialCount: 0,
    })
  }
}

const identityBySlug = new Map(BUILDER_IDENTITIES.map((e) => [e.canonicalSlug, e]))
const users = getUsers()

// slug -> discordId, built once from every known Discord member — same
// fallback used when a builder has no registered discordId in
// builder_identities.json, just credited via a guild/solo/blueprint
// under a name that matches a known Discord member's display name.
const discordIdBySlug = getDiscordIdBySlug(users)

function discordNameFor(slug: string, identity?: (typeof BUILDER_IDENTITIES)[number]): string | undefined {
  const discordId = identity?.discordId ?? discordIdBySlug.get(slug)
  if (!discordId) return undefined
  const u = users[discordId]
  return u?.nickname ?? u?.globalName ?? u?.username
}

const entries: BuilderDirectoryEntry[] = [...rosterBySlug.values()].map((r) => {
  const identity = identityBySlug.get(r.slug)
  const discordName = discordNameFor(r.slug, identity)

  // Properly-cased canonical alias + other aliases, excluding whichever
  // one is already the display name or the Discord name (case-insensitive)
  // — same dedup rule as builders/[slug].astro's aliasNames.
  const aliasNames = [...new Set([identity?.canonicalAlias, ...(identity?.aliases ?? [])])]
    .filter((name): name is string => Boolean(name) && name !== r.name)
    .filter((name) => !discordName || name.toLowerCase() !== discordName.toLowerCase())

  const totalCount = r.guildCount + r.soloCount + r.blueprintCount + r.homesteadSheetCount + r.tutorialCount

  const searchText = [r.name, discordName, identity?.ingameNickname, identity?.neteaseNumberId, ...aliasNames]
    .filter(Boolean)
    .join(" ")
    .toLowerCase()

  // Actual guild/solo bases (name + slug), not just a count — lets the
  // directory's detail panel link straight to each one.
  const profile = getBuilderProfile(r.slug)
  const guilds = (profile?.guilds ?? []).map((g) => ({ name: g.name, slug: g.slug }))
  const solos = (profile?.solos ?? []).map((s) => ({ name: s.name, slug: s.slug }))
  const tutorials = tutorialsBySlug.get(r.slug) ?? []

  return {
    slug: r.slug,
    name: r.name,
    discordName,
    ingameNickname: identity?.ingameNickname,
    neteaseNumberId: identity?.neteaseNumberId,
    aliasNames,
    guilds,
    solos,
    tutorials,
    channels: profile?.channels ?? [],
    tutorialVideos: profile?.tutorialVideos ?? [],
    guildCount: r.guildCount,
    soloCount: r.soloCount,
    blueprintCount: r.blueprintCount,
    homesteadSheetCount: r.homesteadSheetCount,
    tutorialCount: r.tutorialCount,
    totalCount,
    isWbmBuilder: Boolean(identity?.discordId && identity?.neteaseNumberId),
    searchText,
  }
})

const pageDesc = `Browse all ${entries.length} builders credited across Where Winds Meet guild bases, solo builds, blueprints, homestead sheets, and tutorials. Search by Discord name, in-game name, alias, or Character ID.`
// Shorter than pageDesc (used for SEO/meta below) — the search input's own
// placeholder already spells out what you can search by, so repeating it
// in the on-page subtitle just added a second long line under the title.
const subtitle = `Every builder credited across guild bases, solo builds, blueprints, homestead sheets, and tutorials.`
---

<Layout
  title="Where Builders Meet | The Builders Directory"
  description={pageDesc}
  fullWidth
>
  <div class="space-y-6">
    <div class="flex flex-wrap items-center gap-2">
      <h1 class="font-heading text-2xl font-semibold">The Builders Directory</h1>
      <p class="text-muted-foreground hidden text-sm sm:block">{subtitle}</p>
      <p class="text-muted-foreground ml-auto text-sm">
        Not listed? Use <code class="rounded bg-muted px-1 py-0.5 font-mono text-xs">/wwm-uid</code> in Discord to register.
      </p>
    </div>
    <BuildersDirectory client:load entries={entries} />
  </div>
</Layout>
