---
import Layout from "@/layouts/main.astro"
import TopShowcase from "@/components/TopShowcase.astro"
import { GuildTable } from "@/components/GuildTable"
import { buttonVariants } from "@/components/ui/button"
import { Badge } from "@/components/ui/badge"
import { Card, CardContent } from "@/components/ui/card"
import { getSolosSortedByScore, getAllSoloTags, hasSolos, getLastSyncDate } from "@/lib/guilds"
import { HouseIcon, ArrowsClockwiseIcon, TrophyIcon, MountainsIcon, WarningIcon, ShuffleIcon } from "@phosphor-icons/react"

const solos = getSolosSortedByScore()
const allTags = getAllSoloTags()
const lastSync = getLastSyncDate()
const topSolos = solos.filter((g) => g.screenshots && g.screenshots.length > 0).slice(0, 9)
const isEmpty = !hasSolos()
---

<Layout
  title="Solo construction — Where Builders Meet"
  description="Discover solo base builds in Where Winds Meet."
>
  <div class="space-y-12">
    {
      isEmpty && (
        <div class="rounded-xl border border-dashed border-amber-500/50 bg-amber-500/5 px-6 py-4 flex items-start gap-3">
          <WarningIcon weight="duotone" className="size-5 shrink-0 text-amber-500" />
          <div>
            <p class="font-medium text-sm">Work in progress</p>
            <p class="text-sm text-muted-foreground mt-0.5">
              Solo base building is a new category. We're collecting submissions, check back
              soon or{" "}
              <a href="https://discord.gg/Qygt9u26Bn" class="underline hover:text-foreground transition-colors">
                join the Discord
              </a>{" "}
              to be notified when it launches.
            </p>
          </div>
        </div>
      )
    }

    <div class="flex flex-col gap-3">
      <div class="flex items-center gap-3 flex-wrap">
        <h1 class="font-heading text-2xl font-semibold mb-1 flex items-center gap-2"><HouseIcon weight="duotone" className="size-6 text-primary" /> Solo Construction</h1>
        <Badge variant="secondary">{solos.length} build{solos.length !== 1 ? "s" : ""}</Badge>
        {!isEmpty && (
          <Badge variant="outline" className="font-normal text-muted-foreground gap-1.5">
            <ArrowsClockwiseIcon weight="fill" className="size-3 text-green-500" /> Last sync: {lastSync}
          </Badge>
        )}
      </div>
      <p class="text-muted-foreground">
        Awesome individual builds from Jiang Hu wanderers. <span class="whitespace-nowrap">Share yours on <a href="https://discord.gg/Qygt9u26Bn" class="text-foreground underline underline-offset-2 hover:text-primary transition-colors" data-umami-event="discord_cta_click" data-umami-event-page="solo">Discord ↗</a></span>
      </p>
    </div>

    {
      topSolos.length > 0 && (
        <section>
          <div class="flex items-center gap-2 mb-3">
            <h2 class="font-heading text-base font-medium flex items-center gap-2"><TrophyIcon weight="duotone" className="size-4 text-yellow-400" /> Top-rated Solo Construction</h2>
            <button
              id="shuffle-showcase"
              title="Shuffle images"
              class="text-muted-foreground hover:text-foreground transition-colors cursor-pointer"
              aria-label="Shuffle showcase images"
            >
              <ShuffleIcon weight="bold" className="size-4" />
            </button>
          </div>
          <TopShowcase guilds={topSolos} basePath="solos" />
        </section>
      )
    }

    {
      solos.length > 0 && (
        <section>
          <h2 class="font-heading text-base font-medium mb-3 flex items-center gap-2"><MountainsIcon weight="duotone" className="size-4 text-primary" /> All Solo construction</h2>
          <GuildTable client:load guilds={solos} allTags={allTags} basePath="solos" />
        </section>
      )
    }

    {
      isEmpty && (
        <Card>
          <CardContent className="flex flex-col sm:flex-row items-start sm:items-center gap-4">
            <div class="flex-1">
              <p class="font-medium text-sm">Want to showcase your solo build?</p>
              <p class="text-sm text-muted-foreground mt-0.5">
                Post your screenshots in the dedicated channel on our Discord server.
              </p>
            </div>
            <a href="https://discord.gg/Qygt9u26Bn" target="_blank" rel="noopener noreferrer" class={`shrink-0 ${buttonVariants({ size: "lg" })}`} data-umami-event="discord_cta_click" data-umami-event-page="solo">Join Discord ↗</a>
          </CardContent>
        </Card>
      )
    }
  </div>
</Layout>

<script>
  const btn = document.getElementById("shuffle-showcase")
  const grid = document.getElementById("top-showcase-grid")
  if (btn && grid) {
    btn.addEventListener("click", () => {
      ;(window as any).umami?.track("shuffle_click")
      grid.querySelectorAll<HTMLAnchorElement>("a[data-screenshots]").forEach((card) => {
        const shots: string[] = JSON.parse(card.dataset.screenshots ?? "[]")
        if (shots.length === 0) return
        const img = card.querySelector("img")
        if (!img) return
        const pick = shots[Math.floor(Math.random() * shots.length)]
        img.style.opacity = "0"
        img.style.transition = "opacity 0.2s"
        setTimeout(() => {
          img.src = pick
          img.style.opacity = "1"
        }, 200)
      })
    })
  }
</script>
