---
import Layout from "@/layouts/main.astro"
import { GuildCarousel } from "@/components/GuildCarousel"
import { LeaderboardTable } from "@/components/LeaderboardTable"
import { buttonVariants } from "@/components/ui/button"
import { Badge } from "@/components/ui/badge"
import { Card, CardContent } from "@/components/ui/card"
import { getSolosSortedByScore, getAllSoloTags, hasSolos, getLastSyncDate, getLatestSolosWithScreenshots, formatBuilderName } from "@/lib/guilds"
import { BASE } from "@/lib/url"
import { HouseIcon, ArrowsClockwiseIcon, TrophyIcon, MountainsIcon, WarningIcon, SparkleIcon } from "@phosphor-icons/react"

const solos = getSolosSortedByScore()
const allTags = getAllSoloTags()
const lastSync = getLastSyncDate()
const topSolos = solos.filter((g) => g.screenshots && g.screenshots.length > 0).slice(0, 12)
const ogImage = solos.map((g) => g.coverImage ?? g.screenshots?.[0]).find(Boolean)
const latestSolos = getLatestSolosWithScreenshots(3)
const isEmpty = !hasSolos()
---

<Layout
  title="Solo Construction in Where Winds Meet — Where Builders Meet"
  description="Showcase of solo constructions and base builds in Where Winds Meet, ranked by community votes."
  image={ogImage}
>
  <div class="space-y-6">
    {
      isEmpty && (
        <div class="rounded-xl border border-dashed border-amber-500/50 bg-amber-500/5 px-6 py-4 flex items-start gap-3">
          <WarningIcon weight="duotone" className="size-5 shrink-0 text-amber-500" />
          <div>
            <p class="font-medium text-sm">Work in progress</p>
            <p class="text-sm text-muted-foreground mt-0.5">
              Solo base building is a new category. We're collecting submissions, check back
              soon or{" "}
              <a href="https://discord.gg/Qygt9u26Bn" class="underline hover:text-foreground transition-colors" data-umami-event="discord_cta_click">
                join the Discord
              </a>{" "}
              to be notified when it launches.
            </p>
          </div>
        </div>
      )
    }

    <div class="flex flex-col gap-3">
      <div class="flex items-center gap-3 flex-wrap">
        <h1 class="font-heading text-2xl font-semibold mb-1 flex items-center gap-2"><HouseIcon weight="duotone" className="size-6 text-primary" /> Solo Construction</h1>
        <Badge variant="secondary">{solos.length} build{solos.length !== 1 ? "s" : ""}</Badge>
        {!isEmpty && (
          <Badge variant="outline" className="font-normal text-muted-foreground gap-1.5">
            <ArrowsClockwiseIcon weight="fill" className="size-3 text-green-500" /> Last sync: {lastSync}
          </Badge>
        )}
      </div>
      <p class="text-muted-foreground text-sm">
        Awesome individual builds from Jiang Hu wanderers. <span class="whitespace-nowrap">Share yours on <a href="https://discord.gg/Qygt9u26Bn" class="text-foreground underline underline-offset-2 hover:text-primary transition-colors" data-umami-event="discord_cta_click">Discord ↗</a></span>
      </p>
    </div>

    <!-- Top rated carousel -->
    {
      topSolos.length > 0 && (
        <section>
          <h2 class="font-heading text-base font-medium mb-4 flex items-center gap-2"><TrophyIcon weight="duotone" className="size-4 text-yellow-400" /> Top-rated Solo Construction</h2>
          <div class="px-5">
            <GuildCarousel client:load guilds={topSolos} basePath="solos" />
          </div>
        </section>
      )
    }

    <!-- Recently added -->
    {
      latestSolos.length > 0 && (
        <section>
          <h2 class="font-heading text-base font-medium mb-4 flex items-center gap-2"><SparkleIcon weight="duotone" className="size-4 text-blue-500" /> Recently added</h2>
          <div class="px-5"><div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            {latestSolos.map((g) => {
              const shots = g.screenshots ?? []
              const img = g.coverImage ?? shots[0]
              return (
                <a
                  href={`${BASE}/solos/${g.slug}`}
                  class="group relative overflow-hidden rounded-xl ring-1 ring-border aspect-video bg-muted hover:ring-primary transition-all"
                  data-umami-event="solo_click"
                  data-umami-event-name={g.name}
                  data-umami-event-source="recently_added"
                  data-umami-event-type="solos"
                >
                  {img && (
                    <img
                      src={img}
                      alt={g.name}
                      loading="lazy"
                      onerror="this.style.display='none'"
                      class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                    />
                  )}
                  <div class="absolute inset-0 bg-linear-to-t from-black/70 to-transparent" />
                  <div class="absolute bottom-0 left-0 right-0 p-3">
                    <div class="flex items-baseline gap-1.5 mb-1">
                      <p class="text-white font-medium text-sm leading-tight">{g.name}</p>
                      {g.builders && g.builders.length > 0 && (
                        <p class="text-white/60 text-[11px] leading-tight truncate">by {g.builders.map(formatBuilderName).filter(Boolean).join(", ")}</p>
                      )}
                    </div>
                    {g.tags && g.tags.length > 0 && (
                      <div class="flex flex-wrap gap-1">
                        {g.tags.slice(0, 3).map((tag) => (
                          <span class="inline-flex items-center rounded-full bg-black/40 backdrop-blur-sm px-2 py-0.5 text-[10px] text-white/90">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </a>
              )
            })}
          </div></div>
        </section>
      )
    }

    <!-- Ranked table -->
    {
      solos.length > 0 && (
        <section>
          <h2 class="font-heading text-base font-medium mb-3 flex items-center gap-2"><MountainsIcon weight="duotone" className="size-4 text-primary" /> All Solo construction</h2>
          <LeaderboardTable client:load guilds={solos} allTags={allTags} basePath="solos" />
          <noscript>
            <ul class="mt-4 space-y-1 text-sm">
              {solos.map((g) => (
                <li>
                  <a href={`${BASE}/solos/${g.slug}`}>
                    #{g.rank} {g.guildName || g.name} — by {g.builders?.join(", ") || "—"} — Score: {g.score}
                  </a>
                </li>
              ))}
            </ul>
          </noscript>
        </section>
      )
    }

    {
      isEmpty && (
        <Card>
          <CardContent className="flex flex-col sm:flex-row items-start sm:items-center gap-4">
            <div class="flex-1">
              <p class="font-medium text-sm">Want to showcase your solo build?</p>
              <p class="text-sm text-muted-foreground mt-0.5">
                Post your screenshots in the dedicated channel on our Discord server.
              </p>
            </div>
            <a href="https://discord.gg/Qygt9u26Bn" target="_blank" rel="noopener noreferrer" class={`shrink-0 ${buttonVariants({ size: "lg" })}`} data-umami-event="discord_cta_click">Join Discord ↗</a>
          </CardContent>
        </Card>
      )
    }
  </div>
</Layout>
