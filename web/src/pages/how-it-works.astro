---
import Layout from "@/layouts/main.astro"
import { buttonVariants } from "@/components/ui/button"
import { Card, CardContent } from "@/components/ui/card"
import { Table, TableBody, TableHead, TableHeader, TableRow, TableCell } from "@/components/ui/table"
import { BASE } from "@/lib/url"
import { CompassIcon } from "@phosphor-icons/react"
---

<Layout
  title="How it works — Where Builders Meet"
  description="The project, the community, and how scoring works."
>
  <div class="max-w-3xl space-y-10">
    <div class="flex flex-col gap-3">
      <h1 class="font-heading text-2xl font-semibold flex items-center gap-2"><CompassIcon weight="duotone" className="size-6 text-primary" /> How it works</h1>
      <p class="text-muted-foreground text-sm">The community hub for Where Winds Meet builders. <span class="whitespace-nowrap">Join us on <a href="https://discord.gg/Qygt9u26Bn" class="text-foreground underline underline-offset-2 hover:text-primary transition-colors" data-umami-event="discord_cta_click">Discord ↗</a></span></p>
    </div>

    <section class="space-y-4">
      <h2 class="font-heading text-base font-medium">The origin</h2>
      <p class="text-sm text-muted-foreground leading-relaxed">
        It all started after touring tons of incredible guild bases in <strong class="text-foreground"><a href="https://www.wherewindsmeetgame.com" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:text-foreground transition-colors">Where Winds Meet</a></strong>. They were simply too good to keep secret.
        So this place was born: somewhere to share builds, swap ideas, and get inspired together.
      </p>
      <p class="text-sm text-muted-foreground leading-relaxed">
        There's no in-game gallery, and great screenshots tend to vanish in Discord threads. This site collects all
        guild base submissions from the community Discord, ranks them by community votes, and presents them in a
        browsable showcase. No build left behind.
      </p>
    </section>

    <section class="space-y-4">
      <h2 class="font-heading text-base font-medium">The showcase</h2>
      <p class="text-sm text-muted-foreground leading-relaxed">
        A bot watches the Discord forum, picks up new submissions, and counts community reactions.
        Everything syncs automatically <strong class="text-foreground">several times a day</strong> so the showcase stays fresh without any manual work.
      </p>
      <p class="text-sm text-muted-foreground leading-relaxed">
        The top of the homepage features one randomly selected image from each of the <strong class="text-foreground">top 9 ranked guilds</strong>. Choose your best screenshots when submitting.
      </p>
    </section>

    <section class="space-y-4">
      <h2 class="font-heading text-base font-medium">Voting & scoring</h2>
      <p class="text-sm text-muted-foreground leading-relaxed">
        Each guild base has a thread in our Discord forum. Community members can vote by
        reacting to the thread's first post. Reactions are tallied automatically and converted into a score.
      </p>
      <p class="text-sm text-amber-600 dark:text-amber-400 leading-relaxed">
        Note: only reactions on the <strong>first post</strong> of a thread are counted. Reactions on replies or later messages are ignored.
      </p>

      <div class="rounded-xl ring-1 ring-border overflow-hidden">
        <Table>
          <TableHeader className="bg-muted/40 text-muted-foreground">
            <TableRow>
              <TableHead className="text-muted-foreground">Reaction</TableHead>
              <TableHead className="text-muted-foreground">Points</TableHead>
              <TableHead className="text-muted-foreground">Notes</TableHead>
            </TableRow>
          </TableHeader>
          <TableBody>
            <TableRow>
              <TableCell className="text-lg">⭐</TableCell>
              <TableCell className="font-mono font-semibold">+2</TableCell>
              <TableCell className="text-muted-foreground">Best overall</TableCell>
            </TableRow>
            <TableRow>
              <TableCell className="text-lg">👍</TableCell>
              <TableCell className="font-mono font-semibold">+1</TableCell>
              <TableCell className="text-muted-foreground">Good base</TableCell>
            </TableRow>
            <TableRow>
              <TableCell className="text-lg">🔥</TableCell>
              <TableCell className="font-mono font-semibold">+1</TableCell>
              <TableCell className="text-muted-foreground">Amazing creativity</TableCell>
            </TableRow>
          </TableBody>
        </Table>
      </div>
    </section>

    <section class="space-y-4">
      <h2 class="font-heading text-base font-medium">Voter weight</h2>
      <p class="text-sm text-muted-foreground leading-relaxed">
        To keep rankings fair, votes from community members who engage with many guilds count
        more. A voter who has reacted to at least 5 different guild threads carries a higher
        weight than someone who only reacted to one.
      </p>
      <p class="text-sm text-muted-foreground leading-relaxed">
        This prevents guild leaders from inflating their own score by asking members to vote
        only for them.
      </p>
    </section>

    <section class="space-y-4">
      <h2 class="font-heading text-base font-medium">Discord roles</h2>
      <ul class="space-y-2 text-sm">
        <li class="flex items-center gap-2">
          <span class="text-base">🏗️</span>
          <span><strong>Builder</strong>: awarded to users who post their guild base in the channel #guild-base-showcase</span>
        </li>
        <li class="flex items-center gap-2">
          <span class="text-base">🗳️</span>
          <span><strong>Critic</strong>: awarded to active community voters who engage across many guilds</span>
        </li>
      </ul>
    </section>

    <Card>
      <CardContent className="flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <div class="flex-1">
          <p class="font-medium text-sm">Want to get involved?</p>
          <p class="text-sm text-muted-foreground mt-0.5">Join the community Discord or check how to contribute.</p>
        </div>
        <div class="flex gap-2 shrink-0">
          <a href="https://discord.gg/Qygt9u26Bn" target="_blank" rel="noopener noreferrer" class={buttonVariants({ size: "lg" })} data-umami-event="discord_cta_click">Discord ↗</a>
          <a href={`${BASE}/contribute`} class={buttonVariants({ variant: "outline", size: "lg" })}>Contribute</a>
        </div>
      </CardContent>
    </Card>
  </div>
</Layout>
