              <span class="inline-flex items-center gap-1.5 bg-pink-500/20 ring-1 ring-pink-500/50 rounded-full px-3 py-1 text-xs font-semibold text-pink-200 group-hover:bg-pink-500/35 transition-colors">
                <span class="sm:hidden">🎙️ Join</span>
                <span class="hidden sm:inline">🎙️ Join the event ↗</span>
              </span>
            </div>
          </div>
        </a>
        <script is:inline define:vars={{ btwStartMs: BTW_EVENT.startUnixSec * 1000, btwDurationMs: BTW_EVENT.durationMs }}>
          (function () {
            function update() {
              const now = Date.now()
              const diff = btwStartMs - now
              const label = document.getElementById("btw-label")
              const dot = document.getElementById("btw-dot")
              if (!label) return
              if (diff <= 0 && diff > -btwDurationMs) {
                label.textContent = "🟢 Live now"
                label.classList.replace("text-pink-400", "text-green-400")
                if (dot) { dot.classList.replace("bg-pink-400", "bg-green-400"); dot.classList.replace("animate-pulse", "animate-ping") }
              } else if (diff > 0) {
                const h = Math.floor(diff / 3600000)
                const m = Math.floor((diff % 3600000) / 60000)
                label.textContent = "WWM Event · " + (h > 24 ? `in ${Math.round(h / 24)}d` : m > 0 ? `in ${h}h${m}m` : `in ${h}h`)
              }
            }
            update()
            setInterval(update, 30000)
          })()
