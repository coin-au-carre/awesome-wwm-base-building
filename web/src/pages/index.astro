---
import Layout from "@/layouts/main.astro"
import { GuildCarousel } from "@/components/GuildCarousel"
import { LeaderboardTable } from "@/components/LeaderboardTable"
import { getGuildsSortedByScore, getAllTags, getLastSyncDate, getLatestGuildsWithScreenshots, getHiddenGems, formatBuilderName, getUpcomingEvents } from "@/lib/guilds"
import { stripGuildShowcase } from "@/lib/format"
import { isCommunityPosted } from "@/lib/config"
import { BASE } from "@/lib/url"
import { CastleTurretIcon, ArrowsClockwiseIcon, TrophyIcon, SparkleIcon, MountainsIcon, DiamondIcon, BookOpenIcon, CalendarDotIcon, HammerIcon } from "@phosphor-icons/react"
import { getCollection } from "astro:content"

const TAG_PALETTE = [
  { bg: "bg-violet-500/20", text: "text-violet-200", ring: "ring-1 ring-inset ring-violet-400/40" },
  { bg: "bg-sky-500/20", text: "text-sky-200", ring: "ring-1 ring-inset ring-sky-400/40" },
  { bg: "bg-emerald-500/20", text: "text-emerald-200", ring: "ring-1 ring-inset ring-emerald-400/40" },
  { bg: "bg-amber-500/20", text: "text-amber-200", ring: "ring-1 ring-inset ring-amber-400/40" },
  { bg: "bg-rose-500/20", text: "text-rose-200", ring: "ring-1 ring-inset ring-rose-400/40" },
  { bg: "bg-teal-500/20", text: "text-teal-200", ring: "ring-1 ring-inset ring-teal-400/40" },
  { bg: "bg-orange-500/20", text: "text-orange-200", ring: "ring-1 ring-inset ring-orange-400/40" },
  { bg: "bg-indigo-500/20", text: "text-indigo-200", ring: "ring-1 ring-inset ring-indigo-400/40" },
]
function tagColor(tag: string) {
  const hash = [...tag].reduce((a, c) => a + c.charCodeAt(0), 0)
  return TAG_PALETTE[hash % TAG_PALETTE.length]
}
function relativeDate(createdAt: string): string {
  const ms = Date.now() - new Date(createdAt.replace(" at ", " ")).getTime()
  if (isNaN(ms) || ms < 0) return ""
  const hours = Math.floor(ms / 3600000)
  const days = Math.floor(ms / 86400000)
  if (hours < 24) return hours <= 1 ? "1h ago" : `${hours}h ago`
  if (days === 1) return "yesterday"
  if (days < 7) return `${days}d ago`
  if (days < 30) return `${Math.floor(days / 7)}w ago`
  return `${Math.floor(days / 30)}mo ago`
}

const guilds = getGuildsSortedByScore()
const allArticles = await getCollection("articles", ({ data }) => data.published !== false)
const featuredArticles = allArticles.filter((e) => e.data.featured).sort((a, b) => a.data.order - b.data.order)
const allTags = getAllTags()
const lastSync = getLastSyncDate()
const topGuilds = guilds.filter((g) => g.screenshots && g.screenshots.length > 0).slice(0, 12)
const ogImage = guilds.map((g) => g.coverImage ?? g.screenshots?.[0]).find(Boolean)

const heroCandidates = guilds
  .filter((g) => isCommunityPosted(g) && (g.coverImage ?? g.screenshots?.[0]))
  .map((g) => ({
    img: g.coverImage ?? g.screenshots![0],
    href: `${BASE}/guilds/${g.slug}`,
    name: g.name,
    label: stripGuildShowcase(g.guildName || g.name),
    builders: (g.builders ?? []).map(formatBuilderName).filter(Boolean).join(", "),
  }))
const latestGuilds = getLatestGuildsWithScreenshots(3)
const hiddenGems = getHiddenGems()
const upcomingEvents = getUpcomingEvents()
const now = Date.now()
const upcomingEventsDisplay = upcomingEvents.map((event) => {
  const startMs = new Date(event.scheduledStart).getTime()
  const endMs = event.scheduledEnd ? new Date(event.scheduledEnd).getTime() : startMs
  const live = event.status === "active" || (startMs <= now && endMs >= now)
  const minsUntil = Math.round((startMs - now) / 60000)
  const urgent = !live && minsUntil >= 0 && minsUntil <= 60
  const timeLabel = live
    ? "Live now"
    : urgent
    ? `in ${minsUntil} min`
    : minsUntil <= 1440
    ? `in ${Math.round(minsUntil / 60)}h`
    : `in ${Math.round(minsUntil / 1440)}d`
  return { ...event, live, urgent, timeLabel }
})
---

<Layout
  title="Where Builders Meet | Awesome constructions and builders in Where Winds Meet"
  description="Community gallery of guild base constructions in Where Winds Meet, ranked by community votes. Find base building inspiration from top builders."
  image={ogImage}
>
  <style>
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(14px) scale(0.98); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    .fade-up {
      opacity: 0;
      animation: fadeUp 0.45s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
    @keyframes eventGlow {
      0%, 100% { box-shadow: 0 0 0 1px rgb(34 211 238 / 0.5), 0 0 10px 0px rgb(34 211 238 / 0); }
      50%       { box-shadow: 0 0 0 1px rgb(34 211 238 / 0.9), 0 0 18px 4px rgb(34 211 238 / 0.2); }
    }
    .event-urgent { animation: eventGlow 2s ease-in-out infinite; }
    @keyframes eventLive {
      0%, 100% { box-shadow: 0 0 0 1px rgb(74 222 128 / 0.5), 0 0 10px 0px rgb(74 222 128 / 0); }
      50%       { box-shadow: 0 0 0 1px rgb(74 222 128 / 0.9), 0 0 18px 4px rgb(74 222 128 / 0.25); }
    }
    .event-live { animation: eventLive 2s ease-in-out infinite; }
  </style>

  <div class="space-y-6">
    <!-- Hero banner -->
    <div class="-mx-4 -mt-8 dark:rounded-none rounded-xl relative h-56 sm:h-72 overflow-hidden mb-2">
      <div class="absolute inset-0 bg-muted" />
      <img id="hero-img" src="" alt="" class="absolute inset-0 w-full h-full object-cover object-center hidden" aria-hidden="true" />
      <div class="absolute inset-0 bg-linear-to-t from-black/60 via-black/20 to-black/5 dark:from-black/85 dark:via-black/35 dark:to-black/10" />
      <a
        id="hero-credit"
        href="#"
        class="absolute top-3 right-4 hidden items-center gap-1.5 bg-black/40 backdrop-blur-sm border border-white/15 rounded-full px-2.5 py-1 text-xs text-white/70 hover:text-white hover:bg-black/60 transition-all group"
        title="View this guild"
        data-umami-event="hero_guild_credit_click"
      >
        <span id="hero-label" class="max-w-28 truncate"></span>
        <span id="hero-builders" class="text-white/45 text-[11px] max-w-24 truncate shrink-0 hidden"></span>
        <svg class="size-3 shrink-0 opacity-60 group-hover:opacity-100 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
      </a>
      <script is:inline define:vars={{ heroCandidates }}>
        const c = heroCandidates[Math.floor(Math.random() * heroCandidates.length)]
        if (c) {
          const img = document.getElementById("hero-img")
          img.src = c.img
          img.classList.remove("hidden")
          const credit = document.getElementById("hero-credit")
          credit.href = c.href
          credit.dataset.umamiEventName = c.name
          credit.classList.remove("hidden")
          credit.classList.add("flex")
          document.getElementById("hero-label").textContent = c.label
          if (c.builders) {
            const b = document.getElementById("hero-builders")
            b.textContent = "by " + c.builders
            b.classList.remove("hidden")
          }
        }
      </script>
      <div class="absolute bottom-0 left-0 right-0 px-6 pb-6">
        <h1 class="font-heading text-2xl sm:text-3xl font-bold text-white drop-shadow mb-1.5 flex items-center gap-2">
          <CastleTurretIcon weight="duotone" className="size-6 text-primary" /> Guild Bases
        </h1>
        <p class="text-white/65 text-sm mb-3">Beautiful constructions in Where Winds Meet</p>
        <div class="flex items-center gap-2 flex-wrap text-xs text-white/60">
          <span class="inline-flex items-center gap-1.5 bg-white/10 backdrop-blur-sm border border-white/15 rounded-full px-2.5 py-1">
            <CastleTurretIcon weight="duotone" className="size-3" /> {guilds.length} guilds
          </span>
          <span class="inline-flex items-center gap-1.5 bg-white/10 backdrop-blur-sm border border-white/15 rounded-full px-2.5 py-1">
            <ArrowsClockwiseIcon weight="fill" className="size-3 text-green-400" />
            <span id="last-sync-date">{lastSync}</span>
          </span>
          {lastSync && (
            <script is:inline define:vars={{ lastSync }}>
              const d = new Date(lastSync)
              const pad = n => String(n).padStart(2, "0")
              const formatted = `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}`
              document.getElementById("last-sync-date").textContent = formatted
            </script>
          )}
          <a href={`${BASE}/catalog`} class="inline-flex items-center gap-1.5 bg-white/10 backdrop-blur-sm border border-white/15 rounded-full px-2.5 py-1 hover:bg-white/20 transition-colors" data-umami-event="catalog_pill_click">
            <BookOpenIcon weight="duotone" className="size-3 text-amber-300 shrink-0" /> Browse the items catalog
          </a>
          <a href="/rss.xml" class="inline-flex items-center gap-1.5 bg-white/10 backdrop-blur-sm border border-white/15 rounded-full px-2.5 py-1 hover:bg-white/20 transition-colors" title="RSS feed">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="currentColor" class="text-orange-400 shrink-0">
              <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
            </svg>
            RSS
          </a>
        </div>
      </div>
    </div>

    <!-- Recently added -->
    {latestGuilds.length > 0 && (
      <section>
        <h2 class="font-heading text-base font-medium mb-4 flex items-center gap-2"><SparkleIcon weight="duotone" className="size-4 text-blue-500" /> Recently added</h2>
        <div class="px-5">
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            {latestGuilds.map((g, idx) => {
              const shots = g.screenshots ?? []
              const img = g.coverImage ?? shots[0]
              return (
                <a
                  href={`${BASE}/guilds/${g.slug}`}
                  class="fade-up group relative overflow-hidden rounded-xl ring-1 ring-border aspect-video bg-muted hover:ring-primary transition-all"
                  style={`animation-delay: ${idx * 80}ms`}
                  data-umami-event="guild_click"
                  data-umami-event-name={g.name}
                  data-umami-event-source="recently_added"
                  data-umami-event-type="guilds"
                >
                  {img && (
                    <img
                      src={img}
                      alt={stripGuildShowcase(g.name)}
                      loading="lazy"
                      onerror="this.style.display='none'"
                      class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                    />
                  )}
                  <div class="absolute inset-0 bg-linear-to-t from-black/70 to-transparent" />
                  {g.createdAt && (
                    <div class="absolute top-2 left-2 text-[10px] font-medium px-1.5 py-0.5 rounded-md bg-black/50 backdrop-blur-sm text-white/60">
                      {relativeDate(g.createdAt)}
                    </div>
                  )}
                  {g.rank <= 10 && (
                    <div class="absolute top-2 right-2 text-[11px] font-bold font-mono px-1.5 py-0.5 rounded-md bg-black/50 backdrop-blur-sm text-white/90">
                      #{g.rank}
                    </div>
                  )}
                  <div class="absolute bottom-0 left-0 right-0 p-3">
                    <div class="flex items-baseline gap-1.5 mb-1">
                      <p class="text-white font-medium text-sm leading-tight">{stripGuildShowcase(g.name)}</p>
                      {g.builders && g.builders.length > 0 && (
                        <p class="text-white/60 text-[11px] leading-tight truncate">by {g.builders.map(formatBuilderName).filter(Boolean).join(", ")}</p>
                      )}
                    </div>
                    {g.tags && g.tags.length > 0 && (
                      <div class="flex flex-wrap gap-1">
                        {g.tags.slice(0, 3).map((tag) => {
                          const cfg = tagColor(tag)
                          return (
                            <span class={`inline-flex items-center rounded-full ${cfg.bg} ${cfg.text} ${cfg.ring} backdrop-blur-sm px-2 py-0.5 text-[10px] font-medium`}>
                              {tag}
                            </span>
                          )
                        })}
                      </div>
                    )}
                  </div>
                </a>
              )
            })}
          </div>
          <p class="text-xs text-muted-foreground mt-3">Want to add your guild? <a href={`${BASE}/contribute`} class="text-foreground underline underline-offset-2 hover:text-primary transition-colors" data-umami-event="contribute_cta_click">Contribute ↗</a></p>
        </div>
      </section>
    )}

    <!-- Featured Articles + Events -->
    {(featuredArticles.length > 0 || upcomingEventsDisplay.length > 0) && (
      <div class="flex flex-col sm:flex-row flex-wrap gap-2">
        {featuredArticles.map((article) => {
          const body = article.body ?? ""
          const ytID = body.match(/youtube\.com\/embed\/([^"?\s]+)/)?.[1] ?? ""
          const firstImg = body.match(/<img[^>]+src=["']([^"']+)["']/)?.[1] ?? ""
          const thumb = ytID ? `https://img.youtube.com/vi/${ytID}/hqdefault.jpg` : (article.data.image ?? firstImg)
          return (
            <a
              href={`${BASE}/tutorials/${article.id}`}
              class="group flex flex-1 items-center gap-3 rounded-xl ring-1 ring-pink-500/25 bg-card hover:ring-pink-500/50 hover:shadow-sm transition-all px-3 py-2.5"
              data-umami-event="featured_article_click"
            >
              {thumb ? (
                <div class="relative shrink-0 w-20 aspect-video rounded-md overflow-hidden bg-black">
                  <img
                    src={thumb}
                    alt={article.data.title}
                    class="absolute inset-0 h-full w-full object-cover"
                  />
                </div>
              ) : (
                <div class="shrink-0 w-20 aspect-video rounded-md bg-pink-500/10 flex items-center justify-center">
                  <BookOpenIcon weight="duotone" className="size-5 text-pink-400" />
                </div>
              )}
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-1.5 mb-0.5">
                  <svg class="size-3 text-pink-500 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
                  <span class="text-[10px] font-semibold uppercase tracking-widest text-pink-500">{article.data.featuredLabel ?? "Featured Article"}</span>
                </div>
                <p class="text-xs font-medium leading-snug line-clamp-2">{article.data.title}</p>
                {article.data.authors && article.data.authors.length > 0 && (
                  <p class="text-[11px] text-muted-foreground/70">by {article.data.authors.join(", ")}</p>
                )}
              </div>
              <svg class="size-3.5 shrink-0 text-muted-foreground/40 group-hover:text-pink-500 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          )
        })}
        {upcomingEventsDisplay.map((event) => {
          const { live, urgent, timeLabel } = event
          return (
            <a
              href={`${BASE}/events`}
              class={`group flex flex-1 items-center gap-3 rounded-xl bg-card hover:shadow-sm transition-all px-3 py-2.5 ${live ? "event-live bg-green-500/5" : urgent ? "event-urgent bg-cyan-500/5" : "ring-1 ring-cyan-500/25 hover:ring-cyan-500/50"}`}
              data-umami-event="upcoming_event_click"
            >
              {event.image ? (
                <div class="relative shrink-0 w-20 aspect-video rounded-md overflow-hidden bg-black">
                  <img
                    src={event.image}
                    alt={event.name}
                    class="absolute inset-0 h-full w-full object-cover"
                  />
                </div>
              ) : (
                <div class={`shrink-0 w-20 aspect-video rounded-md flex items-center justify-center ${live ? "bg-green-500/20" : urgent ? "bg-cyan-500/20" : "bg-cyan-500/10"}`}>
                  <CalendarDotIcon weight="duotone" className={`size-5 ${live ? "text-green-300" : urgent ? "text-cyan-300" : "text-cyan-400"}`} />
                </div>
              )}
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-1.5 mb-0.5">
                  <span class={`inline-block size-1.5 rounded-full shrink-0 ${live ? "bg-green-400 animate-ping" : urgent ? "bg-cyan-300 animate-ping" : "bg-cyan-400 animate-pulse"}`} />
                  <span class={`text-[10px] font-semibold uppercase tracking-widest ${live ? "text-green-400" : urgent ? "text-cyan-300" : "text-cyan-400"}`}>
                    {live ? "🟢 " : urgent ? "🔔 " : ""}Event {timeLabel}
                  </span>
                </div>
                <p class={`text-xs font-medium leading-snug line-clamp-2 ${live || urgent ? "text-foreground" : ""}`}>{event.name}</p>
                {event.guildName && (
                  <p class="text-xs text-muted-foreground/70 truncate">{event.guildName}</p>
                )}
              </div>
              <svg class={`size-3.5 shrink-0 transition-all group-hover:translate-x-0.5 ${live ? "text-green-400" : urgent ? "text-cyan-400" : "text-muted-foreground/40 group-hover:text-cyan-400"}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          )
        })}
      </div>
    )}

    <!-- Catalog discovery banner -->
    <a
      href={`${BASE}/catalog`}
      class="group flex items-center gap-4 rounded-xl ring-1 ring-amber-500/25 bg-card hover:ring-amber-500/50 hover:shadow-sm transition-all px-4 py-3"
      data-umami-event="catalog_banner_click"
    >
      <div class="shrink-0 flex items-center gap-1">
        {[
          { cat: "Basic Structure",      label: "Basic Structure" },
          { cat: "Furniture Decoration", label: "Furniture Decoration" },
          { cat: "Guild Construction",   label: "Guild Construction" },
        ].map(({ cat, label }) => (
          <img
            src={`/catalog/${encodeURIComponent(cat)}/icon.png`}
            alt={label}
            class="size-8 object-contain transition-all [filter:brightness(0)_opacity(0.55)] group-hover:[filter:brightness(0)_opacity(0.75)] dark:[filter:brightness(0)_invert(1)_opacity(0.6)] dark:group-hover:[filter:brightness(0)_invert(1)_opacity(0.85)]"
          />
        ))}
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-semibold flex items-center gap-1.5">
          <HammerIcon weight="duotone" className="size-4 text-amber-400 shrink-0" />
          Construction Catalog
        </p>
        <p class="text-xs text-muted-foreground">Browse every building item, blueprint, and diagram. Searchable by tag and style.</p>
      </div>
      <svg class="size-4 shrink-0 text-amber-400/50 group-hover:text-amber-400 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
    </a>

    <!-- Ranked table -->
    <section>
      <h2 class="font-heading text-base font-medium mb-3 flex items-center gap-2"><MountainsIcon weight="duotone" className="size-4 text-primary" /> All Guild bases</h2>
      <LeaderboardTable client:load guilds={guilds} allTags={allTags} />
      <noscript>
        <ul class="mt-4 space-y-1 text-sm">
          {guilds.map((g) => (
            <li>
              <a href={`${BASE}/guilds/${g.slug}`}>
                #{g.rank} {g.guildName || g.name} — by {g.builders?.join(", ") || "—"} — Score: {g.score}
              </a>
            </li>
          ))}
        </ul>
      </noscript>
      <p class="text-xs text-muted-foreground mt-3">Want to vote? <a href={`${BASE}/how-it-works`} class="text-foreground underline underline-offset-2 hover:text-primary transition-colors">Votes count more when you explore many guilds ↗</a></p>
      <p class="text-xs text-muted-foreground mt-1.5">Looking for a builder? <a href="https://discord.gg/Qygt9u26Bn" target="_blank" rel="noopener noreferrer" class="text-foreground underline underline-offset-2 hover:text-primary transition-colors" data-umami-event="building_request_cta_click">#building-requests ↗</a></p>
    </section>

    <!-- Top rated carousel -->
    {topGuilds.length > 0 && (
      <section>
        <h2 class="font-heading text-base font-medium mb-4 flex items-center gap-2"><TrophyIcon weight="duotone" className="size-4 text-yellow-400" /> Top-rated Guild bases</h2>
        <div class="px-5">
          <GuildCarousel client:load guilds={topGuilds} />
        </div>
      </section>
    )}

    <!-- Hidden gems -->
    {hiddenGems.length > 0 && (
      <section>
        <h2 class="font-heading text-base font-medium mb-4 flex items-center gap-2"><DiamondIcon weight="duotone" className="size-4 text-cyan-400" /> Hidden Gems</h2>
        <div class="px-5">
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            {hiddenGems.map((g, idx) => {
              const shots = g.screenshots ?? []
              const img = g.coverImage ?? shots[0]
              return (
                <a
                  href={`${BASE}/guilds/${g.slug}`}
                  class="fade-up group relative overflow-hidden rounded-xl ring-1 ring-border aspect-video bg-muted hover:ring-primary transition-all"
                  style={`animation-delay: ${idx * 80}ms`}
                  data-umami-event="guild_click"
                  data-umami-event-name={g.name}
                  data-umami-event-source="hidden_gems"
                  data-umami-event-type="guilds"
                >
                  {img && (
                    <img
                      src={img}
                      alt={stripGuildShowcase(g.name)}
                      loading="lazy"
                      onerror="this.style.display='none'"
                      class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                    />
                  )}
                  <div class="absolute inset-0 bg-linear-to-t from-black/70 to-transparent" />
                  {g.rank <= 10 && (
                    <div class="absolute top-2 right-2 text-[11px] font-bold font-mono px-1.5 py-0.5 rounded-md bg-black/50 backdrop-blur-sm text-white/90">
                      #{g.rank}
                    </div>
                  )}
                  <div class="absolute bottom-0 left-0 right-0 p-3">
                    <div class="flex items-baseline gap-1.5 mb-1">
                      <p class="text-white font-medium text-sm leading-tight">{stripGuildShowcase(g.name)}</p>
                      {g.builders && g.builders.length > 0 && (
                        <p class="text-white/60 text-[11px] leading-tight truncate">by {g.builders.map(formatBuilderName).filter(Boolean).join(", ")}</p>
                      )}
                    </div>
                    {g.tags && g.tags.length > 0 && (
                      <div class="flex flex-wrap gap-1">
                        {g.tags.slice(0, 3).map((tag) => {
                          const cfg = tagColor(tag)
                          return (
                            <span class={`inline-flex items-center rounded-full ${cfg.bg} ${cfg.text} ${cfg.ring} backdrop-blur-sm px-2 py-0.5 text-[10px] font-medium`}>
                              {tag}
                            </span>
                          )
                        })}
                      </div>
                    )}
                  </div>
                </a>
              )
            })}
          </div>
        </div>
      </section>
    )}
  </div>
</Layout>
