---
import Layout from "@/layouts/main.astro"
import { GuildCarousel, type CarouselGuild } from "@/components/GuildCarousel"
import { LeaderboardTable, type LeaderboardGuild } from "@/components/LeaderboardTable"
import BuilderLinks from "@/components/BuilderLinks.astro"
import { getGuildsSortedByScore, getAllTags, getLastSyncDate, getLatestGuildsWithScreenshots, getRecentGuildsWithScreenshots, getHiddenGems, formatBuilderName, getUpcomingEvents } from "@/lib/guilds"
import { stripGuildShowcase, thumbUrl, builderSlug } from "@/lib/format"
import { formatSyncDate } from "@/lib/dates"
import { getActiveBuilderSlugs } from "@/lib/builders"
import { isBuilderSubmission } from "@/lib/config"
import { BASE } from "@/lib/url"
import { tagColor } from "@/lib/colors"
import { ArrowsClockwiseIcon, TrophyIcon, SparkleIcon, DiamondIcon, BookOpenIcon, CalendarDotIcon, HammerIcon, StackIcon, UsersIcon } from "@phosphor-icons/react"
import { getCollection, type CollectionEntry } from "astro:content"
function relativeDate(createdAt: string): string {
  const ms = Date.now() - new Date(createdAt.replace(" at ", " ")).getTime()
  if (isNaN(ms) || ms < 0) return ""
  const hours = Math.floor(ms / 3600000)
  const days = Math.floor(ms / 86400000)
  if (hours < 24) return hours <= 1 ? "1h ago" : `${hours}h ago`
  if (days === 1) return "yesterday"
  if (days < 7) return `${days}d ago`
  if (days < 30) return `${Math.floor(days / 7)}w ago`
  return `${Math.floor(days / 30)}mo ago`
}

const guilds = getGuildsSortedByScore()
const allArticles: CollectionEntry<"articles">[] = await getCollection("articles", (e: CollectionEntry<"articles">) => e.data.published !== false)
type FeaturedEntry = { article: CollectionEntry<"articles">; thumb: string }
const featuredArticles: FeaturedEntry[] = allArticles.filter((e) => e.data.featured).sort((a, b) => new Date(b.data.date ?? 0).getTime() - new Date(a.data.date ?? 0).getTime()).map((article) => {
  const body = article.body ?? ""
  const ytID = body.match(/youtube\.com\/embed\/([^"?\s]+)/)?.[1] ?? ""
  const firstImg = body.match(/<img[^>]+src=["']([^"']+)["']/)?.[1] ?? ""
  const thumb = ytID ? `https://img.youtube.com/vi/${ytID}/hqdefault.jpg` : (article.data.image ?? firstImg)
  return { article, thumb }
})
const tutorialAuthorSlugs = new Set<string>(allArticles.flatMap((a) => (a.data.authors ?? []).map((n: string) => builderSlug(n))))
const activeBuilders = getActiveBuilderSlugs(tutorialAuthorSlugs)
const allTags = getAllTags()
const lastSync = getLastSyncDate()
const topGuilds: CarouselGuild[] = guilds
  .filter((g) => g.screenshots && g.screenshots.length > 0)
  .slice(0, 12)
  .map((g) => ({
    slug: g.slug, rank: g.rank, name: g.name, guildName: g.guildName,
    builders: g.builders, tags: g.tags, coverImage: g.coverImage,
    screenshots: g.screenshots?.[0] ? [g.screenshots[0]] : undefined,
    buildTitle: g.buildTitle, createdAt: g.createdAt,
  }))
const ogImage = guilds.map((g) => g.coverImage ?? g.screenshots?.[0]).find(Boolean)

const heroCandidates = guilds
  .filter((g) => isBuilderSubmission(g) && (g.coverImage ?? g.screenshots?.[0]))
  .slice(0, 25)
  .map((g) => ({
    img: thumbUrl(g.coverImage ?? g.screenshots![0], 1400, 560),
    href: `${BASE}/guilds/${g.slug}`,
    name: g.name,
    label: stripGuildShowcase(g.guildName || g.name),
    builders: (g.builders ?? []).map(formatBuilderName).filter(Boolean).join(", "),
  }))
const heroFirst = heroCandidates[0]
const recentGuilds = getRecentGuildsWithScreenshots(4)
const useCarousel = recentGuilds.length > 3
const latestGuilds: CarouselGuild[] = (useCarousel ? recentGuilds : getLatestGuildsWithScreenshots(3)).map((g) => ({
  slug: g.slug, rank: g.rank, name: g.name, guildName: g.guildName,
  builders: g.builders, tags: g.tags, coverImage: g.coverImage,
  screenshots: g.screenshots?.[0] ? [g.screenshots[0]] : undefined,
  buildTitle: g.buildTitle, createdAt: g.createdAt,
}))
const hiddenGems = getHiddenGems()
const upcomingEvents = getUpcomingEvents()
const now = Date.now()

const leanGuilds: LeaderboardGuild[] = guilds.map((g) => ({
  slug: g.slug,
  rank: g.rank,
  name: g.name,
  guildName: g.guildName,
  builders: g.builders,
  tags: g.tags,
  score: g.score,
  lastModified: g.lastModified,
  coverImage: g.coverImage,
  screenshots: g.screenshots?.[0] ? [g.screenshots[0]] : undefined,
  buildTitle: g.buildTitle,
  isCurrent: g.isCurrent,
  posterDiscordId: g.posterDiscordId,
  postedOnBehalfOf: g.postedOnBehalfOf,
}))

// Toggle this to restore normal sections after the event
const SHOW_BEYOND_WALL_EVENT = false

const upcomingEventsDisplay = upcomingEvents.map((event) => {
  const startMs = new Date(event.scheduledStart).getTime()
  const endMs = event.scheduledEnd ? new Date(event.scheduledEnd).getTime() : startMs
  const live = event.status === "active" || (startMs <= now && endMs >= now)
  const minsUntil = Math.round((startMs - now) / 60000)
  const urgent = !live && minsUntil >= 0 && minsUntil <= 60
  const h = Math.floor(minsUntil / 60)
  const m = minsUntil % 60
  const timeLabel = live
    ? "Live now"
    : urgent
    ? `in ${minsUntil} min`
    : minsUntil <= 1440
    ? m > 0 ? `in ${h}h${m}m` : `in ${h}h`
    : `in ${Math.round(minsUntil / 1440)}d`
  return { ...event, live, urgent, timeLabel, startMs }
}).sort((a, b) => a.startMs - b.startMs)
const eventsToShow = upcomingEventsDisplay.slice(0, 4)
const articlesToShow = featuredArticles.slice(0, Math.max(0, 4 - eventsToShow.length))
---

<Layout
  title="Where Builders Meet | Awesome constructions and builders in Where Winds Meet"
  description="Community gallery of guild base constructions in Where Winds Meet, ranked by community votes. Find base building inspiration from top builders."
  image={ogImage}
  preloadImage={heroFirst?.img}
>
  <style>
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(14px) scale(0.98); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    .fade-up {
      opacity: 0;
      animation: fadeUp 0.45s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
    @keyframes eventGlow {
      0%, 100% { box-shadow: 0 0 0 1px rgb(34 211 238 / 0.5), 0 0 10px 0px rgb(34 211 238 / 0); }
      50%       { box-shadow: 0 0 0 1px rgb(34 211 238 / 0.9), 0 0 18px 4px rgb(34 211 238 / 0.2); }
    }
    .event-urgent { animation: eventGlow 2s ease-in-out infinite; }
    @keyframes eventLive {
      0%, 100% { box-shadow: 0 0 0 1px rgb(74 222 128 / 0.5), 0 0 10px 0px rgb(74 222 128 / 0); }
      50%       { box-shadow: 0 0 0 1px rgb(74 222 128 / 0.9), 0 0 18px 4px rgb(74 222 128 / 0.25); }
    }
    .event-live { animation: eventLive 2s ease-in-out infinite; }
  </style>

  <div class="space-y-6">
    <!-- Hero banner -->
    <div class="-mx-4 -mt-8 rounded-2xl relative h-56 sm:h-72 overflow-hidden mb-2">
      <div class="absolute inset-0 bg-muted" />
      <img
        id="hero-img"
        src={heroFirst?.img ?? ""}
        alt=""
        fetchpriority="high"
        loading="eager"
        class={`absolute inset-0 w-full h-full object-cover object-center transition-opacity duration-300${heroFirst ? "" : " hidden"}`}
        aria-hidden="true"
      />
      <div class="absolute inset-0 bg-linear-to-t from-black/60 via-black/20 to-black/5 dark:from-black/85 dark:via-black/35 dark:to-black/10" />
      <a
        id="hero-credit"
        href={heroFirst?.href ?? "#"}
        class={`absolute top-3 right-4 items-center gap-1.5 bg-black/40 backdrop-blur-sm border border-white/15 rounded-full px-2.5 py-1 text-xs text-white/70 hover:text-white hover:bg-black/60 transition-all group${heroFirst ? " flex" : " hidden"}`}
        title="View this guild"
        data-umami-event="hero_guild_credit_click"
        data-umami-event-name={heroFirst?.name}
      >
        <span id="hero-label" class="max-w-28 truncate">{heroFirst?.label}</span>
        <span id="hero-builders" class={`text-white/45 text-[11px] max-w-24 truncate shrink-0${heroFirst?.builders ? "" : " hidden"}`}>{heroFirst?.builders ? `by ${heroFirst.builders}` : ""}</span>
        <svg class="size-3 shrink-0 opacity-60 group-hover:opacity-100 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
      </a>
      <script is:inline define:vars={{ heroCandidates }}>
        if (heroCandidates.length > 1) {
          // Defer randomization until idle so heroFirst is always the LCP candidate
          // (preloaded + fetchpriority=high). The swap happens after first paint.
          var doSwap = function() {
            var idx = Math.floor(Math.random() * heroCandidates.length)
            var c = heroCandidates[idx]
            if (idx !== 0 && c) {
              var img = document.getElementById("hero-img")
              if (!img) return
              img.style.opacity = "0"
              img.onload = function() { img.style.opacity = "1" }
              img.src = c.img
              var credit = document.getElementById("hero-credit")
              credit.href = c.href
              credit.dataset.umamiEventName = c.name
              document.getElementById("hero-label").textContent = c.label
              var b = document.getElementById("hero-builders")
              if (c.builders) { b.textContent = "by " + c.builders; b.classList.remove("hidden") }
              else { b.classList.add("hidden") }
            }
          }
          if (typeof requestIdleCallback !== "undefined") {
            requestIdleCallback(doSwap)
          } else {
            setTimeout(doSwap, 200)
          }
        }
      </script>
      <div class="absolute bottom-0 left-0 right-0 px-6 pb-6">
        <h1 class="font-heading text-2xl sm:text-3xl font-bold text-white drop-shadow mb-1.5 flex items-center gap-3 flex-wrap">
          <span class="flex items-center gap-2"><img src="/images/logo_1.webp" alt="" aria-hidden="true" class="size-14 object-contain" /> Guilds</span>
          <span class="flex items-center gap-2 font-normal text-xs text-white/80">
            <span class="inline-flex items-center gap-1.5 bg-white/10 backdrop-blur-sm border border-white/15 rounded-full px-2.5 py-1">
              <img src="/images/logo_1.webp" alt="" aria-hidden="true" class="size-3 object-contain" /> {guilds.length} guilds
            </span>
            {lastSync && (
              <span class="inline-flex items-center gap-1.5 bg-white/10 backdrop-blur-sm border border-white/15 rounded-full px-2.5 py-1">
                <ArrowsClockwiseIcon weight="fill" className="size-3 text-green-400" />
                {formatSyncDate(lastSync)}
              </span>
            )}
          </span>
        </h1>
        <p class="text-white/65 text-sm">Beautiful constructions in Where Winds Meet</p>
      </div>
    </div>

    <!-- Beyond the Wall event banner (temporary) — set SHOW_BEYOND_WALL_EVENT = false to restore normal sections -->
    {SHOW_BEYOND_WALL_EVENT && (
      <section>
        <a
          href="https://discord.com/events/1483447710617960508/1505853545424093265"
          target="_blank"
          rel="noopener noreferrer"
          class="group relative flex rounded-2xl overflow-hidden ring-1 ring-pink-500/40 hover:ring-pink-500/70 hover:shadow-xl transition-all h-48 sm:h-56"
          data-umami-event="beyond_wall_event_banner_click"
        >
          {/* background */}
          <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/events/beyond-the-wall/houses_on_hill.jpg'); filter: brightness(0.45) saturate(0.7);" />
          <div class="absolute inset-0 bg-linear-to-r from-black/90 via-black/60 to-transparent" />
          <div class="absolute inset-0 bg-linear-to-t from-black/70 via-transparent to-transparent" />
          {/* build thumbnails strip — right side */}
          <div class="absolute right-0 top-0 bottom-0 w-2/5 hidden sm:flex">
            <div class="flex-1 overflow-hidden"><img src="/events/beyond-the-wall/dream_house.jpg" alt="" aria-hidden="true" class="w-full h-full object-cover opacity-70" style="mask-image: linear-gradient(to right, transparent 0%, black 40%); -webkit-mask-image: linear-gradient(to right, transparent 0%, black 40%);" /></div>
            <div class="flex-1 overflow-hidden"><img src="/events/beyond-the-wall/coffee.jpg" alt="" aria-hidden="true" class="w-full h-full object-cover opacity-70" /></div>
          </div>
          {/* content */}
          <div class="relative flex flex-col justify-center gap-2 px-6 py-5 max-w-lg">
            <div class="flex items-center gap-2">
              <span id="btw-dot" class="size-2 rounded-full bg-pink-400 animate-pulse shrink-0" />
              <span id="btw-label" class="text-[10px] font-semibold uppercase tracking-widest text-pink-400">WWM Event · May 19 · 15:00 UTC</span>
            </div>
            <div>
              <p class="text-xl sm:text-2xl font-bold text-white leading-tight drop-shadow">
                Beyond the Wall <span class="text-pink-400">with Carni</span>
              </p>
              <p class="text-sm text-white/70 mt-1">
                Carni, one of the finest builders, streams CN content live on Discord
              </p>
              <p class="text-xs text-white/50 mt-0.5">
                Join <span class="text-indigo-300 font-medium">#General Voice</span> to watch · Open to everyone
              </p>
            </div>
            <div class="flex items-center gap-2 mt-1 flex-wrap">
              <span class="inline-flex items-center gap-1.5 bg-white/8 ring-1 ring-white/15 rounded-full px-3 py-1 text-xs text-white/75">
                📅 Tuesday, May 19, 2026 · 15:00 UTC
              </span>
              <span class="inline-flex items-center gap-1.5 bg-pink-500/20 ring-1 ring-pink-500/50 rounded-full px-3 py-1 text-xs font-semibold text-pink-200 group-hover:bg-pink-500/35 transition-colors">
                🎙️ Join the event ↗
              </span>
            </div>
          </div>
        </a>
        <script is:inline>
          (function () {
            const startMs = 1779202800 * 1000
            function update() {
              const now = Date.now()
              const diff = startMs - now
              const label = document.getElementById("btw-label")
              const dot = document.getElementById("btw-dot")
              if (!label) return
              if (diff <= 0 && diff > -7200000) {
                label.textContent = "🟢 Live now"
                label.classList.replace("text-pink-400", "text-green-400")
                if (dot) { dot.classList.replace("bg-pink-400", "bg-green-400"); dot.classList.replace("animate-pulse", "animate-ping") }
              } else if (diff > 0) {
                const h = Math.floor(diff / 3600000)
                const m = Math.floor((diff % 3600000) / 60000)
                label.textContent = "WWM Event · " + (h > 24 ? `in ${Math.round(h / 24)}d` : m > 0 ? `in ${h}h${m}m` : `in ${h}h`)
              }
            }
            update()
            setInterval(update, 30000)
          })()
        </script>
      </section>
    )}

    <!-- Recently added -->
    {latestGuilds.length > 0 && (
      <section>
        <h2 class="font-heading text-base font-medium mb-1 flex items-center gap-2">
          <SparkleIcon weight="duotone" className="size-4 text-blue-500" /> Recently added
        </h2>
        <div class="px-5">
          {useCarousel ? (
            <GuildCarousel client:idle guilds={latestGuilds} showDate={true} />
          ) : (
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
              {latestGuilds.map((g, idx) => {
                const shots = g.screenshots ?? []
                const img = g.coverImage ?? shots[0]
                return (
                  <div
                    class="fade-up group relative overflow-hidden rounded-xl ring-1 ring-border aspect-video bg-muted hover:ring-primary transition-all"
                    style={`animation-delay: ${idx * 80}ms`}
                  >
                    <a
                      href={`${BASE}/guilds/${g.slug}`}
                      class="absolute inset-0 z-10"
                      aria-label={stripGuildShowcase(g.guildName || g.name)}
                      data-umami-event="guild_click"
                      data-umami-event-name={g.name}
                      data-umami-event-source="recently_added"
                      data-umami-event-type="guilds"
                    />
                    {img && (
                      <img
                        src={thumbUrl(img)}
                        alt={stripGuildShowcase(g.guildName || g.name)}
                        loading="lazy"
                        onerror="this.style.display='none'"
                        class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                      />
                    )}
                    <div class="absolute inset-0 bg-linear-to-t from-black/70 to-transparent" />
                    {g.createdAt && (
                      <div class="absolute top-2 left-2 z-20 text-[10px] font-medium px-1.5 py-0.5 rounded-md bg-black/50 backdrop-blur-sm text-white/60">
                        {relativeDate(g.createdAt)}
                      </div>
                    )}
                    <div class="absolute top-2 right-2 z-20 flex items-center gap-1.5">
                      {g.buildTitle && (
                        <div class="flex items-center gap-1 text-[10px] font-medium px-1.5 py-0.5 rounded-md bg-black/50 backdrop-blur-sm text-blue-300">
                          <StackIcon weight="fill" className="size-2.5 shrink-0" />
                          {g.buildTitle}
                        </div>
                      )}
                      {g.rank <= 10 && (
                        <div class="text-[11px] font-bold font-mono px-1.5 py-0.5 rounded-md bg-black/50 backdrop-blur-sm text-white/90">
                          #{g.rank}
                        </div>
                      )}
                    </div>
                    <div class="absolute bottom-0 left-0 right-0 p-3 z-20">
                      <div class="flex items-baseline gap-1.5 mb-1">
                        <p class="text-white font-medium text-sm leading-tight">
                          {stripGuildShowcase(g.guildName || g.name)}
                        </p>
                        {g.builders && g.builders.length > 0 && (
                          <p class="text-white/60 text-[11px] leading-tight truncate">by <BuilderLinks builders={g.builders} activeBuilders={activeBuilders} /></p>
                        )}
                      </div>
                      {g.tags && g.tags.length > 0 && (
                        <div class="flex flex-wrap gap-1">
                          {g.tags.slice(0, 3).map((tag) => {
                            const cfg = tagColor(tag)
                            return (
                              <span class={`inline-flex items-center rounded-full ${cfg.bg} ${cfg.text} ${cfg.ring} backdrop-blur-sm px-2 py-0.5 text-[10px] font-medium`}>
                                {tag}
                              </span>
                            )
                          })}
                        </div>
                      )}
                    </div>
                  </div>
                )
              })}
            </div>
          )}
          <p class="text-xs text-muted-foreground mt-3">Want to add your guild? <a href={`${BASE}/contribute`} class="text-foreground underline underline-offset-2 hover:text-primary transition-colors" data-umami-event="contribute_cta_click">Contribute ↗</a></p>
        </div>
      </section>
    )}


    <!-- Featured Articles + Events -->
    {!SHOW_BEYOND_WALL_EVENT && (articlesToShow.length > 0 || eventsToShow.length > 0) && (
      <section>
        <h2 class="font-heading text-base font-medium mb-1 flex items-center gap-2">
          <svg class="size-4 text-pink-800 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
          Featured articles & events
        </h2>
        <div class="px-5">
        <div class="flex flex-col sm:flex-row flex-wrap gap-2">
        {eventsToShow.map((event) => {
          const { live, urgent, timeLabel } = event
          return (
            <a
              href={`${BASE}/events`}
              class={`event-card group flex flex-1 items-center gap-3 rounded-xl bg-card hover:shadow-sm transition-all px-3 py-2.5 ${live ? "event-live bg-green-500/5" : urgent ? "event-urgent bg-cyan-500/5" : "ring-1 ring-cyan-500/25 hover:ring-cyan-500/50"}`}
              data-umami-event="upcoming_event_click"
              data-start={event.scheduledStart}
              data-end={event.scheduledEnd ?? ""}
              data-status={event.status ?? ""}
            >
              {event.image ? (
                <div class="relative shrink-0 w-32 aspect-video rounded-md overflow-hidden bg-black">
                  <img
                    src={event.image}
                    alt={event.name}
                    class="absolute inset-0 h-full w-full object-cover"
                  />
                </div>
              ) : (
                <div class={`event-icon-bg shrink-0 w-32 aspect-video rounded-md flex items-center justify-center ${live ? "bg-green-500/20" : urgent ? "bg-cyan-500/20" : "bg-cyan-500/10"}`}>
                  <CalendarDotIcon weight="duotone" className={`event-icon size-5 ${live ? "text-green-300" : urgent ? "text-cyan-300" : "text-cyan-400"}`} />
                </div>
              )}
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-1.5 mb-0.5">
                  <span class={`event-dot inline-block size-1.5 rounded-full shrink-0 ${live ? "bg-green-400 animate-ping" : urgent ? "bg-cyan-300 animate-ping" : "bg-cyan-400 animate-pulse"}`} />
                  <span class={`event-label text-[10px] font-semibold uppercase tracking-widest ${live ? "text-green-400" : urgent ? "text-cyan-300" : "text-cyan-400"}`}>
                    {live ? "🟢 " : urgent ? "🔔 " : ""}Event {timeLabel}
                  </span>
                </div>
                <p class={`text-xs font-medium leading-snug line-clamp-2 ${live || urgent ? "text-foreground" : ""}`}>{event.name}</p>
                {event.guildName && (
                  <p class="text-xs text-muted-foreground/70 truncate">{event.guildName}</p>
                )}
              </div>
              <svg class={`event-arrow size-3.5 shrink-0 transition-all group-hover:translate-x-0.5 ${live ? "text-green-400" : urgent ? "text-cyan-400" : "text-muted-foreground/40 group-hover:text-cyan-400"}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          )
        })}
        {articlesToShow.map((fa) => {
          return (
            <a
              href={`${BASE}/tutorials/${fa.article.id}`}
              class="group flex flex-1 items-center gap-3 rounded-xl ring-1 ring-pink-500/25 bg-card hover:ring-pink-500/50 hover:shadow-sm transition-all px-3 py-2.5"
              data-umami-event="featured_article_click"
            >
              {fa.thumb ? (
                <div class="relative shrink-0 w-32 aspect-video rounded-md overflow-hidden bg-black">
                  <img
                    src={fa.thumb}
                    alt={fa.article.data.title}
                    class="absolute inset-0 h-full w-full object-cover"
                  />
                </div>
              ) : (
                <div class="shrink-0 w-32 aspect-video rounded-md bg-pink-500/10 flex items-center justify-center">
                  <BookOpenIcon weight="duotone" className="size-5 text-pink-400" />
                </div>
              )}
              <div class="flex-1 min-w-0">
                <p class="text-xs font-medium leading-snug line-clamp-2 mb-0.5">{fa.article.data.title}</p>
                {fa.article.data.authors && fa.article.data.authors.length > 0 && (
                  <p class="text-[11px] text-muted-foreground/70">by {fa.article.data.authors.join(", ")}</p>
                )}
              </div>
              <svg class="size-3.5 shrink-0 text-muted-foreground/40 group-hover:text-pink-500 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          )
        })}
        <script is:inline>
          function updateEventCards() {
            const now = Date.now()
            document.querySelectorAll(".event-card").forEach(function(card) {
              const startMs = new Date(card.dataset.start).getTime()
              const endMs = card.dataset.end ? new Date(card.dataset.end).getTime() : startMs
              const isLive = card.dataset.status === "active" || (startMs <= now && endMs >= now)
              const minsUntil = Math.round((startMs - now) / 60000)
              const isUrgent = !isLive && minsUntil >= 0 && minsUntil <= 60
              const h = Math.floor(minsUntil / 60)
              const m = minsUntil % 60
              const timeLabel = isLive
                ? "Live now"
                : isUrgent
                ? "in " + minsUntil + " min"
                : minsUntil <= 1440
                ? m > 0 ? "in " + h + "h" + m + "m" : "in " + h + "h"
                : "in " + Math.round(minsUntil / 1440) + "d"

              // Update card classes
              card.classList.remove("event-live", "event-urgent", "ring-1", "ring-cyan-500/25", "hover:ring-cyan-500/50", "bg-green-500/5", "bg-cyan-500/5")
              if (isLive) {
                card.classList.add("event-live", "bg-green-500/5")
              } else if (isUrgent) {
                card.classList.add("event-urgent", "bg-cyan-500/5")
              } else {
                card.classList.add("ring-1", "ring-cyan-500/25", "hover:ring-cyan-500/50")
              }

              // Update dot
              const dot = card.querySelector(".event-dot")
              if (dot) {
                dot.className = "event-dot inline-block size-1.5 rounded-full shrink-0 " +
                  (isLive ? "bg-green-400 animate-ping" : isUrgent ? "bg-cyan-300 animate-ping" : "bg-cyan-400 animate-pulse")
              }

              // Update label
              const label = card.querySelector(".event-label")
              if (label) {
                label.className = "event-label text-[10px] font-semibold uppercase tracking-widest " +
                  (isLive ? "text-green-400" : isUrgent ? "text-cyan-300" : "text-cyan-400")
                label.textContent = (isLive ? "🟢 " : isUrgent ? "🔔 " : "") + "Event " + timeLabel
              }

              // Update icon bg
              const iconBg = card.querySelector(".event-icon-bg")
              if (iconBg) {
                iconBg.className = "event-icon-bg shrink-0 w-32 aspect-video rounded-md flex items-center justify-center " +
                  (isLive ? "bg-green-500/20" : isUrgent ? "bg-cyan-500/20" : "bg-cyan-500/10")
              }

              // Update icon color
              const icon = card.querySelector(".event-icon")
              if (icon) {
                icon.className = "event-icon size-5 " +
                  (isLive ? "text-green-300" : isUrgent ? "text-cyan-300" : "text-cyan-400")
              }

              // Update arrow color
              const arrow = card.querySelector(".event-arrow")
              if (arrow) {
                arrow.className = "event-arrow size-3.5 shrink-0 transition-all group-hover:translate-x-0.5 " +
                  (isLive ? "text-green-400" : isUrgent ? "text-cyan-400" : "text-muted-foreground/40 group-hover:text-cyan-400")
              }
            })
          }
          updateEventCards()
          setInterval(updateEventCards, 30000)
        </script>
      </div>
        </div>
      </section>
    )}

    <!-- Catalog discovery banner -->
    {!SHOW_BEYOND_WALL_EVENT && <a
      href={`${BASE}/catalog`}
      class="group relative flex items-center gap-3 rounded-xl ring-1 ring-amber-500/35 bg-linear-to-r from-amber-500/12 via-amber-500/6 to-card hover:ring-amber-500/65 hover:from-amber-500/18 hover:shadow-md transition-all px-4 py-2.5 overflow-hidden"
      data-umami-event="catalog_banner_click"
    >
      <div class="absolute right-0 top-0 bottom-0 w-24 bg-linear-to-l from-orange-500/8 to-transparent pointer-events-none" />
      <div class="shrink-0 flex items-center gap-1">
        {[
          { cat: "Basic Structure",      label: "Basic Structure" },
          { cat: "Furniture Decoration", label: "Furniture Decoration" },
          { cat: "Guild Construction",   label: "Guild Construction" },
        ].map(({ cat, label }) => (
          <img
            src={`/catalog/${encodeURIComponent(cat)}/icon.png`}
            alt={label}
            class="size-7 object-contain transition-transform group-hover:scale-110"
            style="filter: brightness(0) saturate(100%) invert(60%) sepia(80%) saturate(600%) hue-rotate(340deg) drop-shadow(0 0 3px rgba(251,146,60,0.45))"
          />
        ))}
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-semibold flex items-center gap-2">
          {/* <HammerIcon weight="duotone" className="size-4 text-amber-400 shrink-0" /> */}
          Construction Catalog
          <span class="text-xs font-normal text-muted-foreground hidden sm:inline"> every WWM building item in one place</span>
        </p>
      </div>
      <svg class="size-4 shrink-0 text-amber-400/55 group-hover:text-amber-400 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
    </a>}

    <!-- Ranked table -->
    <section>
      <h2 class="font-heading text-base font-medium mb-3 flex items-center gap-2"><img src="/images/logo_mountain1.webp" alt="" aria-hidden="true" class="size-10 object-contain" /> All Guild bases</h2>
      <LeaderboardTable client:visible guilds={leanGuilds} allTags={allTags} activeBuilderSlugs={[...activeBuilders]} />
      <noscript>
        <ul class="mt-4 space-y-1 text-sm">
          {guilds.map((g) => (
            <li>
              <a href={`${BASE}/guilds/${g.slug}`}>
                #{g.rank} {g.guildName || g.name} — by {g.builders?.join(", ") || "—"} — Score: {g.score}
              </a>
            </li>
          ))}
        </ul>
      </noscript>
      <p class="text-xs text-muted-foreground mt-3">Want to vote? <a href={`${BASE}/how-it-works`} class="text-foreground underline underline-offset-2 hover:text-primary transition-colors">Votes count more when you explore many guilds ↗</a></p>
    </section>

    <!-- Building requests banner -->
    <a
      href="https://discord.gg/Qygt9u26Bn"
      target="_blank"
      rel="noopener noreferrer"
      class="group relative flex items-center gap-3 rounded-xl ring-1 ring-indigo-500/35 bg-linear-to-r from-indigo-500/12 via-indigo-500/6 to-card hover:ring-indigo-500/65 hover:from-indigo-500/18 hover:shadow-md transition-all px-4 py-2.5 overflow-hidden"
      data-umami-event="building_requests_banner_click"
    >
      <div class="absolute right-0 top-0 bottom-0 w-24 bg-linear-to-l from-indigo-500/8 to-transparent pointer-events-none" />
      <div class="shrink-0 flex items-center justify-center size-9 rounded-lg bg-indigo-500/15">
        <UsersIcon weight="duotone" className="size-5 text-indigo-400 transition-transform group-hover:scale-110" />
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-semibold flex items-center gap-2">
          Looking for a builder?
          <span class="text-xs font-normal text-muted-foreground hidden sm:inline">— Find your match on Discord <span class="text-indigo-400">#building-requests</span></span>
        </p>
      </div>
      <svg class="size-4 shrink-0 text-indigo-400/55 group-hover:text-indigo-400 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
    </a>

    <!-- Top rated carousel -->
    {topGuilds.length > 0 && (
      <section>
        <h2 class="font-heading text-base font-medium mb-1 flex items-center gap-2"><TrophyIcon weight="duotone" className="size-4 text-yellow-400" /> Top-rated Guild bases</h2>
        <div class="px-5">
          <GuildCarousel client:visible guilds={topGuilds} showRank={false} />
        </div>
      </section>
    )}

    <!-- Hidden gems -->
    {hiddenGems.length > 0 && (
      <section>
        <h2 class="font-heading text-base font-medium mb-1 flex items-center gap-2"><DiamondIcon weight="duotone" className="size-4 text-cyan-400" /> Hidden Gems</h2>
        <div class="px-5">
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            {hiddenGems.map((g, idx) => {
              const shots = g.screenshots ?? []
              const img = g.coverImage ?? shots[0]
              return (
                <div
                  class="fade-up group relative overflow-hidden rounded-xl ring-1 ring-border aspect-video bg-muted hover:ring-primary transition-all"
                  style={`animation-delay: ${idx * 80}ms`}
                >
                  <a
                    href={`${BASE}/guilds/${g.slug}`}
                    class="absolute inset-0 z-10"
                    aria-label={stripGuildShowcase(g.guildName || g.name)}
                    data-umami-event="guild_click"
                    data-umami-event-name={g.name}
                    data-umami-event-source="hidden_gems"
                    data-umami-event-type="guilds"
                  />
                  {img && (
                    <img
                      src={thumbUrl(img)}
                      alt={stripGuildShowcase(g.guildName || g.name)}
                      loading="lazy"
                      onerror="this.style.display='none'"
                      class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                    />
                  )}
                  <div class="absolute inset-0 bg-linear-to-t from-black/70 to-transparent" />
                  <div class="absolute top-2 right-2 z-20 flex items-center gap-1.5">
                    {g.buildTitle && (
                      <div class="flex items-center gap-1 text-[10px] font-medium px-1.5 py-0.5 rounded-md bg-black/50 backdrop-blur-sm text-blue-300">
                        <StackIcon weight="fill" className="size-2.5 shrink-0" />
