                <span class="hidden sm:inline">🗺️ Register to the tour ↗</span>
              </span>
            </div>
          </div>
        </a>
        <script is:inline define:vars={{ tourStartMs, tourEndMs }}>
          (function () {
            function update() {
              const now = Date.now()
              const diff = tourStartMs - now
              const isLive = diff <= 0 && (tourEndMs - now) >= 0
              const label = document.getElementById("tour-label")
              const dot = document.getElementById("tour-dot")
              if (!label) return
              if (isLive) {
                label.textContent = "🟢 Live now"
                label.className = "text-[10px] font-semibold uppercase tracking-widest text-green-400"
                if (dot) { dot.className = "size-2 rounded-full shrink-0 bg-green-400 animate-ping" }
              } else if (diff > 0) {
                const h = Math.floor(diff / 3600000)
                const m = Math.floor((diff % 3600000) / 60000)
                const t = diff <= 3600000 ? `in ${Math.round(diff / 60000)} min` : m > 0 ? `in ${h}h${m}m` : `in ${h}h`
                label.textContent = "Base Tour · " + t
              }
            }
            update()
            setInterval(update, 30000)
          })()
        </script>
      </section>
