---
import Layout from "@/layouts/main.astro"
import TopShowcase from "@/components/TopShowcase.astro"
import { GuildTable } from "@/components/GuildTable"
import { getGuildsSortedByScore, getAllTags, getLastSyncDate } from "@/lib/guilds"

const guilds = getGuildsSortedByScore()
const allTags = getAllTags()
const lastSync = getLastSyncDate()
const topGuilds = guilds.filter((g) => g.screenshots && g.screenshots.length > 0).slice(0, 9)
---

<Layout>
  <div class="space-y-12">
    <!-- Hero -->
    <div>
      <h1 class="font-heading text-2xl font-semibold mb-1">
        🏰 Guild Bases
      </h1>
      <p class="text-muted-foreground text-sm">
        {guilds.length} bases · The most beautiful constructions in Jiang Hu ·{" "}
        <a href="https://discord.gg/Qygt9u26Bn" class="underline hover:text-foreground transition-colors">
          add yours on Discord
        </a>
      </p>
      <p class="text-xs text-muted-foreground mt-1">🔄 Last sync: {lastSync}</p>
    </div>

    <!-- Top showcase -->
    {
      topGuilds.length > 0 && (
        <section>
          <div class="flex items-center gap-2 mb-3">
            <h2 class="font-heading text-base font-medium">✨ Top-rated Guild bases</h2>
            <button
              id="shuffle-showcase"
              title="Shuffle images"
              class="text-muted-foreground hover:text-foreground transition-colors cursor-pointer"
              aria-label="Shuffle showcase images"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 18h1.4c1.3 0 2.5-.6 3.3-1.7l6.1-8.6c.7-1.1 2-1.7 3.3-1.7H22"/>
                <path d="m18 2 4 4-4 4"/>
                <path d="M2 6h1.9c1.5 0 2.9.9 3.6 2.2"/>
                <path d="M22 18h-5.9c-1.3 0-2.5-.6-3.3-1.7l-.5-.8"/>
                <path d="m18 14 4 4-4 4"/>
              </svg>
            </button>
          </div>
          <TopShowcase guilds={topGuilds} />
        </section>
      )
    }

    <!-- Ranked table -->
    <section>
      <h2 class="font-heading text-base font-medium mb-3">📸 All Guild bases</h2>
      <GuildTable client:load guilds={guilds} allTags={allTags} />
    </section>
  </div>
</Layout>

<script>
  const btn = document.getElementById("shuffle-showcase")
  const grid = document.getElementById("top-showcase-grid")
  if (btn && grid) {
    btn.addEventListener("click", () => {
      grid.querySelectorAll<HTMLAnchorElement>("a[data-screenshots]").forEach((card) => {
        const shots: string[] = JSON.parse(card.dataset.screenshots ?? "[]")
        if (shots.length === 0) return
        const img = card.querySelector("img")
        if (!img) return
        const pick = shots[Math.floor(Math.random() * shots.length)]
        img.style.opacity = "0"
        img.style.transition = "opacity 0.2s"
        setTimeout(() => {
          img.src = pick
          img.style.opacity = "1"
        }, 200)
      })
    })
  }
</script>
