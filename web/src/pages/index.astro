---
import Layout from "@/layouts/main.astro"
import { GuildCarousel } from "@/components/GuildCarousel"
import { GuildTable } from "@/components/GuildTable"
import { getGuildsSortedByScore, getAllTags, getLastSyncDate, getLatestGuildsWithScreenshots } from "@/lib/guilds"
import { BASE } from "@/lib/url"
import { Badge } from "@/components/ui/badge"
import { CastleTurret, ArrowsClockwise, Trophy, Sparkle, Buildings } from "@phosphor-icons/react"

const guilds = getGuildsSortedByScore()
const allTags = getAllTags()
const lastSync = getLastSyncDate()
const topGuilds = guilds.filter((g) => g.screenshots && g.screenshots.length > 0).slice(0, 12)
const latestGuilds = getLatestGuildsWithScreenshots(3)
---

<Layout>
  <div class="space-y-12">
    <!-- Hero -->
    <div class="flex flex-col gap-3">
      <div class="flex items-center gap-3 flex-wrap">
        <h1 class="font-heading text-3xl font-bold tracking-tight flex items-center gap-2"><CastleTurret weight="duotone" className="size-7 text-red-500" /> Guild Bases</h1>
        <Badge variant="secondary">{guilds.length} bases</Badge>
        <Badge variant="outline" className="font-normal text-muted-foreground gap-1.5">
          <ArrowsClockwise weight="fill" className="size-3 text-green-500" /> Last sync: {lastSync}
        </Badge>
      </div>
      <p class="text-muted-foreground">
        The most beautiful constructions in Jiang Hu. <span class="whitespace-nowrap">Share yours on <a href="https://discord.gg/Qygt9u26Bn" class="text-foreground underline underline-offset-2 hover:text-primary transition-colors">Discord ↗</a></span>
      </p>
    </div>

    <!-- Top rated carousel -->
    {
      topGuilds.length > 0 && (
        <section>
          <h2 class="font-heading text-base font-medium mb-4 flex items-center gap-2"><Trophy weight="duotone" className="size-4 text-yellow-400" /> Top-rated Guild bases</h2>
          <div class="px-5">
            <GuildCarousel client:load guilds={topGuilds} />
          </div>
        </section>
      )
    }

    <!-- Latest guilds -->
    {
      latestGuilds.length > 0 && (
        <section>
          <h2 class="font-heading text-base font-medium mb-4 flex items-center gap-2"><Sparkle weight="duotone" className="size-4 text-blue-500" /> Recently added</h2>
          <div class="px-5"><div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            {latestGuilds.map((g) => {
              const shots = g.screenshots ?? []
              const img = shots[Math.floor(Math.random() * shots.length)]
              return (
                <a
                  href={`${BASE}/guilds/${g.slug}`}
                  class="group relative overflow-hidden rounded-xl ring-1 ring-border aspect-video bg-muted hover:ring-primary transition-all"
                >
                  {img && (
                    <img
                      src={img}
                      alt={g.name}
                      loading="lazy"
                      onerror="this.style.display='none'"
                      class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                    />
                  )}
                  <div class="absolute inset-0 bg-linear-to-t from-black/70 to-transparent" />
                  <div class="absolute bottom-0 left-0 right-0 p-3">
                    <p class="text-white font-medium text-sm leading-tight mb-1">{g.name}</p>
                    {g.tags && g.tags.length > 0 && (
                      <div class="flex flex-wrap gap-1">
                        {g.tags.slice(0, 3).map((tag) => (
                          <span class="inline-flex items-center rounded-full bg-black/40 backdrop-blur-sm px-2 py-0.5 text-[10px] text-white/90">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </a>
              )
            })}
          </div></div>
        </section>
      )
    }

    <!-- Ranked table -->
    <section>
      <h2 class="font-heading text-base font-medium mb-3 flex items-center gap-2"><Buildings weight="duotone" className="size-4 text-orange-500" /> All Guild bases</h2>
      <GuildTable client:load guilds={guilds} allTags={allTags} />
    </section>
  </div>
</Layout>
