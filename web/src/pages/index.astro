                      </div>
                    )}
                    {g.rank <= 10 && (
                      <div class="text-[11px] font-bold font-mono px-1.5 py-0.5 rounded-md bg-black/50 backdrop-blur-sm text-white/90">
                        #{g.rank}
                      </div>
                    )}
                  </div>
                  <div class="absolute bottom-0 left-0 right-0 p-3 z-20">
                    <div class="flex items-baseline gap-1.5 mb-1">
                      <p class="text-white font-medium text-sm leading-tight">
                        {stripGuildShowcase(g.guildName || g.name)}
