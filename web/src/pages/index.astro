---
import Layout from "@/layouts/main.astro"
import { GuildCarousel, type CarouselGuild } from "@/components/GuildCarousel"
import { LeaderboardTable, type LeaderboardGuild } from "@/components/LeaderboardTable"
import BuilderLinks from "@/components/BuilderLinks.astro"
import { getGuildsSortedByScore, getAllTags, getLastSyncDate, getLatestGuildsWithScreenshots, getRecentGuildsWithScreenshots, getHiddenGems, formatBuilderName, getUpcomingEvents, UPCOMING_EVENTS_WINDOW_MS, FEATURED_EVENTS_WINDOW_MS } from "@/lib/guilds"
import { stripGuildShowcase, thumbUrl, builderSlug } from "@/lib/format"
import { formatSyncDate } from "@/lib/dates"
import { getActiveBuilderSlugs } from "@/lib/builders"
import { isBuilderSubmission } from "@/lib/config"
import { BASE } from "@/lib/url"
import { tagColor } from "@/lib/colors"
import { GuildWall } from "@/components/GuildWall"
import { ArrowsClockwiseIcon, TrophyIcon, SparkleIcon, DiamondIcon, BookOpenIcon, CalendarDotIcon, StackIcon, UsersIcon, BroadcastIcon, MicrophoneStageIcon } from "@phosphor-icons/react"
import { getCollection, type CollectionEntry } from "astro:content"

// ─── Page toggles ────────────────────────────────────────────────────────────
const SHOW_BEYOND_WALL_EVENT = false   // restore after the event
const SHOW_PATCH_BANNER      = true    // v1.7 update banner
const SHOW_TOUR_BANNER       = true   // auto-shows when a tour event is within 24h
const SHOW_FEATURED_BANNERS  = true   // featured articles & events + catalog banner
const SHOW_GUILD_WALL        = true    // "Discover Guild Bases" random wall
const SHOW_TOP_RATED         = false    // "Top-rated Guild bases" carousel
const SHOW_HIDDEN_GEMS       = false    // "Hidden Gems" section
// ─────────────────────────────────────────────────────────────────────────────

function relativeDate(createdAt: string): string {
  const ms = Date.now() - new Date(createdAt.replace(" at ", " ")).getTime()
  if (isNaN(ms) || ms < 0) return ""
  const hours = Math.floor(ms / 3600000)
  const days = Math.floor(ms / 86400000)
  if (hours < 24) return hours <= 1 ? "1h ago" : `${hours}h ago`
  if (days === 1) return "yesterday"
  if (days < 7) return `${days}d ago`
  if (days < 30) return `${Math.floor(days / 7)}w ago`
  return `${Math.floor(days / 30)}mo ago`
}

const guilds = getGuildsSortedByScore()
const allArticles: CollectionEntry<"articles">[] = await getCollection("articles", (e: CollectionEntry<"articles">) => e.data.published !== false)
type FeaturedEntry = { article: CollectionEntry<"articles">; thumb: string }
const featuredArticles: FeaturedEntry[] = allArticles.filter((e) => e.data.featured).sort((a, b) => new Date(b.data.date ?? 0).getTime() - new Date(a.data.date ?? 0).getTime()).map((article) => {
  const body = article.body ?? ""
  const ytID = body.match(/youtube\.com\/embed\/([^"?\s]+)/)?.[1] ?? ""
  const firstImg = body.match(/<img[^>]+src=["']([^"']+)["']/)?.[1] ?? ""
  const thumb = ytID ? `https://img.youtube.com/vi/${ytID}/hqdefault.jpg` : (article.data.image ?? firstImg)
  return { article, thumb }
})
const tutorialAuthorSlugs = new Set<string>(allArticles.flatMap((a) => (a.data.authors ?? []).map((n: string) => builderSlug(n))))
const activeBuilders = getActiveBuilderSlugs(tutorialAuthorSlugs)
const allTags = getAllTags()
const lastSync = getLastSyncDate()
const topGuilds: CarouselGuild[] = guilds
  .filter((g) => g.screenshots && g.screenshots.length > 0)
  .slice(0, 12)
  .map((g) => ({
    slug: g.slug, rank: g.rank, name: g.name, guildName: g.guildName,
    builders: g.builders, tags: g.tags, coverImage: g.coverImage,
    screenshots: g.screenshots?.[0] ? [g.screenshots[0]] : undefined,
    buildTitle: g.buildTitle, createdAt: g.createdAt,
  }))
const ogImage = guilds.map((g) => g.coverImage ?? g.screenshots?.[0]).find(Boolean)

const heroCandidates = guilds
  .filter((g) => isBuilderSubmission(g) && (g.coverImage ?? g.screenshots?.[0]))
  .slice(0, 25)
  .map((g) => {
    const rawSrc = g.coverImage ?? g.screenshots![0]
    return {
      img: thumbUrl(rawSrc, 1400, 560),
      imgSm: thumbUrl(rawSrc, 800, 380),
      href: `${BASE}/guilds/${g.slug}`,
      name: g.name,
      label: stripGuildShowcase(g.guildName || g.name),
      builders: (g.builders ?? []).map(formatBuilderName).filter(Boolean).join(", "),
    }
  })
const heroFirst = heroCandidates[0]
const RECENT_GUILDS_DAYS = 7 // change this to widen or narrow the "recent" window
const recentGuilds = getRecentGuildsWithScreenshots(RECENT_GUILDS_DAYS)
const useCarousel = recentGuilds.length > 3
const latestGuilds: CarouselGuild[] = (useCarousel ? recentGuilds : getLatestGuildsWithScreenshots(3)).map((g) => ({
  slug: g.slug, rank: g.rank, name: g.name, guildName: g.guildName,
  builders: g.builders, tags: g.tags, coverImage: g.coverImage,
  screenshots: g.screenshots?.[0] ? [g.screenshots[0]] : undefined,
  buildTitle: g.buildTitle, createdAt: g.createdAt,
}))
const guildsWithScreenshots = guilds.filter((g) => g.coverImage || (g.screenshots && g.screenshots.length > 0))
const hiddenGems = getHiddenGems()
const upcomingEvents = getUpcomingEvents()
const now = Date.now()

const leanGuilds: LeaderboardGuild[] = guilds.map((g) => ({
  slug: g.slug,
  rank: g.rank,
  name: g.name,
  guildName: g.guildName,
  builders: g.builders,
  tags: g.tags,
  score: g.score,
  lastModified: g.lastModified,
  coverImage: g.coverImage,
  screenshots: g.screenshots?.[0] ? [g.screenshots[0]] : undefined,
  buildTitle: g.buildTitle,
  isCurrent: g.isCurrent,
  posterDiscordId: g.posterDiscordId,
  postedOnBehalfOf: g.postedOnBehalfOf,
  formerNames: g.formerNames,
}))

const BTW_EVENT = {
  url:          "https://discord.com/events/1483447710617960508/1512075806778855574",
  startUnixSec: 1780776000,           // date -d "2026-06-06 20:00 UTC" +%s
  durationMs:   2 * 60 * 60 * 1000,  // how long "Live now" stays shown
  dateLabel:    "Saturday, June 6, 2026 · 20:00 UTC",
  dateLabelShort: "Jun 6 · 20:00 UTC",
  title:        "Beyond the Wall",
  titleAccent:  "with Carni",
  description:  "Carni, one of the finest builders, streams CN content live on Discord",
  channel:      "#General Voice",
  imgBg:        "/events/beyond-the-wall/greenzen.jpg",
  imgLeft:      "/events/beyond-the-wall/luminoushall.jpg",
  imgRight:     "/events/beyond-the-wall/palace.jpg",
}
// Auto-show a tour banner when a tour event starts within UPCOMING_EVENTS_WINDOW_MS (or is live)
const upcomingTourEvent = SHOW_TOUR_BANNER
  ? (upcomingEvents.find(e => {
      if (e.type !== "tour") return false
      if (!e.name.toLowerCase().includes("panda base tour")) return false
      const startMs = new Date(e.scheduledStart).getTime()
      const endMs = e.scheduledEnd ? new Date(e.scheduledEnd).getTime() : startMs
      const isLive = e.status === "active" || (startMs <= now && endMs >= now)
      const isSoon = startMs > now && (startMs - now) <= UPCOMING_EVENTS_WINDOW_MS
      return isLive || isSoon
    }) ?? null)
  : null

const tourStartMs = upcomingTourEvent ? new Date(upcomingTourEvent.scheduledStart).getTime() : 0
const tourEndMs = upcomingTourEvent?.scheduledEnd ? new Date(upcomingTourEvent.scheduledEnd).getTime() : tourStartMs
const tourIsLive = upcomingTourEvent
  ? (upcomingTourEvent.status === "active" || (tourStartMs <= now && tourEndMs >= now))
  : false
const tourMinsUntil = upcomingTourEvent ? Math.round((tourStartMs - now) / 60000) : 0
const tourH = Math.floor(tourMinsUntil / 60)
const tourM = tourMinsUntil % 60
const tourTimeLabel = tourIsLive
  ? "Live now"
  : tourMinsUntil <= 60
  ? `in ${tourMinsUntil} min`
  : tourM > 0 ? `in ${tourH}h${tourM}m` : `in ${tourH}h`

// Extract guild slugs from wherebuildersmeet.com links in the tour description
const tourGuildSlugs: string[] = upcomingTourEvent?.description
  ? [...upcomingTourEvent.description.matchAll(/wherebuildersmeet\.com\/guilds\/([a-z0-9-]+)/g)].map(m => m[1])
  : []

// Resolve images and names for tour stop guilds
const tourGuildCards = tourGuildSlugs
  .map(slug => guilds.find(g => g.slug === slug))
  .filter((g): g is (typeof guilds)[0] => g != null && !!(g.coverImage ?? g.screenshots?.[0]))
  .slice(0, 3)
  .map(g => ({
    slug: g.slug,
    name: stripGuildShowcase(g.guildName || g.name),
    img: thumbUrl(g.coverImage ?? g.screenshots![0], 640, 360),
    href: `${BASE}/guilds/${g.slug}`,
  }))

// Format tour start date for display (UTC)
const _tourDate = upcomingTourEvent ? new Date(upcomingTourEvent.scheduledStart) : null
const MONTHS_SHORT = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"]
const DAYS_SHORT = ["Sun","Mon","Tue","Wed","Thu","Fri","Sat"]
const tourDateLabel = _tourDate
  ? `${DAYS_SHORT[_tourDate.getUTCDay()]}, ${MONTHS_SHORT[_tourDate.getUTCMonth()]} ${_tourDate.getUTCDate()} · ${String(_tourDate.getUTCHours()).padStart(2,"0")}:${String(_tourDate.getUTCMinutes()).padStart(2,"0")} UTC`
  : ""

const upcomingEventsDisplay = upcomingEvents.map((event) => {
  const startMs = new Date(event.scheduledStart).getTime()
  const endMs = event.scheduledEnd ? new Date(event.scheduledEnd).getTime() : startMs
  const live = event.status === "active" || (startMs <= now && endMs >= now)
  const minsUntil = Math.round((startMs - now) / 60000)
  const urgent = !live && minsUntil >= 0 && minsUntil <= 60
  const h = Math.floor(minsUntil / 60)
  const m = minsUntil % 60
  const timeLabel = live
    ? "Live now"
    : urgent
    ? `in ${minsUntil} min`
    : minsUntil <= 1440
    ? m > 0 ? `in ${h}h${m}m` : `in ${h}h`
    : `in ${Math.round(minsUntil / 1440)}d`
  const guildImage = !event.image && event.guildSlug
    ? guilds.find(g => g.slug === event.guildSlug)?.coverImage
      ?? guilds.find(g => g.slug === event.guildSlug)?.screenshots?.[0]
    : undefined
  return { ...event, image: event.image ?? guildImage, live, urgent, timeLabel, startMs }
}).sort((a, b) => a.startMs - b.startMs)
const eventsToShow = upcomingEventsDisplay
  .filter(e => !(upcomingTourEvent && e.id === upcomingTourEvent.id))
  .filter(e => e.live || (e.startMs - now) <= FEATURED_EVENTS_WINDOW_MS)
  .slice(0, 4)
const articlesToShow = featuredArticles.slice(0, Math.max(0, 4 - eventsToShow.length))
---

<Layout
  title="Where Builders Meet | Awesome constructions and builders in Where Winds Meet"
  description="Community gallery of guild base constructions in Where Winds Meet, ranked by community votes. Find base building inspiration from top builders."
  image={ogImage}
  preloadImage={heroFirst?.img}
  preloadImageSm={heroFirst?.imgSm}
>
  <style is:global>
    body { position: relative; }
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: -1;
      background: radial-gradient(
        ellipse 65% 50% at 50% 22%,
        rgba(34, 211, 238, 0.09) 0%,
        rgba(34, 211, 238, 0.03) 55%,
        transparent 75%
      );
    }
  </style>
  <style>
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(14px) scale(0.98); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    .fade-up {
      opacity: 0;
      animation: fadeUp 0.45s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
    @keyframes eventGlow {
      0%, 100% { box-shadow: 0 0 0 1px rgb(34 211 238 / 0.5), 0 0 10px 0px rgb(34 211 238 / 0); }
      50%       { box-shadow: 0 0 0 1px rgb(34 211 238 / 0.9), 0 0 18px 4px rgb(34 211 238 / 0.2); }
    }
    .event-urgent { animation: eventGlow 2s ease-in-out infinite; }
    @keyframes eventLive {
      0%, 100% { box-shadow: 0 0 0 1px rgb(74 222 128 / 0.5), 0 0 10px 0px rgb(74 222 128 / 0); }
      50%       { box-shadow: 0 0 0 1px rgb(74 222 128 / 0.9), 0 0 18px 4px rgb(74 222 128 / 0.25); }
    }
    .event-live { animation: eventLive 2s ease-in-out infinite; }
  </style>

  <div class="space-y-6">
    <!-- Hero banner -->
    <div class="-mx-4 -mt-4 rounded-2xl relative h-56 sm:h-72 overflow-hidden mb-2">
      <div class="absolute inset-0 bg-muted" />
      <img
        id="hero-img"
        src={heroFirst?.img ?? ""}
        srcset={heroFirst ? `${heroFirst.imgSm} 800w, ${heroFirst.img} 1400w` : ""}
        sizes="100vw"
        alt=""
        fetchpriority="high"
        loading="eager"
        class={`absolute inset-0 w-full h-full object-cover object-center transition-opacity duration-300${heroFirst ? "" : " hidden"}`}
        aria-hidden="true"
      />
      <div class="absolute inset-0 bg-linear-to-t from-black/60 via-black/20 to-black/5 dark:from-black/85 dark:via-black/35 dark:to-black/10" />
      <a
        id="hero-credit"
        href={heroFirst?.href ?? "#"}
        class={`absolute top-3 right-4 items-center gap-1.5 bg-black/40 backdrop-blur-sm border border-white/15 rounded-full px-2.5 py-1 text-xs text-white/70 hover:text-white hover:bg-black/60 transition-all group${heroFirst ? " flex" : " hidden"}`}
        title="View this guild"
        data-umami-event="hero_guild_credit_click"
        data-umami-event-name={heroFirst?.name}
      >
        <span id="hero-label" class="max-w-28 truncate">{heroFirst?.label}</span>
        <span id="hero-builders" class={`text-white/45 text-[11px] max-w-24 truncate shrink-0${heroFirst?.builders ? "" : " hidden"}`}>{heroFirst?.builders ? `by ${heroFirst.builders}` : ""}</span>
        <svg class="size-3 shrink-0 opacity-60 group-hover:opacity-100 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
      </a>
      <script is:inline define:vars={{ heroCandidates }}>
        if (heroCandidates.length > 1) {
          // Defer randomization until idle so heroFirst is always the LCP candidate
          // (preloaded + fetchpriority=high). The swap happens after first paint.
          var doSwap = function() {
            var idx = Math.floor(Math.random() * heroCandidates.length)
            var c = heroCandidates[idx]
            if (idx !== 0 && c) {
              var img = document.getElementById("hero-img")
              if (!img) return
              img.style.opacity = "0"
              img.onload = function() { img.style.opacity = "1" }
              img.srcset = c.imgSm + ' 800w, ' + c.img + ' 1400w'
              img.src = c.img
              var credit = document.getElementById("hero-credit")
              credit.href = c.href
              credit.dataset.umamiEventName = c.name
              document.getElementById("hero-label").textContent = c.label
              var b = document.getElementById("hero-builders")
              if (c.builders) { b.textContent = "by " + c.builders; b.classList.remove("hidden") }
              else { b.classList.add("hidden") }
            }
          }
          if (typeof requestIdleCallback !== "undefined") {
            requestIdleCallback(doSwap)
          } else {
            setTimeout(doSwap, 200)
          }
        }
      </script>
      <a
        id="streaming-section"
        href="https://discord.gg/Qygt9u26Bn"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden absolute top-3 left-4 z-20 group items-center gap-1.5 bg-black/40 backdrop-blur-sm border border-white/15 rounded-full px-2.5 py-1 text-xs text-white/70 hover:text-white hover:bg-black/60 transition-all"
        data-umami-event="streaming_watch_click"
      >
        <BroadcastIcon weight="fill" className="size-4 text-green-300 shrink-0 animate-pulse" />
        <span id="streaming-names"></span><span id="streaming-channel" class="hidden sm:inline"></span>
      </a>
      <script is:inline>
        (function () {
          var STREAMING_URL = "https://raw.githubusercontent.com/coin-au-carre/awesome-wwm-base-building/main/data/streaming.json"
          function update() {
            fetch(STREAMING_URL)
              .then(function (r) { return r.json() })
              .then(function (data) {
                var section = document.getElementById("streaming-section")
                var names = document.getElementById("streaming-names")
                if (!section || !names) return
                var streamers = data.streamers || []
                if (streamers.length === 0) {
                  section.classList.remove("flex")
                  section.classList.add("hidden")
                } else {
                  var byChannel = {}
                  streamers.forEach(function (s) {
                    var ch = s.channelName || "voice"
                    if (!byChannel[ch]) byChannel[ch] = []
                    byChannel[ch].push(s.username)
                  })
                  var parts = Object.entries(byChannel).map(function (entry) {
                    return { names: entry[1].join(", "), channel: entry[0] }
                  })
                  var namesEl = document.getElementById("streaming-names")
                  var channelEl = document.getElementById("streaming-channel")
                  if (namesEl) namesEl.textContent = parts.map(function(p) { return p.names }).join(", ") + " streaming"
                  if (channelEl) channelEl.textContent = parts.map(function(p) { return "in #" + p.channel }).join(" · ")
                  section.classList.remove("hidden")
                  section.classList.add("flex")
                }
              })
              .catch(function () {
                var section = document.getElementById("streaming-section")
                if (section) { section.classList.remove("flex"); section.classList.add("hidden") }
              })
          }
          update()
          setInterval(update, 30000)
        })()
      </script>
      <div class="absolute bottom-0 left-0 right-0 px-6 pb-6">
        <h1 class="font-heading text-2xl sm:text-3xl font-bold text-white drop-shadow mb-1.5 flex items-center gap-3 flex-wrap">
          <span class="flex items-center gap-2"><img src="/images/logo_1.webp" alt="" aria-hidden="true" class="size-14 object-contain" /> Guilds</span>
          <span class="flex items-center gap-2 font-normal text-xs text-white/80">
            <span class="inline-flex items-center gap-1.5 bg-white/10 backdrop-blur-sm border border-white/15 rounded-full px-2.5 py-1">
              <img src="/images/logo_1.webp" alt="" aria-hidden="true" class="size-3 object-contain" /> {guilds.length} guilds
            </span>
            {lastSync && (
              <span class="inline-flex items-center gap-1.5 bg-white/10 backdrop-blur-sm border border-white/15 rounded-full px-2.5 py-1">
                <ArrowsClockwiseIcon weight="fill" className="size-3 text-green-400" />
                {formatSyncDate(lastSync)}
              </span>
            )}
          </span>
        </h1>
        <p class="text-white/65 text-sm">Beautiful constructions in Where Winds Meet</p>
      </div>
    </div>

    <!-- Patch notes banner — set SHOW_PATCH_BANNER = false to restore normal sections -->
    {SHOW_PATCH_BANNER && (
      <section>
        <div class="group relative flex rounded-2xl overflow-hidden ring-1 ring-blue-500/40 hover:ring-blue-500/70 hover:shadow-xl transition-all h-36 sm:h-40">
          {/* background */}
          <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/events/beyond-the-wall/houses_on_hill.webp'); filter: brightness(0.45) saturate(0.7);" />
          <div class="absolute inset-0 bg-linear-to-r from-black/90 via-black/60 to-transparent" />
          <div class="absolute inset-0 bg-linear-to-t from-black/70 via-transparent to-transparent" />
          {/* build thumbnails strip — right side */}
          <div class="absolute right-0 top-0 bottom-0 w-2/5 hidden sm:flex">
            <div class="flex-1 overflow-hidden"><img src="/events/beyond-the-wall/dream_house.webp" alt="" aria-hidden="true" class="w-full h-full object-cover opacity-70" style="mask-image: linear-gradient(to right, transparent 0%, black 40%); -webkit-mask-image: linear-gradient(to right, transparent 0%, black 40%);" /></div>
            <div class="flex-1 overflow-hidden"><img src="/events/beyond-the-wall/coffee.webp" alt="" aria-hidden="true" class="w-full h-full object-cover opacity-70" /></div>
          </div>
          {/* content — z-20 so buttons sit above the background overlay link */}
          <div class="relative z-20 flex flex-col justify-center gap-2 px-6 py-5 max-w-lg">
            <div class="flex items-center gap-2">
              <span class="size-2 rounded-full bg-blue-400 animate-pulse shrink-0" />
              <span class="text-[10px] font-semibold uppercase tracking-widest text-blue-400">Game Update · June 5, 2026</span>
            </div>
            <div>
              <p class="text-base sm:text-lg font-bold text-white leading-tight drop-shadow sm:whitespace-nowrap">
                <span class="sm:hidden">The <span class="text-blue-400">v1.7</span> construction update</span>
                <span class="hidden sm:inline">All you need to know about the <span class="text-blue-400">v1.7</span> construction update</span>
              </p>
              <p class="text-sm text-white/70 mt-1">
                2-axis rotation, component cap increased<span class="hidden sm:inline">, new Kaifeng components</span>. <span class="text-red-300 font-semibold">Avoid wiping your base.</span>
              </p>
            </div>
            <div class="flex items-center gap-2 mt-1 flex-wrap">
              <a
                href={`${BASE}/tutorials/construction-updates-v1-7`}
                class="inline-flex items-center gap-1.5 bg-blue-500/20 ring-1 ring-blue-500/50 rounded-full px-3 py-1 text-xs font-semibold text-blue-200 hover:bg-blue-500/35 transition-colors"
                data-umami-event="patch_banner_click"
              >
                <span class="sm:hidden">Read</span>
                <span class="hidden sm:inline">Read update</span>
              </a>
              <a
                href={`${BASE}/bugs`}
                class="inline-flex items-center gap-1.5 bg-red-500/20 ring-1 ring-red-500/40 rounded-full px-3 py-1 text-xs font-semibold text-red-200 hover:bg-red-500/35 transition-colors"
                data-umami-event="patch_banner_bugs_click"
              >
                <span class="sm:hidden">Bugs</span>
                <span class="hidden sm:inline">Known Bugs</span>
              </a>
              <a
                href="https://discord.gg/Qygt9u26Bn"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 bg-indigo-500/20 ring-1 ring-indigo-500/40 rounded-full px-3 py-1 text-xs text-indigo-200 hover:bg-indigo-500/35 transition-colors"
                data-umami-event="patch_banner_discord_click"
              >
                <span class="sm:hidden">💬 Discord</span>
                <span class="hidden sm:inline">💬 Discuss on Discord ↗</span>
              </a>
            </div>
          </div>
          {/* background clickable area for the rest of the card */}
          <a
            href={`${BASE}/tutorials/construction-updates-v1-7`}
            class="absolute inset-0 z-10"
            aria-hidden="true"
            tabindex="-1"
          />
        </div>
      </section>
    )}

    <!-- Beyond the Wall event banner (temporary) — set SHOW_BEYOND_WALL_EVENT = false to restore normal sections -->
    {SHOW_BEYOND_WALL_EVENT && (
      <section>
        <a
          href={BTW_EVENT.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative flex rounded-2xl overflow-hidden ring-1 ring-pink-500/40 hover:ring-pink-500/70 hover:shadow-xl transition-all h-48 sm:h-44"
          data-umami-event="beyond_wall_event_banner_click"
        >
          {/* background */}
          <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${BTW_EVENT.imgBg}'); filter: brightness(0.45) saturate(0.7);`} />
